@model IEnumerable<Tasarim.Core.Entities.Kampanya>

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-toggle-off text-primary me-2"></i>Kampanyaya Ürün Ata
            </h3>
            <p class="text-muted small mt-1 mb-0">Lütfen ürün eklemek veya çıkarmak istediğiniz kampanyayı seçin.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 w-100">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 ps-4">Kampanya Resmi</th>
                            <th class="text-secondary fw-semibold py-3 ps-4">Başlık</th>
                            <th class="text-secondary fw-semibold text-end pe-4" style="width: 200px;">Kampanya Düzenle</th>
                            <th class="text-secondary fw-semibold text-end pe-4" style="width: 200px;">Ürünleri Yönet</th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                        @if (!string.IsNullOrEmpty(item.KampanyaResmi))
                                        {
                                            <img src="/img/@item.KampanyaResmi" alt="@item.KampanyaAd" class="rounded-3 shadow-sm bg-light p-1" style="width: 60px; height: 60px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                            <div class="bg-light rounded-3 justify-content-center align-items-center text-muted shadow-sm" style="width: 60px; height: 60px; display: none !important;">
                                                <i class="fa-solid fa-image fs-5"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-3 d-flex justify-content-center align-items-center text-muted shadow-sm border border-dashed" style="width: 60px; height: 60px;">
                                                <i class="fa-solid fa-image fs-5 opacity-50"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div>
                                            <div class="fw-bold text-dark fs-6 mb-1">@item.KampanyaAd</div>
                                        </div>
                                    </td>

                                <td class="text-end pe-4">
                                        <a asp-controller="Kampanyalar" asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary " title="Düzenle">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                </td>
                                <td>
                                        <a asp-action="UrunAta" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary rounded-pill px-3" title="Ürünleri Yönet">
                                            <i class="fa-solid fa-toggle-on me-1"></i> Ürünleri Yönet
                                        </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>