@model Tasarim.Core.Entities.Slider

@{
    ViewData["Title"] = "Slider Düzenle";
}

<div class="container-fluid mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-images text-primary me-2"></i>Slider Bilgilerini Güncelle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4 opacity-25" />

                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="SliderResim" />


                        <div class="row g-4">
                            <div class="col-md-6 d-flex flex-column">

                                <div class="form-group mb-3">
                                    <label asp-for="SiraNo" class="form-label fw-semibold text-secondary">Gösterim Sırası</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-list-ol text-muted"></i></span>
                                        <input asp-for="SiraNo" class="form-control border-start-0 ps-0" placeholder="Örn: 1, 2, 3..." />
                                    </div>
                                    <span asp-validation-for="SiraNo" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Baslik" class="form-label fw-semibold text-secondary">Slider Başlığı</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-font text-muted"></i></span>
                                        <input asp-for="Baslik" class="form-control border-start-0 ps-0" placeholder="Örn: Büyük Kış İndirimi Başladı!" />
                                    </div>
                                    <span asp-validation-for="Baslik" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="SliderAciklama" class="form-label fw-semibold text-secondary">Slider Açıklaması</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0 align-items-start pt-3"><i class="fa-solid fa-align-left text-muted"></i></span>
                                        <textarea asp-for="SliderAciklama" class="form-control border-start-0 ps-0" rows="3" placeholder="Slayt üzerinde görünecek alt metni buraya girebilirsiniz..."></textarea>
                                    </div>
                                    <span asp-validation-for="SliderAciklama" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group mb-3 flex-grow-1">
                                    <label asp-for="Link" class="form-label fw-semibold text-secondary">Yönlendirme Linki (URL)</label>
                                    <div class="input-group shadow-sm h-100">
                                        <span class="input-group-text bg-light border-end-0 align-items-start pt-3"><i class="fa-solid fa-link text-muted"></i></span>
                                        <textarea asp-for="Link" class="form-control border-start-0 ps-0" rows="2" placeholder="Örn: /kampanyalar/kis-indirimi veya https://site.com/urun..."></textarea>
                                    </div>
                                    <span asp-validation-for="Link" class="text-danger small mt-1 d-block"></span>
                                </div>

                            </div>

                            <div class="col-md-6">
                                <div class="form-group h-100 p-4 bg-light border border-dashed border-2 rounded-4 shadow-sm d-flex flex-column justify-content-center">

                                    @if (!string.IsNullOrEmpty(Model.SliderResim))
                                    {
                                        <div class="mb-4">
                                            <label class="form-label fw-semibold text-secondary text-start w-100 mb-3">Mevcut Slayt Görseli</label>

                                            <div class="d-flex justify-content-center align-items-center bg-white rounded-3 shadow-sm border p-2 w-100" style="min-height: 250px;">
                                                <img src="/img/@Model.SliderResim" alt="@Model.Baslik" class="img-fluid rounded" style="max-height: 240px; max-width: 100%; object-fit: contain;" />
                                            </div>

                                            <div class="form-check text-start bg-white p-3 rounded-3 border border-danger border-opacity-50 mt-3 shadow-sm transition-all">
                                                <input class="form-check-input ms-1 border-danger" type="checkbox" name="cbResmiSil" value="true" id="cbResmiSil" style="cursor:pointer;">
                                                <label class="form-check-label ms-2 text-danger fw-bold user-select-none" for="cbResmiSil" style="cursor:pointer;">
                                                    <i class="fa-solid fa-trash-can me-1"></i> Mevcut Görseli Sistemden Sil
                                                </label>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted fst-italic mb-4 py-5 text-center bg-white rounded-3 border shadow-sm d-flex flex-column justify-content-center align-items-center" style="min-height: 250px;">
                                            <i class="fa-regular fa-image fs-1 text-secondary opacity-50 mb-2"></i>
                                            <span class="fw-medium">Slayt Görseli Bulunmuyor</span>
                                        </div>
                                    }

                                    <div class="mt-auto">
                                        <label class="form-label fw-semibold text-secondary text-start w-100">Görseli Değiştir veya Ekle</label>
                                        <div class="input-group shadow-sm">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-cloud-arrow-up text-primary"></i></span>
                                            <input name="AnaResimDosyasi" type="file" class="form-control border-start-0 ps-0" accept="image/*" />
                                        </div>
                                        <div class="form-text mt-2 small text-muted">
                                            <i class="fa-solid fa-circle-info me-1"></i>Slayt görselini değiştirmek için yeni bir dosya seçebilirsiniz.
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <div class="col-12">
                                <hr class="text-muted my-4 opacity-25" />
                                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
                                    <a asp-action="Index" class="btn btn-light border px-4 py-2 rounded-pill fw-medium text-secondary w-100 w-sm-auto text-center transition-all hover-shadow">
                                        <i class="fa-solid fa-arrow-left me-2"></i>Slider Listesine Dön
                                    </a>
                                    <button type="submit" class="btn btn-success px-5 py-2 rounded-pill shadow-sm fw-bold w-100 w-sm-auto transition-all">
                                        <i class="fa-solid fa-check-circle me-2"></i>Güncellemeleri Kaydet
                                    </button>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}