@model IEnumerable<Tasarim.Core.Entities.Slider>
@{
}

<div class="container-fluid mt-4 mb-5">
    <!-- Üst Başlık ve Ekle Butonu -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="mb-0 text-dark fw-bold font-playfair letter-spacing-1">
                <i class="fa-solid fa-images text-gold me-2"></i>Slider / Manşet Yönetimi
            </h3>
            <p class="text-muted small mt-1 mb-0 text-uppercase letter-spacing-1">Ana sayfadaki görselleri buradan tek ekranda yönetebilirsiniz.</p>
        </div>

        <button onclick="openModal(0)" class="btn btn-dark rounded-pill px-4 shadow-sm text-nowrap fw-bold letter-spacing-1 hover-gold-bg transition-300">
            <i class="fa-solid fa-plus text-gold me-1"></i> Yeni Slayt Ekle
        </button>
    </div>

    <!-- Slider Tablosu -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div>
            <!-- Tabloya 'luvia-mobile-table' sınıfını ekledik -->
            <table class="table table-hover align-middle mb-0 w-100 luvia-mobile-table">
                <thead class="bg-dark text-white text-uppercase small letter-spacing-1">
                    <tr>
                        <th class="ps-md-4 py-3" style="width: 10%;">Sıra</th>
                        <th class="py-3" style="width: 15%;">Görsel</th>
                        <th class="py-3" style="width: 25%;">Başlık</th>
                        <th class="py-3" style="width: 35%;">Açıklama / Link</th>
                        <th class="pe-md-4 py-3 text-md-end" style="width: 15%;">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @foreach (var item in Model.OrderBy(x => x.SiraNo))
                    {
                        <tr id="row_@item.ID">
                            <!-- Her td içine data-label ekledik, bu sayede mobilde başlıklar otomatik çıkacak -->
                            <td data-label="Sıra No" class="ps-md-4 fw-bold fs-5 text-dark">@item.SiraNo</td>
                            
                            <td data-label="Slayt Görseli">
                                @if(!string.IsNullOrEmpty(item.SliderResim))
                                {
                                    <img src="/img/@item.SliderResim" class="rounded-3 shadow-sm border" style="width: 80px; height: 50px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="rounded-3 bg-light border border-dashed d-flex align-items-center justify-content-center text-muted" style="width: 80px; height: 50px;">
                                        <i class="fa-regular fa-image"></i>
                                    </div>
                                }
                            </td>
                            
                            <td data-label="Başlık" class="fw-medium text-dark">@item.Baslik</td>
                            
                            <td data-label="Açıklama & Link">
                                <div class="small text-muted mb-1 text-truncate" style="max-width: 300px;"><i class="fa-solid fa-align-left me-1 opacity-50"></i>@item.SliderAciklama</div>
                                @if(!string.IsNullOrEmpty(item.Link)){ <div class="small text-primary text-truncate" style="max-width: 300px;"><i class="fa-solid fa-link me-1"></i>@item.Link</div> }
                            </td>
                            
                            <td data-label="İşlemler" class="pe-md-4 text-md-end">
                                <div class="d-flex justify-content-end gap-1">
                                    <button onclick="openModal(@item.ID)" class="btn btn-sm btn-outline-dark rounded-pill px-3" title="Düzenle">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button onclick="deleteSlider(@item.ID)" class="btn btn-sm btn-outline-danger rounded-pill px-3" title="Kalıcı Olarak Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted fst-italic">Henüz bir slider eklenmemiş.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- LUVİA Modal (Ekle/Düzenle Pop-up) -->
<div class="modal fade" id="sliderModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            
            <div class="modal-header bg-dark text-white border-0 py-3 rounded-top-4">
                <h5 class="modal-title font-playfair fw-bold letter-spacing-1" id="modalTitle">
                    <i class="fa-solid fa-images text-gold me-2"></i>Slayt Bilgileri
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="sliderForm" onsubmit="saveSlider(event)">
                @Html.AntiForgeryToken()
                <input type="hidden" id="sliderId" name="ID" value="0" />

                <div class="modal-body p-4 p-md-5">
                    <div class="row g-4">
                        
                        <!-- Sol Taraf: Metin Bilgileri -->
                        <div class="col-md-7 d-flex flex-column gap-3">
                            <div>
                                <label class="form-label small fw-bold text-dark text-uppercase letter-spacing-1">Sıra No</label>
                                <input type="number" id="siraNo" name="SiraNo" class="form-control border-dark-subtle shadow-none" value="1" required />
                            </div>
                            <div>
                                <label class="form-label small fw-bold text-dark text-uppercase letter-spacing-1">Başlık</label>
                                <input type="text" id="baslik" name="Baslik" class="form-control border-dark-subtle shadow-none" placeholder="Örn: Yeni Sezon İndirimi" />
                            </div>
                            <div>
                                <label class="form-label small fw-bold text-dark text-uppercase letter-spacing-1">Açıklama</label>
                                <textarea id="aciklama" name="SliderAciklama" class="form-control border-dark-subtle shadow-none" rows="2" placeholder="Slayt alt metni..."></textarea>
                            </div>
                            <div>
                                <label class="form-label small fw-bold text-dark text-uppercase letter-spacing-1">Yönlendirme Linki</label>
                                <input type="text" id="link" name="Link" class="form-control border-dark-subtle shadow-none" placeholder="Örn: /kategori/abiyeler" />
                            </div>
                        </div>

                        <!-- Sağ Taraf: Görsel Yükleme ve Önizleme -->
                        <div class="col-md-5">
                            <label class="form-label small fw-bold text-dark text-uppercase letter-spacing-1">Slayt Görseli</label>
                            <div class="bg-light border border-dashed border-2 rounded-4 p-3 text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 250px; cursor: pointer;" onclick="document.getElementById('resimInput').click()">
                                
                                <!-- Resim Önizleme Alanı -->
                                <img id="previewImg" src="" style="display:none; max-width: 100%; max-height: 200px; object-fit: contain;" class="rounded-3 shadow-sm mb-3" />
                                
                                <div id="uploadIcon">
                                    <i class="fa-solid fa-cloud-arrow-up fs-1 text-gold mb-2"></i>
                                    <p class="small fw-bold text-dark mb-0">Görsel Seç / Değiştir</p>
                                    <p class="small text-muted mt-1 fst-italic">Tıklayın veya sürükleyin</p>
                                </div>
                            </div>
                            <!-- Gizli Dosya Inputu -->
                            <input type="file" id="resimInput" name="resimDosyasi" class="d-none" accept="image/*" onchange="previewImage(event)" />
                        </div>

                    </div>
                </div>

                <div class="modal-footer border-top border-dark-subtle bg-light p-3 px-md-5">
                    <button type="button" class="btn btn-outline-dark rounded-pill px-4 fw-bold letter-spacing-1" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-dark rounded-pill px-5 fw-bold letter-spacing-1 hover-gold-bg transition-300">
                        <i class="fa-solid fa-check text-gold me-2"></i>KAYDET
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 (Şık Uyarılar İçin) -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        .text-gold { color: #D4AF37 !important; }
        .hover-gold-bg:hover { background-color: #D4AF37 !important; color: white !important; border-color: #D4AF37 !important; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: all 0.3s ease; }

           /* =========================================
           MOBİL KART GÖRÜNÜMÜ CSS KODLARI 
           ========================================= */
        @@media (max-width: 768px) {
            /* Üst başlıkları mobilde tamamen gizle */
            .luvia-mobile-table thead {
                display: none;
            }
            
            /* Her bir satırı (tr) birer karta çevir */
            .luvia-mobile-table tbody tr {
                display: block;
                border: 1px solid #dee2e6;
                border-radius: 12px;
                margin-bottom: 20px;
                background-color: #fff;
                box-shadow: 0 4px 10px rgba(0,0,0,0.08);
                padding: 10px 5px;
            }

            /* Sütunları (td) ALTA ALTA dizecek şekilde ayarla */
            .luvia-mobile-table tbody td {
                display: flex;
                flex-direction: column; /* YAN YANA DEĞİL, ALT ALTA */
                align-items: flex-start;
                border-bottom: 1px solid #f8f9fa;
                padding: 12px 15px;
                text-align: left;
                gap: 8px; /* Başlık ile içerik arasına boşluk */
            }

            .luvia-mobile-table tbody td:last-child {
                border-bottom: none;
            }

            /* Sütun başlıkları (Luvia Gold Rengi) */
            .luvia-mobile-table tbody td::before {
                content: attr(data-label);
                font-weight: 700;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: #D4AF37; /* LUVİA GOLD */
                display: block;
                width: 100%;
            }

            /* Uzun linklerin veya resimlerin dışarı taşmasını KESİN engelle */
            .luvia-mobile-table tbody td > * {
                max-width: 100%;
                word-wrap: break-word;
                white-space: normal;
            }
            
            /* Mobilde butonları sağa değil sola yasla */
            .luvia-mobile-table tbody td .d-flex.justify-content-end {
                justify-content: flex-start !important;
            }
        }
    </style>

    <script>
        let modal = new bootstrap.Modal(document.getElementById('sliderModal'));

        function openModal(id) {
            document.getElementById('sliderForm').reset();
            document.getElementById('sliderId').value = id;
            
            document.getElementById('previewImg').style.display = 'none';
            document.getElementById('previewImg').src = '';
            document.getElementById('uploadIcon').style.display = 'block';

            if(id === 0) {
                document.getElementById('modalTitle').innerHTML = '<i class="fa-solid fa-plus text-gold me-2"></i>Yeni Slayt Ekle';
                modal.show();
            } else {
                document.getElementById('modalTitle').innerHTML = '<i class="fa-solid fa-pen text-gold me-2"></i>Slaytı Düzenle';
                
                fetch('/Admin/Sliderlar/GetSlider/' + id)
                    .then(response => response.json())
                    .then(data => {
                        document.getElementById('siraNo').value = data.siraNo;
                        document.getElementById('baslik').value = data.baslik || '';
                        document.getElementById('aciklama').value = data.sliderAciklama || '';
                        document.getElementById('link').value = data.link || '';
                        
                        if(data.sliderResim) {
                            document.getElementById('previewImg').src = '/img/' + data.sliderResim;
                            document.getElementById('previewImg').style.display = 'block';
                            document.getElementById('uploadIcon').style.display = 'none';
                        }
                        modal.show();
                    });
            }
        }

        function previewImage(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('previewImg').style.display = 'block';
                    document.getElementById('uploadIcon').style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        }

        function saveSlider(e) {
            e.preventDefault();
            const formData = new FormData(document.getElementById('sliderForm'));

            fetch('/Admin/Sliderlar/Save', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    modal.hide();
                    Swal.fire({
                        icon: 'success', title: 'Başarılı!', text: 'Slayt bilgileri başarıyla kaydedildi.', confirmButtonColor: '#000', timer: 1500
                    }).then(() => { window.location.reload(); });
                } else {
                    Swal.fire('Hata', data.message, 'error');
                }
            });
        }

        function deleteSlider(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu slayt ve sunucudaki görseli kalıcı olarak silinecektir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Evet, Kalıcı Olarak Sil!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Admin/Sliderlar/DeleteSlider/' + id, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if(data.success) {
                            document.getElementById('row_' + id).remove();
                            Swal.fire({ icon: 'success', title: 'Silindi', text: 'Slayt ve görseli sunucudan temizlendi.', confirmButtonColor: '#000', timer: 1500 });
                        }
                    });
                }
            });
        }
    </script>
}