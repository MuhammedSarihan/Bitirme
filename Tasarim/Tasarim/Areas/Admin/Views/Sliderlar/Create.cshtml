@model Tasarim.Core.Entities.Slider

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-box-open text-primary me-2"></i>Yeni Slide Ekle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <div class="row g-5">
                            <div class="col-md-6">
                                <h5 class="text-primary mb-3"><i class="fa-solid fa-tag me-2"></i>Temel Bilgiler</h5>

                                <div class="form-group mb-3">
                                    <label asp-for="SiraNo" class="form-label fw-semibold text-secondary">Slide Sıra Numarası</label>
                                    <div class="input-group shadow-sm">
                                        <input asp-for="SiraNo" class="form-control border-start-0 ps-0" placeholder="Örn: 1,2,3..." />
                                    </div>
                                    <span asp-validation-for="SiraNo" class="text-danger small"></span>
                                    <div class="form-text small">Bu numara sadece bu slide'a' ait olmalıdır.</div>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Baslik" class="form-label fw-bold text-dark">Slide Başlığı</label>
                                    <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                        <input asp-for="Baslik" class="form-control border-start-0 ps-0" placeholder="Örn: Beyoğlu Abiye..." />
                                    </div>
                                    <span asp-validation-for="Baslik" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Link" class="form-label fw-semibold text-secondary">Slide Linki</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-primary bg-opacity-10 border-end-0 text-primary"><i class="fa-solid fa-link"></i></span>
                                        <input asp-for="Link" class="form-control border-start-0 ps-0" placeholder="Örn: https://www.beyogluabiye.com" />
                                    </div>
                                    <span asp-validation-for="Link" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="SliderAciklama" class="form-label fw-semibold text-secondary">Slide Açıklaması</label>
                                    <div class="input-group shadow-sm">
                                        <textarea asp-for="SliderAciklama" class="form-control border-start-0 ps-0" placeholder="Örn: Beyoğlu abiyede indirim var..." ></textarea>
                                    </div>
                                    <span asp-validation-for="SliderAciklama" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-info mb-3"><i class="fa-solid fa-layer-group me-2"></i>Slide Görseli</h5>

                                <div class="form-group mb-4 p-3 bg-light border border-dashed rounded-3 shadow-sm">
                                    <label class="form-label fw-bold text-dark mb-2"><i class="fa-regular fa-image me-2 text-primary"></i>Görseli Yükle</label>
                                    <input type="file" name="AnaResimDosyasi" class="form-control form-control-lg" accept="image/*" />
                                    <div class="form-text mt-2 small">Müşterilerin katalogda göreceği ana resmi bilgisayarınızdan seçin.</div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-plus me-2"></i>Kaydet
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}