@model IEnumerable<Tasarim.Core.Entities.UrunVaryasyon>

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-boxes-stacked text-primary me-2"></i>Stok Yönetimi
            </h3>
            <p class="text-muted small mt-1 mb-0">Ürünlerinizin beden, renk ve stok adetlerini buradan yönetebilirsiniz.</p>
        </div>

        <div class="d-flex gap-3 align-items-center">

            <div class="input-group shadow-sm rounded-pill overflow-hidden" style="min-width: 300px; border: 1px solid #dee2e6;">
                <span class="input-group-text bg-white border-0 text-muted ps-3">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="varyasyonArama" class="form-control border-0 shadow-none" placeholder="Ürün adı, kod veya beden ara...">
            </div>

            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm text-nowrap fw-medium">
                <i class="fa-solid fa-plus me-1"></i> Yeni Stok/Beden Ekle
            </a>
        </div>
    </div>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 w-100" id="varyasyonTablosu">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 ps-4">Bağlı Ürün</th>
                            <th class="text-secondary fw-semibold text-center">Beden</th>
                            <th class="text-secondary fw-semibold text-center">Stok Durumu</th>
                            <th class="text-secondary fw-semibold text-end pe-4" style="width: 150px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark fs-6">
                                        <i class="fa-solid fa-box text-muted me-2 small"></i>@item.Urun.Baslik
                                    </div>
                                    <div class="text-muted small ms-4">
                                        <i class="fa-solid fa-barcode me-1 opacity-75"></i>Kod: @item.Urun.UrunKod
                                    </div>
                                </td>

                                <td class="text-center">
                                    <span class="badge bg-dark bg-opacity-10 text-dark border px-3 py-2 fs-6">@item.Beden</span>
                                </td>

                                <td class="text-center">
                                    @if (item.StokAdedi > 10)
                                    {
                                        <span class="badge rounded-pill bg-success px-3 py-2 shadow-sm fs-6">
                                            @item.StokAdedi Adet
                                        </span>
                                    }
                                    else if (item.StokAdedi > 0)
                                    {
                                        <span class="badge rounded-pill bg-warning text-dark px-3 py-2 shadow-sm fs-6" title="Stok azalıyor!">
                                            <i class="fa-solid fa-triangle-exclamation me-1"></i> @item.StokAdedi Adet
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger px-3 py-2 shadow-sm fs-6">
                                            <i class="fa-solid fa-xmark me-1"></i> Tükendi (0)
                                        </span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary " title="Düzenle">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info " title="Detaylar">
                                            <i class="fa-solid fa-magnifying-glass"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger " title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#varyasyonTablosu').DataTable({
                // Tabloyu tamamen Türkçe yapmak için dil dosyası
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json',
                },
                // Sayfalama seçenekleri
                lengthMenu: [10, 25, 50, 100],
                // İlk açılışta Stok Durumuna (veya Koda) göre sıralama yapabilirsin
                order: [[0, 'asc']],
                // Tablonun tasarımının Bootstrap 5 ile tam uyumlu olması için ufak ayarlar
                dom: "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });
        });
    </script>

    <style>
        /* DataTables arama kutusuna odaklanıldığında oluşan mavi çizgiyi hafifletelim */
        .dataTables_filter input {
            border-radius: 0.5rem;
            border: 1px solid #dee2e6;
            padding: 0.375rem 0.75rem;
        }

            .dataTables_filter input:focus {
                border-color: #86b7fe;
                outline: 0;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const aramaKutusu = document.getElementById('varyasyonArama');
            
            aramaKutusu.addEventListener('keyup', function () {
                let filtre = this.value.toLowerCase();
                let satirlar = document.querySelectorAll('#varyasyonTablosu tbody tr'); 

                satirlar.forEach(function (satir) {
                    let satirMetni = satir.textContent.toLowerCase();
                    if (satirMetni.includes(filtre)) {
                        satir.style.display = '';
                    } else {
                        satir.style.display = 'none';
                    }
                });
            });
        });
    </script>
}