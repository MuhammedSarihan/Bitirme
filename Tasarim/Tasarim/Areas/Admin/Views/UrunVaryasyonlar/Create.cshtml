@model Tasarim.Areas.Admin.Models.TopluVaryasyonViewModel

@{
}

<div class="container-fluid mt-4 mb-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold font-playfair letter-spacing-1">
                <i class="fa-solid fa-layer-group text-gold me-2"></i>Toplu Stok Paneli
            </h3>
            <p class="text-muted small mt-1 mb-0 text-uppercase letter-spacing-1">Seçili ürüne ait varyasyonları listeye ekleyip tek seferde kaydedin.</p>
        </div>
        <!-- YENİ ROTA: Listeye Dön butonu artık Ürünler/Index sayfasına gidiyor -->
        <a asp-controller="Urunler" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 fw-bold letter-spacing-1 shadow-sm">
            <i class="fa-solid fa-arrow-left me-2"></i>Kataloğa Dön
        </a>
    </div>

    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                
                <form asp-action="Create" id="varyasyonForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger m-3 rounded-3 shadow-sm" role="alert"></div>

                    <!-- ÜST FORM ALANI (Listeye Ekleme Yeri) -->
                    <div class="card-body bg-light p-4 border-bottom border-dark-subtle">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">
                                <label asp-for="SecilenUrunID" class="form-label small fw-bold text-dark text-uppercase letter-spacing-1 mb-2">
                                    <i class="fa-solid fa-box-open text-gold me-1"></i> Bağlı Ürün
                                </label>
                                <select asp-for="SecilenUrunID" id="urunAramaListesi" class="form-select shadow-none" asp-items="ViewBag.UrunID">
                                    <option value="">-- Ürün Arayın veya Seçin --</option>
                                </select>
                                <span asp-validation-for="SecilenUrunID" class="text-danger small mt-2 d-block"></span>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold text-dark text-uppercase letter-spacing-1 mb-2">
                                    <i class="fa-solid fa-ruler text-gold me-1"></i> Beden
                                </label>
                                <input type="text" id="tempBeden" class="form-control border-dark-subtle shadow-none text-uppercase" style="height: 44px;" placeholder="Örn: 42, M" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small fw-bold text-dark text-uppercase letter-spacing-1 mb-2">
                                    <i class="fa-solid fa-cubes text-gold me-1"></i> Adet
                                </label>
                                <input type="number" id="tempAdet" class="form-control border-dark-subtle shadow-none fw-bold text-center" style="height: 44px;" value="1" min="1" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" id="btnEkle" class="btn btn-dark w-100 fw-bold letter-spacing-1 hover-gold-bg transition-300 shadow-sm" style="height: 44px;">
                                    <i class="fa-solid fa-plus me-1 text-gold"></i> EKLE
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- ALT TABLO VE KAYDET ALANI -->
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-dark text-uppercase small letter-spacing-1">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 40%;">Seçilen Ürün Bilgisi</th>
                                    <th class="py-3 text-center" style="width: 20%;">Beden</th>
                                    <th class="py-3 text-center" style="width: 20%;">Adet</th>
                                    <th class="pe-4 py-3 text-end" style="width: 20%;">İşlem</th>
                                </tr>
                            </thead>
                            <tbody id="varyasyonTableBody" class="bg-white">
                                <!-- JS ile dinamik satırlar buraya gelecek -->
                                <tr id="bosDurum">
                                    <td colspan="4" class="text-center py-5 text-muted fst-italic">
                                        <i class="fa-solid fa-arrow-up d-block fs-3 mb-2 opacity-25"></i>
                                        Yukarıdaki formu kullanarak listeye beden eklemeye başlayın.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="card-footer bg-white border-top border-dark-subtle p-4 d-flex justify-content-between align-items-center">
                        <span class="small text-muted fst-italic">* Eklemek istemediğiniz veya boş kalan satırlar kaydedilmeyecektir.</span>
                        <button type="submit" id="btnKaydet" class="btn btn-dark rounded-pill px-5 py-2 fw-bold letter-spacing-1 hover-gold-bg transition-300 shadow-sm" disabled>
                            <i class="fa-solid fa-check text-gold me-2"></i> VERİTABANINA KAYDET
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Select2 Kurulumu
            $('#urunAramaListesi').select2({
                placeholder: "-- Ürün Kodunu Arayın veya Seçin --",
                allowClear: true,
                width: '100%'
            });

            // YENİ EKLENTİ: Ürünler sayfasından ?urunId=... parametresiyle gelindiyse
            // Select2 içindeki ürünü otomatik olarak seç
            const urlParams = new URLSearchParams(window.location.search);
            const urunId = urlParams.get('urunId');
            if (urunId) {
                $('#urunAramaListesi').val(urunId).trigger('change');
            }

            var satirSayaci = 0;

            // "Ekle" Butonu İşlevi
            $('#btnEkle').click(function(e) {
                e.preventDefault(); 

                var secilenUrunId = $('#urunAramaListesi').val();
                var secilenUrunMetni = $('#urunAramaListesi option:selected').text();
                var beden = $('#tempBeden').val().trim().toUpperCase();
                var adet = $('#tempAdet').val();

                if (!secilenUrunId || !beden || !adet || parseInt(adet) < 1) {
                    alert('Lütfen Ürün, Beden ve Adet bilgisini eksiksiz giriniz.');
                    return;
                }

                // Boş yazısını kaldır
                $('#bosDurum').remove();

                // Güvenli ASP.NET Core Index mühürü
                var indexInput = '<input type="hidden" name="Varyasyonlar.Index" value="' + satirSayaci + '" />';

                // LUVİA konseptine uygun satır tasarımı
                var yeniSatir = '<tr id="satir_' + satirSayaci + '">' +
                    '<td class="ps-4 fw-medium text-dark">' +
                        indexInput +
                        '<input type="hidden" name="Varyasyonlar[' + satirSayaci + '].UrunID" value="' + secilenUrunId + '" />' +
                        '<i class="fa-solid fa-check text-success me-2 opacity-50"></i>' + (secilenUrunMetni !== "-- Ürün Arayın veya Seçin --" ? secilenUrunMetni : secilenUrunId) +
                    '</td>' +
                    '<td class="text-center fw-bold text-dark fs-5">' +
                        beden +
                        '<input type="hidden" name="Varyasyonlar[' + satirSayaci + '].Beden" value="' + beden + '" />' +
                    '</td>' +
                    '<td class="text-center fw-bold text-success">' +
                        adet + ' Adet' +
                        '<input type="hidden" name="Varyasyonlar[' + satirSayaci + '].StokAdedi" value="' + adet + '" />' +
                    '</td>' +
                    '<td class="pe-4 text-end">' +
                        '<button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 btn-sil" title="Bu satırı sil">' +
                            '<i class="fa-solid fa-trash me-1"></i> Sil' +
                        '</button>' +
                    '</td>' +
                '</tr>';

                $('#varyasyonTableBody').append(yeniSatir);
                satirSayaci++; 

                // Kaydet butonunu aktifleştir
                $('#btnKaydet').prop('disabled', false);

                // Formu temizle
                $('#tempBeden').val('');
                $('#tempAdet').val('1');
                $('#tempBeden').focus();
            });

            // Çöp Kutusuyla satır silme işlemi
            $('#varyasyonTableBody').on('click', '.btn-sil', function() {
                $(this).closest('tr').fadeOut(300, function() {
                    $(this).remove();
                    
                    // Tabloda hiç satır kalmadıysa eski haline döndür
                    if($('#varyasyonTableBody tr').length === 0) {
                        $('#btnKaydet').prop('disabled', true);
                        $('#varyasyonTableBody').html(`
                            <tr id="bosDurum">
                                <td colspan="4" class="text-center py-5 text-muted fst-italic">
                                    <i class="fa-solid fa-arrow-up d-block fs-3 mb-2 opacity-25"></i>
                                    Yukarıdaki formu kullanarak listeye beden eklemeye başlayın.
                                </td>
                            </tr>
                        `);
                    }
                });
            });
        });
    </script>

    <style>
        .text-gold { color: #D4AF37 !important; }
        .hover-gold-bg:hover { background-color: #D4AF37 !important; color: white !important; border-color: #D4AF37 !important; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: all 0.3s ease; }
        
        /* Select2 Kütüphanesi LUVİA Özelleştirmesi */
        .select2-container .select2-selection--single {
            height: 44px !important;
            padding: 7px 12px;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            box-shadow: none !important;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 42px !important;
            right: 10px !important;
        }
        .select2-container--default.select2-container--focus .select2-selection--single {
            border-color: #000;
        }
    </style>
}