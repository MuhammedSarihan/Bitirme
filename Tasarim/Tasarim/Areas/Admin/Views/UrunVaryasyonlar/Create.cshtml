@model Tasarim.Core.Entities.UrunVaryasyon

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-layer-group text-primary me-2"></i>Yeni Beden ve Stok Ekle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <div class="form-group mb-2 p-4 bg-light rounded-3 border">
                                    <label asp-for="UrunID" class="form-label fw-bold text-dark fs-5 mb-3">
                                        <i class="fa-solid fa-box text-primary me-2"></i>İşlem Yapılacak Ürün Kodu
                                    </label>

                                    <select asp-for="UrunID" id="urunAramaListesi" class="form-select form-select-lg shadow-sm" asp-items="ViewBag.UrunID">
                                        <option value="">-- Ürün Kodunu Seçiniz Veya Arayınız --</option>
                                    </select>

                                    <span asp-validation-for="UrunID" class="text-danger small mt-2 d-block"></span>
                                    <div class="form-text mt-2 text-muted">
                                        Listedeki ürünler arasından aradığınızı bulmak için kutuya tıklayıp ürün kodunu yazmaya başlayın.
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Beden" class="form-label fw-semibold text-secondary">Beden Ölçüsü</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-ruler text-muted"></i></span>
                                        <input asp-for="Beden" class="form-control border-start-0 ps-0" placeholder="Örn: 38, 40, Standart..." />
                                    </div>
                                    <span asp-validation-for="Beden" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-12 mt-3">
                                <div class="form-group mb-4">
                                    <label asp-for="StokAdedi" class="form-label fw-bold text-success fs-5">Bu Bedenden Kaç Adet Var?</label>
                                    <div class="input-group input-group-lg shadow-sm">
                                        <span class="input-group-text bg-success bg-opacity-10 border-success border-opacity-50 text-success"><i class="fa-solid fa-boxes-stacked"></i></span>
                                        <input asp-for="StokAdedi" class="form-control border-success border-opacity-50 fw-bold text-success" type="number" min="0" placeholder="0" />
                                    </div>
                                    <span asp-validation-for="StokAdedi" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-plus me-2"></i>Stoğu Kaydet
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
            $('#urunAramaListesi').select2({
                placeholder: "-- Ürün Kodunu Arayın veya Seçin --",
                allowClear: true,
                width: '100%' // Bootstrap ile uyumlu olması için %100 genişlik veriyoruz
            });
        });
    </script>

    <style>
        /* Select2 kutusunun yüksekliğini ve kenarlıklarını Bootstrap'e uydurmak için ufak bir makyaj */
        .select2-container .select2-selection--single {
            height: 48px !important;
            padding: 8px 12px;
            border: 1px solid #dee2e6;
            border-radius: 0.5rem;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 46px !important;
            right: 10px !important;
        }
    </style>
}