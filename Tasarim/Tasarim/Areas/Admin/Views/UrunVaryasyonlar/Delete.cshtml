@model Tasarim.Core.Entities.UrunVaryasyon

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="alert alert-danger shadow-sm rounded-4 mb-4 border-0 border-start border-danger border-5" role="alert">
                <h5 class="alert-heading fw-bold mb-2 text-danger">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>Dikkat! Bu İşlem Geri Alınamaz
                </h5>
                <p class="mb-0 text-dark">Aşağıda detayları verilen "<strong>@Model.Beden Beden</strong>" stok kaydını kalıcı olarak silmek üzeresiniz. Lütfen bilgileri kontrol edip işleminizi onaylayın.</p>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-trash-can text-danger me-2"></i>Stok Kaydını Sil
                        </h3>
                        <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill shadow-sm">
                            Kayıt ID: @Model.ID
                        </span>
                    </div>
                    <hr class="text-muted mb-4" />

                    <div class="row g-5">
                        <div class="col-md-6">
                            <h5 class="text-primary mb-3"><i class="fa-solid fa-box-open me-2"></i>Ana Ürün Bilgisi</h5>

                            <div class="bg-light p-4 rounded-3 border h-100 opacity-75">
                                <h5 class="fw-bold text-dark mb-2 text-decoration-line-through text-muted">@Html.DisplayFor(model => model.Urun.Baslik)</h5>
                                <div class="text-muted mb-0">
                                    <i class="fa-solid fa-barcode me-2"></i>Ürün Kodu: <strong class="text-dark">@Html.DisplayFor(model => model.Urun.UrunKod)</strong>
                                </div>

                                @if (!string.IsNullOrEmpty(Model.Urun.AnaResim))
                                {
                                    <div class="mt-3 text-center">
                                        <img src="@Model.Urun.AnaResim" alt="Ürün Görseli" class="img-fluid rounded-3 shadow-sm border opacity-50" style="max-height: 120px; object-fit: contain;" onerror="this.style.display='none';" />
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h5 class="text-danger mb-3"><i class="fa-solid fa-layer-group me-2"></i>Silinecek Varyasyon</h5>

                            <ul class="list-group list-group-flush shadow-sm rounded-3 border">
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-ruler me-2"></i>@Html.DisplayNameFor(model => model.Beden)</span>
                                    <span class="badge bg-dark bg-opacity-10 text-dark border px-3 py-2 fs-6">@Html.DisplayFor(model => model.Beden)</span>
                                </li>

                                <li class="list-group-item px-4 py-4 d-flex justify-content-between align-items-center bg-danger bg-opacity-10 border-danger">
                                    <span class="text-danger fw-bold"><i class="fa-solid fa-boxes-stacked me-2"></i>Kaybedilecek Stok</span>
                                    <span class="badge bg-danger px-4 py-2 shadow-sm fs-5">
                                        @Model.StokAdedi Adet
                                    </span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <hr class="text-muted my-5" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Vazgeç
                        </a>

                        <form asp-action="Delete">
                            <input type="hidden" asp-for="ID" />
                            <button type="submit" class="btn btn-danger px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-trash-can me-2"></i>Kaydı Kalıcı Olarak Sil
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>