

@model Tasarim.Core.Entities.Urun

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-box-open text-primary me-2"></i>Yeni Ürün Ekle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <div class="row g-5">
                            <div class="col-md-6">
                                <h5 class="text-primary mb-3"><i class="fa-solid fa-tag me-2"></i>Temel Bilgiler</h5>

                                <div class="form-group mb-3">
                                    <label asp-for="UrunKod" class="form-label fw-semibold text-secondary">Benzersiz Ürün Kodu (SKU)</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-barcode text-muted"></i></span>
                                        <input asp-for="UrunKod" class="form-control border-start-0 ps-0" placeholder="Örn: BEY3122-SYH" />
                                    </div>
                                    <span asp-validation-for="UrunKod" class="text-danger small"></span>
                                    <div class="form-text small">Bu kod sadece bu renge ait ve benzersiz olmalıdır.</div>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="ModelKodu" class="form-label fw-bold text-dark">Model / Grup Kodu</label>
                                    <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                        <span class="input-group-text bg-primary bg-opacity-10 border-end-0 text-primary"><i class="fa-solid fa-link"></i></span>
                                        <input asp-for="ModelKodu" class="form-control border-start-0 ps-0" placeholder="Örn: BEY3122" />
                                    </div>
                                    <span asp-validation-for="ModelKodu" class="text-danger small"></span>
                                    <div class="form-text small text-primary">Aynı ürünün farklı renklerini birbirine bağlamak için kullanılır (Örn: Tüm renkler için BEY3122 giriniz).</div>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Baslik" class="form-label fw-semibold text-secondary">Ürün Başlığı (Adı)</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-heading text-muted"></i></span>
                                        <input asp-for="Baslik" class="form-control border-start-0 ps-0" placeholder="Örn: Beyoğlu Abiye 3122 Siyah" />
                                    </div>
                                    <span asp-validation-for="Baslik" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Renk" class="form-label fw-semibold text-secondary">Ürün Rengi</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-palette text-muted"></i></span>
                                        <input asp-for="Renk" class="form-control border-start-0 ps-0" placeholder="Örn: Siyah, Kırmızı, Saks Mavisi..." />
                                    </div>
                                    <span asp-validation-for="Renk" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Aciklama" class="form-label fw-semibold text-secondary">Ürün Açıklaması</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-align-left text-muted"></i></span>
                                        <textarea asp-for="Aciklama" class="form-control border-start-0 ps-0" rows="3" placeholder="Kumaş türü, yıkama talimatı vb..."></textarea>
                                    </div>
                                    <span asp-validation-for="Aciklama" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-info mb-3"><i class="fa-solid fa-layer-group me-2"></i>Görsel & Sınıflandırma</h5>

                                <div class="form-group mb-4 p-3 bg-light border border-dashed rounded-3 shadow-sm">
                                    <label class="form-label fw-bold text-dark mb-2"><i class="fa-regular fa-image me-2 text-primary"></i>Ana Görseli Yükle</label>
                                    <input type="file" name="AnaResimDosyasi" class="form-control form-control-lg" accept="image/*" />
                                    <div class="form-text mt-2 small">Müşterilerin katalogda göreceği ana resmi bilgisayarınızdan seçin.</div>
                                </div>
                                <div class="form-group mb-4 p-3 bg-light border border-dashed rounded-3 shadow-sm mt-3">
                                    <label class="form-label fw-bold text-dark mb-2">
                                        <i class="fa-solid fa-images me-2 text-info"></i>Çoklu Galeri Fotoğrafları
                                    </label>
                                    <input type="file" name="EkGorseller" id="ekGorselInput" class="form-control" accept="image/*" multiple />

                                    <div id="boyutUyarisi" class="text-danger small mt-2 fw-bold" style="display:none;">
                                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                        Seçtiğiniz resimlerin toplam boyutu çok yüksek (Max 20MB)! Lütfen daha az veya daha küçük boyutlu resimler seçin.
                                    </div>
                                    <div class="form-text mt-2 small text-muted">Aynı anda en fazla 10 adet ve toplamda 20MB'ı geçmeyecek şekilde seçim yapınız.</div>
                                </div>
                                <div class="form-group mb-4">
                                    <label asp-for="Fiyat" class="form-label fw-bold text-success fs-5">Satış Fiyatı</label>
                                    <div class="input-group input-group-lg shadow-sm">
                                        <span class="input-group-text bg-success bg-opacity-10 border-success border-opacity-50 text-success"><i class="fa-solid fa-turkish-lira-sign"></i></span>
                                        <input asp-for="Fiyat" class="form-control border-success border-opacity-50 fw-bold text-success" type="text" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Fiyat" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="KategoriID" class="form-label fw-semibold text-secondary">Kategori</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-sitemap text-muted"></i></span>
                                        <select asp-for="KategoriID" class="form-select border-start-0 ps-0" asp-items="ViewBag.KategoriID">
                                            <option value="">-- Kategori Seçiniz --</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="KategoriID" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="MarkaID" class="form-label fw-semibold text-secondary">Marka</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-copyright text-muted"></i></span>
                                        <select asp-for="MarkaID" class="form-select border-start-0 ps-0" asp-items="ViewBag.MarkaID">
                                            <option value="">-- Marka Seçiniz --</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="MarkaID" class="text-danger small"></span>
                                </div>

                                <div class="d-flex gap-4 p-3 bg-light rounded-3 shadow-sm border mt-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="AktifMi" id="aktifMiSwitch" checked>
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="aktifMiSwitch">
                                            Müşterilere Göster (Aktif/Pasif)
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-plus me-2"></i>Ürünü Kaydet
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}