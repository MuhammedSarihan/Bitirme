@model Tasarim.Core.Entities.Urun

@{
}

<div class="container-fluid mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            
            <!-- Sayfa Başlığı ve ID -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <div>
                    <h3 class="mb-0 text-dark fw-bold font-playfair">
                        <i class="fa-solid fa-pen-to-square text-gold me-2"></i>Ürün Düzenle
                    </h3>
                    <p class="text-muted small mt-1 mb-0 letter-spacing-1 text-uppercase">Mevcut Ürün Bilgilerini Güncelle</p>
                </div>
                <span class="badge bg-dark text-white px-4 py-2 rounded-pill shadow-sm fw-bold letter-spacing-1 border border-dark-subtle">
                    Ürün ID: @Model.ID
                </span>
            </div>

            <!-- Ana Form Kartı -->
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-4 p-md-5 pb-0 position-relative">
                    
                    <form asp-action="Edit" enctype="multipart/form-data" class="d-flex flex-column h-100">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <!-- Gizli Alanlar -->
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="AnaResim" />

                        <div class="row g-5 mb-5">
                            

                            <div class="col-md-7"> 
                                <h5 class="font-playfair fw-bold mb-4 border-bottom border-light pb-3">
                                    <i class="fa-solid fa-tag text-dark me-2"></i>Temel Bilgiler & Fiyatlandırma
                                </h5>

                                <div class="row">
                                    <div class="col-sm-6 form-group mb-4">
                                        <label asp-for="UrunKod" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Benzersiz Kodu (SKU)</label>
                                        <div class="input-group shadow-sm rounded-2">
                                            <span class="input-group-text bg-light border-dark-subtle border-end-0"><i class="fa-solid fa-barcode text-muted"></i></span>
                                            <input asp-for="UrunKod" class="form-control border-dark-subtle border-start-0 ps-0 shadow-none fw-medium" placeholder="Örn: BEY3122-SYH" />
                                        </div>
                                        <span asp-validation-for="UrunKod" class="text-danger small fw-bold"></span>
                                    </div>

                                    <div class="col-sm-6 form-group mb-4">
                                        <label asp-for="ModelKodu" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Model / Grup Kodu</label>
                                        <div class="input-group shadow-sm rounded-2">
                                            <span class="input-group-text bg-dark border-dark text-white border-end-0"><i class="fa-solid fa-link"></i></span>
                                            <input asp-for="ModelKodu" class="form-control border-dark border-start-0 ps-0 shadow-none fw-bold text-dark" placeholder="Örn: BEY3122" />
                                        </div>
                                        <span asp-validation-for="ModelKodu" class="text-danger small fw-bold"></span>
                                    </div>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="Baslik" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Ürün Başlığı (Adı)</label>
                                    <div class="input-group shadow-sm rounded-2">
                                        <span class="input-group-text bg-light border-dark-subtle border-end-0"><i class="fa-solid fa-heading text-muted"></i></span>
                                        <input asp-for="Baslik" class="form-control border-dark-subtle border-start-0 ps-0 shadow-none fw-medium" placeholder="Örn: Beyoğlu Abiye 3122 Siyah" />
                                    </div>
                                    <span asp-validation-for="Baslik" class="text-danger small fw-bold"></span>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="Renk" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Ürün Rengi</label>
                                    <div class="input-group shadow-sm rounded-2">
                                        <span class="input-group-text bg-light border-dark-subtle border-end-0"><i class="fa-solid fa-palette text-muted"></i></span>
                                        <input asp-for="Renk" class="form-control border-dark-subtle border-start-0 ps-0 shadow-none fw-medium" placeholder="Örn: Siyah, Kırmızı..." />
                                    </div>
                                    <span asp-validation-for="Renk" class="text-danger small fw-bold"></span>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="Aciklama" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Ürün Açıklaması</label>
                                    <div class="input-group shadow-sm rounded-2">
                                        <span class="input-group-text bg-light border-dark-subtle border-end-0 align-items-start pt-2"><i class="fa-solid fa-align-left text-muted"></i></span>
                                        <textarea asp-for="Aciklama" class="form-control border-dark-subtle border-start-0 ps-0 shadow-none" rows="4"></textarea>
                                    </div>
                                    <span asp-validation-for="Aciklama" class="text-danger small fw-bold"></span>
                                </div>

                                <!-- Fiyat, Kategori, Marka (Yan yana 3'lü dizilim) -->
                                <div class="row">
                                    <div class="col-sm-4 form-group mb-4">
                                        <label asp-for="Fiyat" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Satış Fiyatı</label>
                                        <div class="input-group shadow-sm rounded-2">
                                            <span class="input-group-text bg-dark text-gold border-dark"><i class="fa-solid fa-turkish-lira-sign"></i></span>
                                            <input asp-for="Fiyat" class="form-control border-dark fw-bold text-dark shadow-none" type="text" placeholder="0.00" />
                                        </div>
                                        <span asp-validation-for="Fiyat" class="text-danger small fw-bold"></span>
                                    </div>

                                    <div class="col-sm-4 form-group mb-4">
                                        <label asp-for="KategoriID" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Kategori</label>
                                        <select asp-for="KategoriID" class="form-select border-dark-subtle shadow-sm fw-medium" asp-items="ViewBag.KategoriID"></select>
                                        <span asp-validation-for="KategoriID" class="text-danger small fw-bold"></span>
                                    </div>

                                    <div class="col-sm-4 form-group mb-4">
                                        <label asp-for="MarkaID" class="form-label small text-uppercase letter-spacing-1 fw-bold text-muted">Marka</label>
                                        <select asp-for="MarkaID" class="form-select border-dark-subtle shadow-sm fw-medium" asp-items="ViewBag.MarkaID"></select>
                                        <span asp-validation-for="MarkaID" class="text-danger small fw-bold"></span>
                                    </div>
                                </div>

                                <div class="d-flex p-3 bg-light rounded-3 shadow-sm border border-dark-subtle mt-2">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input border-dark" type="checkbox" role="switch" asp-for="AktifMi" id="aktifMiSwitch">
                                        <label class="form-check-label fw-bold small text-uppercase letter-spacing-1 text-dark user-select-none ms-2" style="cursor: pointer;" for="aktifMiSwitch">
                                            Müşterilere Göster (Aktif)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-5"> 
                                <h5 class="font-playfair fw-bold mb-4 border-bottom border-light pb-3">
                                    <i class="fa-solid fa-images text-dark me-2"></i>Görsel Yönetimi
                                </h5>

                                <!-- Ana Görsel Alanı -->
                                <div class="form-group mb-4 p-4 bg-light border border-dark-subtle border-dashed rounded-3">
                                    <span class="d-block small text-uppercase letter-spacing-1 fw-bold text-dark mb-3"><i class="fa-regular fa-image me-2 text-gold"></i>Mevcut Ana Görsel</span>

                                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                                    {
                                        <div class="mb-3 text-center">
                                            <img src="/img/@Model.AnaResim" alt="@Model.Baslik" class="img-fluid rounded shadow-sm bg-white p-2 mb-3 border" style="max-height: 180px; object-fit: contain;" />

                                            <div class="form-check text-start bg-white p-3 rounded-3 border border-danger border-opacity-25 shadow-sm d-inline-block w-100">
                                                <input class="form-check-input ms-1 border-danger" type="checkbox" name="cbResmiSil" value="true" id="cbResmiSil">
                                                <label class="form-check-label ms-2 text-danger fw-bold user-select-none" for="cbResmiSil" style="cursor:pointer;">
                                                    <i class="fa-solid fa-trash-can me-1"></i> Mevcut Ana Resmi Kalıcı Sil
                                                </label>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted fst-italic text-center mb-3 py-4 border bg-white rounded-3"><i class="fa-regular fa-image fs-1 opacity-25"></i><br />Görsel Yok</div>
                                    }

                                    <label class="form-label fw-bold text-dark small mt-2">Görseli Değiştir</label>
                                    <input name="AnaResimDosyasi" type="file" class="form-control border-dark-subtle shadow-sm" accept="image/*" />
                                    <div class="form-text mt-1 small text-muted">Sadece yeni bir resim yüklemek istiyorsanız dosya seçin.</div>
                                </div>

                                <!-- Galeri Alanı -->
                                <div class="form-group mb-4 p-4 bg-light border border-dark-subtle border-dashed rounded-3">
                                    <h6 class="fw-bold text-dark mb-3 small text-uppercase letter-spacing-1"><i class="fa-solid fa-layer-group text-dark me-2"></i>Ürün Galerisi</h6>

                                    @if (Model.Resimler != null && Model.Resimler.Any())
                                    {
                                        <div class="row g-2 mb-3">
                                            @foreach (var resim in Model.Resimler.OrderBy(r => r.SiraNo))
                                            {
                                                <div class="col-4 position-relative">
                                                    <img src="/img/@resim.ResimYolu" class="img-fluid rounded border shadow-sm w-100 bg-white p-1" style="object-fit: cover; aspect-ratio: 3/4;" />

                                                    <button type="submit" asp-action="EkResimSil" asp-route-resimId="@resim.ID" asp-route-urunId="@Model.ID" formnovalidate
                                                            class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle shadow border-white"
                                                            style="width:24px; height:24px; padding:0; display:flex; align-items:center; justify-content:center; border-width: 2px !important;"
                                                            onclick="return confirm('Bu fotoğrafı galeri listesinden kalıcı olarak silmek istediğinize emin misiniz?');">
                                                        <i class="fa-solid fa-xmark" style="font-size: 11px;"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted small fst-italic mb-3 py-3 text-center border bg-white rounded-3"><i class="fa-solid fa-circle-exclamation me-1"></i>Bu ürüne ait ek galeri fotoğrafı bulunmuyor.</div>
                                    }

                                    <label class="form-label fw-bold text-dark small mt-2 border-top border-dark-subtle pt-3 w-100">Galeriye Yeni Fotoğraflar Ekle</label>
                                    <input name="EkGorseller" type="file" class="form-control border-dark-subtle shadow-sm" accept="image/*" multiple />
                                    <div class="form-text mt-1 small text-muted">Aynı anda birden fazla fotoğraf seçebilirsiniz.</div>
                                </div>
                            </div>
                        </div>

                        <div class="position-sticky bottom-0 bg-white py-3 px-4 shadow-lg border-top border-dark-subtle z-3 d-flex justify-content-between align-items-center flex-wrap gap-3" style="margin: 0 -3rem; border-radius: 0 0 1rem 1rem;">
                            
                            <a href="/Admin/Urunler/Index" class="btn btn-light border-dark-subtle px-4 rounded-pill fw-bold text-secondary transition-300">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            
                            <button type="submit" class="btn btn-dark px-5 rounded-pill shadow-sm fw-bold letter-spacing-1 hover-gold-bg transition-300">
                                <i class="fa-solid fa-check me-2 text-gold"></i>DEĞİŞİKLİKLERİ KAYDET
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    
    <style>
        .text-gold { color: #D4AF37 !important; }
        .hover-gold-bg:hover { background-color: #D4AF37 !important; color: white !important; border-color: #D4AF37 !important; }
        .hover-gold:hover { color: #D4AF37 !important; transition: 0.3s; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: all 0.3s ease; }
        .border-dashed { border-style: dashed !important; border-width: 2px !important; }
        
        /* Aktif/Pasif Switch Rengi */
        .form-switch .form-check-input:checked { background-color: #000; border-color: #000; }
        
        /* Inputlara tıklandığındaki mavi çerçeveyi kaldırır, daha zarif siyah yapar */
        .form-control:focus, .form-select:focus {
            border-color: #000;
            box-shadow: 0 0 0 0.25rem rgba(0, 0, 0, 0.1);
        }
    </style>
}