
@model Tasarim.Core.Entities.Urun

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-pen-to-square text-warning me-2"></i>Ürün Düzenle
                        </h3>
                        <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill shadow-sm">
                            Ürün ID: @Model.ID
                        </span>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="AnaResim" />

                        <div class="row g-5">
                            <div class="col-md-6">
                                <h5 class="text-primary mb-3"><i class="fa-solid fa-tag me-2"></i>Temel Bilgiler</h5>

                                <div class="form-group mb-3">
                                    <label asp-for="UrunKod" class="form-label fw-semibold text-secondary">Benzersiz Ürün Kodu (SKU)</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-barcode text-muted"></i></span>
                                        <input asp-for="UrunKod" class="form-control border-start-0 ps-0" placeholder="Örn: BEY3122-SYH" />
                                    </div>
                                    <span asp-validation-for="UrunKod" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="ModelKodu" class="form-label fw-bold text-dark">Model / Grup Kodu</label>
                                    <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                        <span class="input-group-text bg-primary bg-opacity-10 border-end-0 text-primary"><i class="fa-solid fa-link"></i></span>
                                        <input asp-for="ModelKodu" class="form-control border-start-0 ps-0" placeholder="Örn: BEY3122" />
                                    </div>
                                    <span asp-validation-for="ModelKodu" class="text-danger small"></span>
                                    <div class="form-text small text-primary">Aynı modelin farklı renklerini gruplamak için kullanılır.</div>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Baslik" class="form-label fw-semibold text-secondary">Ürün Başlığı (Adı)</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-heading text-muted"></i></span>
                                        <input asp-for="Baslik" class="form-control border-start-0 ps-0" placeholder="Örn: Beyoğlu Abiye 3122 Siyah" />
                                    </div>
                                    <span asp-validation-for="Baslik" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Renk" class="form-label fw-semibold text-secondary">Ürün Rengi</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-palette text-muted"></i></span>
                                        <input asp-for="Renk" class="form-control border-start-0 ps-0" placeholder="Örn: Siyah, Kırmızı..." />
                                    </div>
                                    <span asp-validation-for="Renk" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Aciklama" class="form-label fw-semibold text-secondary">Ürün Açıklaması</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-align-left text-muted"></i></span>
                                        <textarea asp-for="Aciklama" class="form-control border-start-0 ps-0" rows="3"></textarea>
                                    </div>
                                    <span asp-validation-for="Aciklama" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-info mb-3"><i class="fa-solid fa-layer-group me-2"></i>Görsel & Sınıflandırma</h5>

                                <div class="form-group mb-4 text-center p-3 bg-light border border-dashed rounded-3 shadow-sm">
                                    <span class="d-block text-secondary fw-semibold mb-2">Mevcut Ana Görsel</span>

                                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                                    {
                                        <div class="mb-3">
                                            <img src="/img/@Model.AnaResim" alt="@Model.Baslik" class="img-fluid rounded shadow-sm bg-white p-2 mb-2" style="max-height: 120px; object-fit: contain;" />

                                            <div class="form-check text-start bg-danger bg-opacity-10 p-2 rounded-3 border border-danger border-opacity-25 mt-2 d-inline-block w-100">
                                                <input class="form-check-input ms-1 border-danger" type="checkbox" name="cbResmiSil" value="true" id="cbResmiSil">
                                                <label class="form-check-label ms-2 text-danger fw-bold user-select-none" for="cbResmiSil" style="cursor:pointer;">
                                                    <i class="fa-solid fa-trash-can me-1"></i> Resmi Kalıcı Sil
                                                </label>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted fst-italic mb-3 py-4"><i class="fa-regular fa-image fs-1 opacity-25"></i><br />Görsel Yok</div>
                                    }

                                    <label class="form-label fw-semibold text-secondary text-start w-100 mt-2">Görseli Değiştir</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-upload text-muted"></i></span>
                                        <input name="AnaResimDosyasi" type="file" class="form-control border-start-0 ps-0" accept="image/*" />
                                    </div>
                                    <div class="form-text mt-1 small text-start">Sadece yeni bir resim yüklemek istiyorsanız dosya seçin.</div>
                                </div>
                                <div class="form-group mb-4 p-3 bg-light border rounded-3 shadow-sm mt-4">
                                    <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-images text-info me-2"></i>Ürün Galerisi</h6>

                                    @if (Model.Resimler != null && Model.Resimler.Any())
                                    {
                                        <div class="row g-2 mb-3">
                                            @foreach (var resim in Model.Resimler.OrderBy(r => r.SiraNo))
                                            {
                                                <div class="col-4 position-relative">
                                                    <img src="/img/@resim.ResimYolu" class="img-fluid rounded border shadow-sm w-100" style=" object-fit: cover;" />

                                                    <button type="submit" asp-action="EkResimSil" asp-route-resimId="@resim.ID" asp-route-urunId="@Model.ID" formnovalidate
                                                            class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 rounded-circle shadow"
                                                            style="width:24px; height:24px; padding:0; display:flex; align-items:center; justify-content:center;"
                                                            onclick="return confirm('Bu fotoğrafı kalıcı olarak silmek istediğinize emin misiniz?');">
                                                        <i class="fa-solid fa-xmark" style="font-size: 12px;"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted small fst-italic mb-3"><i class="fa-solid fa-circle-exclamation me-1"></i>Bu ürüne ait ek galeri fotoğrafı bulunmuyor.</div>
                                    }

                                    <label class="form-label fw-semibold text-secondary text-start w-100 mt-2 border-top pt-2">Galeriye Yeni Fotoğraflar Ekle</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-folder-plus text-muted"></i></span>
                                        <input name="EkGorseller" type="file" class="form-control border-start-0 ps-0" accept="image/*" multiple />
                                    </div>
                                    <div class="form-text mt-1 small">CTRL tuşuna basılı tutarak birden fazla fotoğraf seçebilirsiniz.</div>
                                </div>
                                <div class="form-group mb-4">
                                    <label asp-for="Fiyat" class="form-label fw-bold text-success fs-5">Satış Fiyatı</label>
                                    <div class="input-group input-group-lg shadow-sm">
                                        <span class="input-group-text bg-success bg-opacity-10 border-success border-opacity-50 text-success"><i class="fa-solid fa-turkish-lira-sign"></i></span>
                                        <input asp-for="Fiyat" class="form-control border-success border-opacity-50 fw-bold text-success" type="text" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Fiyat" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="KategoriID" class="form-label fw-semibold text-secondary">Kategori</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-sitemap text-muted"></i></span>
                                        <select asp-for="KategoriID" class="form-select border-start-0 ps-0" asp-items="ViewBag.KategoriID"></select>
                                    </div>
                                    <span asp-validation-for="KategoriID" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="MarkaID" class="form-label fw-semibold text-secondary">Marka</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-copyright text-muted"></i></span>
                                        <select asp-for="MarkaID" class="form-select border-start-0 ps-0" asp-items="ViewBag.MarkaID"></select>
                                    </div>
                                    <span asp-validation-for="MarkaID" class="text-danger small"></span>
                                </div>

                                <div class="d-flex gap-4 p-3 bg-light rounded-3 shadow-sm border mt-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="AktifMi" id="aktifMiSwitch">
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="aktifMiSwitch">
                                            Müşterilere Göster (Aktif/Pasif)
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-success px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-check me-2"></i>Değişiklikleri Kaydet
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}