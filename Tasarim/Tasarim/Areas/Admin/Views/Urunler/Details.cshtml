
@model Tasarim.Core.Entities.Urun

@{
    ViewData["Title"] = Model.Baslik + " - Ürün Detayları";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-circle-info text-info me-2"></i>Ürün Detayları
                        </h3>
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex gap-2">
                                <a asp-action="Index" class="btn btn-light border px-3 rounded-pill text-secondary" title="Listeye Dön">
                                    <i class="fa-solid fa-arrow-left"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn btn-primary px-3 rounded-pill shadow-sm" title="Ürünü Düzenle">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                            </div>
                            <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill shadow-sm">
                                Ürün ID: @Model?.ID
                            </span>
                        </div>
                    </div>
                    <hr class="text-muted mb-4" />

                    <div class="row g-5">
                        <div class="col-md-7">
                            <h4 class="fw-bold text-dark mb-1">@Html.DisplayFor(model => model.Baslik)</h4>

                            <div class="d-flex gap-3 text-muted mb-4">
                                <span><i class="fa-solid fa-barcode me-1"></i>Kod: <strong>@Html.DisplayFor(model => model.UrunKod)</strong></span>
                                <span class="text-primary"><i class="fa-solid fa-link me-1"></i>Model: <strong>@(string.IsNullOrEmpty(Model.ModelKodu) ? "-" : Model.ModelKodu)</strong></span>
                            </div>

                            <h2 class="text-success fw-bold mb-4">@Model.Fiyat.ToString("C2")</h2>

                            <ul class="list-group list-group-flush shadow-sm rounded-3 border mb-4">
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-palette me-2"></i>Renk</span>
                                    <span class="fw-bold text-dark">@(string.IsNullOrEmpty(Model.Renk) ? "-" : Model.Renk)</span>
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-sitemap me-2"></i>Kategori</span>
                                    <span class="fw-bold text-dark">@Html.DisplayFor(model => model.Kategori.KategoriAd)</span>
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-copyright me-2"></i>Marka</span>
                                    <span class="fw-bold text-dark">@Html.DisplayFor(model => model.Marka.MarkaAd)</span>
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-power-off me-2"></i>Durum</span>
                                    @if (Model.AktifMi)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-75 px-3">Müşterilere Açık</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-75 px-3">Gizli (Pasif)</span>
                                    }
                                </li>
                            </ul>

                            <div class="bg-light p-4 rounded-3 border opacity-75">
                                <h6 class="text-secondary fw-bold mb-2"><i class="fa-solid fa-align-left me-2"></i>Açıklama</h6>
                                <p class="mb-0 text-dark small lh-base">
                                    @(string.IsNullOrEmpty(Model.Aciklama) ? "Bu ürün için henüz bir açıklama girilmemiş." : Model.Aciklama)
                                </p>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="sticky-top" style="top: 20px;">
                                <div class="bg-white p-3 rounded-4 shadow-sm border mb-3 text-center d-flex align-items-center justify-content-center" style="min-height: 400px;">
                                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                                    {
                                        <img src="/img/@Model.AnaResim" id="mainImage" alt="@Model.Baslik" class="img-fluid rounded-3 active-fade" style="max-height: 380px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                        <div class="text-muted small text-center" style="display:none;">
                                            <i class="fa-regular fa-image fs-1 mb-2 text-secondary opacity-50"></i><br />
                                            <span>Görsel Yüklenemedi</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-5">
                                            <i class="fa-regular fa-image fs-1 mb-3 opacity-25" style="font-size: 4rem !important;"></i>
                                            <p class="small mb-0 fst-italic">Görsel Eklenmemiş</p>
                                        </div>
                                    }
                                </div>

                                <div class="d-flex gap-2 overflow-auto pb-2 custom-scrollbar">
                                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                                    {
                                        <div class="thumb-item active" onclick="updateMainImage('/img/@Model.AnaResim', this)">
                                            <img src="/img/@Model.AnaResim" class="rounded border shadow-sm" style="width: 70px; height: 70px; object-fit: cover;" />
                                        </div>
                                    }

                                    @if (Model.Resimler != null && Model.Resimler.Any())
                                    {
                                        @foreach (var resim in Model.Resimler.OrderBy(r => r.SiraNo))
                                        {
                                            <div class="thumb-item" onclick="updateMainImage('/img/@resim.ResimYolu', this)">
                                                <img src="/img/@resim.ResimYolu" class="rounded border shadow-sm" style="width: 70px; height: 70px; object-fit: cover;" />
                                            </div>
                                        }
                                    }
                                </div>
                                <p class="text-center text-muted small mt-2"><i class="fa-solid fa-magnifying-glass-plus me-1"></i> Resimler arasında geçiş yapmak için tıklayın.</p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-3 border-top">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="text-primary mb-0 fw-bold">
                                <i class="fa-solid fa-boxes-stacked me-2"></i>Mevcut Beden ve Stoklar
                            </h4>
                            <a asp-controller="UrunVaryasyonlar" asp-action="Create" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                <i class="fa-solid fa-plus me-1"></i> Yeni Beden Ekle
                            </a>
                        </div>

                        @if (Model.Varyasyonlar != null && Model.Varyasyonlar.Any())
                        {
                            <div class="table-responsive rounded-3 border shadow-sm">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4">Beden</th>
                                            <th class="text-center">Stok Durumu</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var varyasyon in Model.Varyasyonlar.OrderBy(v => v.Beden))
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <span class="badge bg-dark bg-opacity-10 text-dark border px-3 py-2 fs-6">@varyasyon.Beden</span>
                                                </td>
                                                <td class="text-center">
                                                    @if (varyasyon.StokAdedi > 10)
                                                    {
                                                        <span class="badge rounded-pill bg-success px-3 py-2">@varyasyon.StokAdedi Adet</span>
                                                    }
                                                    else if (varyasyon.StokAdedi > 0)
                                                    {
                                                        <span class="badge rounded-pill bg-warning text-dark px-3 py-2"><i class="fa-solid fa-triangle-exclamation me-1"></i> @varyasyon.StokAdedi Adet</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge rounded-pill bg-danger px-3 py-2"><i class="fa-solid fa-xmark me-1"></i> Tükendi (0)</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning shadow-sm rounded-3 border-0 border-start border-warning border-4">
                                <i class="fa-solid fa-circle-exclamation me-2"></i>Bu ürüne ait henüz beden veya stok girilmemiş.
                            </div>
                        }
                    </div>

                    <hr class="text-muted my-5" />
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .thumb-item {
        cursor: pointer;
        transition: 0.3s;
        opacity: 0.6;
        min-width: 70px;
    }

        .thumb-item:hover, .thumb-item.active {
            opacity: 1;
            transform: translateY(-3px);
        }

            .thumb-item.active img {
                border: 2px solid #0d6efd !important;
            }

    .active-fade {
        animation: imgFade 0.4s ease-in-out;
    }

    @@keyframes imgFade {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* Custom Scrollbar for Thumbnails */
    .custom-scrollbar::-webkit-scrollbar {
        height: 5px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }
</style>

@section Scripts {
    <script>
        function updateMainImage(src, element) {
            const mainImg = document.getElementById('mainImage');
            mainImg.src = src;

            // Animasyonu Yenile
            mainImg.classList.remove('active-fade');
            void mainImg.offsetWidth;
            mainImg.classList.add('active-fade');

            // Aktif Sınıfını Güncelle
            document.querySelectorAll('.thumb-item').forEach(item => item.classList.remove('active'));
            element.classList.add('active');
        }
    </script>
}