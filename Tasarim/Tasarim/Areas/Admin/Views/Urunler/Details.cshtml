@model Tasarim.Core.Entities.Urun

@{
}

<div class="container-fluid mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            
            <!-- Sayfa Başlığı ve Butonlar -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <div>
                    <h3 class="mb-0 text-dark fw-bold font-playfair">
                        <i class="fa-solid fa-circle-info text-gold me-2"></i>Ürün Detayları & Stok
                    </h3>
                    <p class="text-muted small mt-1 mb-0 letter-spacing-1 text-uppercase">Ürün Performansı ve Envanter Yönetimi</p>
                </div>
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <span class="badge bg-dark text-white px-4 py-2 rounded-pill shadow-sm fw-bold letter-spacing-1 border border-dark-subtle">
                        Ürün ID: @Model?.ID
                    </span>
                    <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-bold text-secondary transition-300 hover-gold">
                        <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn btn-dark px-4 rounded-pill shadow-sm fw-bold letter-spacing-1 hover-gold-bg transition-300">
                        <i class="fa-solid fa-pen me-2 text-gold"></i>Düzenle
                    </a>
                </div>
            </div>

            <!-- Ana Form Kartı -->
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-4 p-md-5">

                    <div class="row g-5">
                        
                        <!-- 1. SÜTUN: ÜRÜN BİLGİLERİ -->
                        <div class="col-md-7">
                            <h4 class="font-playfair fw-bold text-dark mb-2">@Html.DisplayFor(model => model.Baslik)</h4>

                            <div class="d-flex flex-wrap gap-3 text-muted mb-4 small letter-spacing-1 text-uppercase">
                                <span><i class="fa-solid fa-barcode me-1"></i>Kod: <strong class="text-dark">@Html.DisplayFor(model => model.UrunKod)</strong></span>
                                <span class="text-secondary">|</span>
                                <span><i class="fa-solid fa-link me-1"></i>Model: <strong class="text-dark">@(string.IsNullOrEmpty(Model.ModelKodu) ? "-" : Model.ModelKodu)</strong></span>
                            </div>

                            <h2 class="text-gold font-playfair fw-bold mb-4 border-bottom border-light pb-4">@Model.Fiyat.ToString("C2")</h2>

                            <ul class="list-group list-group-flush shadow-sm rounded-3 border mb-4">
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center bg-light">
                                    <span class="text-secondary fw-bold small text-uppercase letter-spacing-1"><i class="fa-solid fa-palette me-2 text-dark"></i>Renk</span>
                                    <span class="fw-bold text-dark">@(string.IsNullOrEmpty(Model.Renk) ? "-" : Model.Renk)</span>
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center bg-white">
                                    <span class="text-secondary fw-bold small text-uppercase letter-spacing-1"><i class="fa-solid fa-sitemap me-2 text-dark"></i>Kategori</span>
                                    <span class="fw-bold text-dark">@Html.DisplayFor(model => model.Kategori.KategoriAd)</span>
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center bg-light">
                                    <span class="text-secondary fw-bold small text-uppercase letter-spacing-1"><i class="fa-solid fa-copyright me-2 text-dark"></i>Marka</span>
                                    <span class="fw-bold text-dark">@Html.DisplayFor(model => model.Marka.MarkaAd)</span>
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center bg-white">
                                    <span class="text-secondary fw-bold small text-uppercase letter-spacing-1"><i class="fa-solid fa-power-off me-2 text-dark"></i>Durum</span>
                                    @if (Model.AktifMi)
                                    {
                                        <span class="badge rounded-pill bg-dark px-3 text-gold letter-spacing-1">Müşterilere Açık</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger px-3 letter-spacing-1">Gizli (Pasif)</span>
                                    }
                                </li>
                            </ul>

                            <div class="bg-light p-4 rounded-3 border border-dark-subtle border-dashed mt-4">
                                <h6 class="text-dark fw-bold mb-3 small text-uppercase letter-spacing-1"><i class="fa-solid fa-align-left me-2 text-gold"></i>Açıklama</h6>
                                <p class="mb-0 text-secondary small lh-lg">
                                    @(string.IsNullOrEmpty(Model.Aciklama) ? "Bu ürün için henüz bir açıklama girilmemiş." : Model.Aciklama)
                                </p>
                            </div>
                        </div>

                        <!-- 2. SÜTUN: MEDYA (Görseller) -->
                        <div class="col-md-5">
                            <div class="sticky-top" style="top: 20px;">
                                <div class="bg-light p-3 rounded-4 shadow-sm border border-dark-subtle mb-3 text-center d-flex align-items-center justify-content-center" style="min-height: 400px;">
                                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                                    {
                                        <img src="/img/@Model.AnaResim" id="mainImage" alt="@Model.Baslik" class="img-fluid rounded-3 active-fade bg-white p-1 border" style="max-height: 380px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                        <div class="text-muted small text-center" style="display:none;">
                                            <i class="fa-regular fa-image fs-1 mb-2 text-secondary opacity-50"></i><br />
                                            <span>Görsel Yüklenemedi</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-5">
                                            <i class="fa-regular fa-image fs-1 mb-3 opacity-25" style="font-size: 4rem !important;"></i>
                                            <p class="small mb-0 fst-italic">Görsel Eklenmemiş</p>
                                        </div>
                                    }
                                </div>

                                <div class="d-flex gap-2 overflow-auto pb-2 custom-scrollbar justify-content-center">
                                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                                    {
                                        <div class="thumb-item active" onclick="updateMainImage('/img/@Model.AnaResim', this)">
                                            <img src="/img/@Model.AnaResim" class="rounded border shadow-sm bg-white p-1" style="width: 70px; height: 70px; object-fit: cover;" />
                                        </div>
                                    }

                                    @if (Model.Resimler != null && Model.Resimler.Any())
                                    {
                                        @foreach (var resim in Model.Resimler.OrderBy(r => r.SiraNo))
                                        {
                                            <div class="thumb-item" onclick="updateMainImage('/img/@resim.ResimYolu', this)">
                                                <img src="/img/@resim.ResimYolu" class="rounded border shadow-sm bg-white p-1" style="width: 70px; height: 70px; object-fit: cover;" />
                                            </div>
                                        }
                                    }
                                </div>
                                <p class="text-center text-muted small mt-2"><i class="fa-solid fa-magnifying-glass-plus me-1"></i> Resimler arasında geçiş yapmak için tıklayın.</p>
                            </div>
                        </div>
                    </div>

                    <!-- STOK VE BEDEN YÖNETİMİ -->
                    <div class="mt-5 pt-5 border-top border-dark-subtle">
                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                            <h4 class="font-playfair fw-bold text-dark mb-0">
                                <i class="fa-solid fa-boxes-stacked me-2 text-gold"></i>Beden & Stok Durumu
                            </h4>
                            <button type="button" onclick="openYeniBedenModal()" class="btn btn-outline-dark rounded-pill px-4 fw-bold letter-spacing-1 hover-gold-bg transition-300">
    <i class="fa-solid fa-plus me-1"></i> Yeni Beden Ekle
</button>
                        </div>

                        @if (Model.Varyasyonlar != null && Model.Varyasyonlar.Any())
                        {
                            <div class="table-responsive rounded-4 border border-dark-subtle shadow-sm overflow-hidden">
                                <table class="table table-hover align-middle mb-0 bg-white">
                                    <thead class="bg-dark text-white">
                                        <tr>
                                            <th class="ps-4 py-3 fw-semibold small text-uppercase letter-spacing-1">Beden</th>
                                            <th class="text-center py-3 fw-semibold small text-uppercase letter-spacing-1">Stok Durumu</th>
                                            <th class="text-end pe-4 py-3 fw-semibold small text-uppercase letter-spacing-1">İşlem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var varyasyon in Model.Varyasyonlar.OrderBy(v => v.Beden))
                                        {
                                            <tr>
                                                <td class="ps-4 py-3">
                                                    <span class="badge bg-light text-dark border border-dark-subtle px-3 py-2 fs-6 shadow-sm">@varyasyon.Beden</span>
                                                </td>
                                                <td class="text-center py-3">
                                                    @if (varyasyon.StokAdedi > 10)
                                                    {
                                                        <span id="stokBadge_@varyasyon.ID" class="badge rounded-pill bg-success px-4 py-2 shadow-sm fs-6">@varyasyon.StokAdedi Adet</span>
                                                    }
                                                    else if (varyasyon.StokAdedi > 0)
                                                    {
                                                        <span id="stokBadge_@varyasyon.ID" class="badge rounded-pill bg-warning text-dark px-4 py-2 shadow-sm fs-6"><i class="fa-solid fa-triangle-exclamation me-1"></i> @varyasyon.StokAdedi Adet Kaldı</span>
                                                    }
                                                    else
                                                    {
                                                        <span id="stokBadge_@varyasyon.ID" class="badge rounded-pill bg-danger px-4 py-2 shadow-sm fs-6"><i class="fa-solid fa-xmark me-1"></i> Tükendi (0)</span>
                                                    }
                                                </td>
                                                <td class="text-end pe-4 py-3">
                                                    <!-- HIZLI STOK GÜNCELLEME BUTONU -->
                                                    <button onclick="openStokModal(@varyasyon.ID, '@varyasyon.Beden', @varyasyon.StokAdedi)" class="btn btn-sm btn-outline-dark hover-gold-bg transition-300 rounded-pill px-3 fw-bold">
                                                        <i class="fa-solid fa-bolt me-1 text-gold"></i> Hızlı Stok
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert bg-light border border-dark-subtle border-dashed shadow-sm rounded-4 text-center py-5">
                                <i class="fa-solid fa-box-open fs-1 text-muted opacity-50 mb-3"></i>
                                <h6 class="font-playfair fw-bold text-dark">Bu ürüne ait henüz beden veya stok girilmemiş.</h6>
                            </div>
                        }
                    </div>
                    <!-- YORUMLAR -->
                    <div class="mt-5 pt-5 border-top border-dark-subtle">
                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                            <h4 class="font-playfair fw-bold text-dark mb-0">
                                <i class="fa-solid fa-comments me-2 text-gold"></i>Müşteri Yorumları
                            </h4>
                            <span class="badge bg-dark text-white rounded-pill px-3 py-2 fw-bold">@(Model.Yorumlar?.Count ?? 0) Yorum</span>
                        </div>

                        @if (Model.Yorumlar != null && Model.Yorumlar.Any())
                        {
                            <div class="list-group shadow-sm rounded-4 border-0">
                                @foreach (var yorum in Model.Yorumlar.OrderByDescending(y => y.Tarih))
                                {
                                    <div class="list-group-item list-group-item-action p-4 border border-dark-subtle mb-2 rounded-4 bg-light">
                                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                            <div>
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    <h6 class="fw-bold text-dark mb-0">@(yorum.Profil?.Ad ?? "Bilinmeyen") @(yorum.Profil?.Soyad ?? "Kullanıcı")</h6>
                                                    <span class="text-muted small"><i class="fa-regular fa-clock me-1"></i> @yorum.Tarih.ToString("dd.MM.yyyy HH:mm")</span>
                                                </div>

                                                <div class="text-gold small mb-3">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= yorum.Puan) { <i class="fa-solid fa-star"></i> }
                                                        else { <i class="fa-regular fa-star text-muted opacity-25"></i> }
                                                    }
                                                </div>

                                                <p class="mb-0 text-secondary fst-italic">"@yorum.YorumIcerik"</p>
                                            </div>

                                            <form asp-action="AdminYorumSil" asp-controller="Urunler" method="post" class="m-0 p-0" onsubmit="return confirm('UYARI: Bu müşteri yorumunu kalıcı olarak silmek istediğinize emin misiniz?');">
                                                <input type="hidden" name="YorumID" value="@yorum.ID" />
                                                <input type="hidden" name="UrunID" value="@Model.ID" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm bg-white">
                                                    <i class="fa-solid fa-trash-can me-1"></i> Sil
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert bg-light border border-dark-subtle border-dashed shadow-sm rounded-4 text-center py-4">
                                <i class="fa-regular fa-comment-dots fs-2 text-muted opacity-50 mb-2"></i>
                                <p class="mb-0 text-secondary small fw-bold">Bu ürüne henüz müşteri yorumu yapılmamış.</p>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- HIZLI STOK GÜNCELLEME MODALI -->
<div class="modal fade" id="hizliStokModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white border-0 py-3 rounded-top-4">
                <h6 class="modal-title font-playfair fw-bold letter-spacing-1"><i class="fa-solid fa-bolt text-gold me-2"></i> Stok Güncelle</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="small fw-bold text-muted mb-1">Seçili Beden</p>
                <h4 id="modalBedenText" class="fw-bold text-dark mb-4">-</h4>
                
                <input type="hidden" id="hs_VaryasyonID" />
                
                <label class="small fw-bold text-muted mb-2">Yeni Stok Adedi</label>
                <div class="input-group mb-4 shadow-sm rounded-2">
                    <span class="input-group-text bg-light border-dark-subtle"><i class="fa-solid fa-boxes-stacked"></i></span>
                    <input type="number" id="hs_YeniStok" class="form-control form-control-lg text-center fw-bold border-dark-subtle" min="0" />
                </div>
                
                <button onclick="stokKaydet()" class="btn btn-dark w-100 rounded-pill fw-bold letter-spacing-1 hover-gold-bg transition-300">
                    KAYDET
                </button>
            </div>
        </div>
    </div>
</div>

<!-- YENİ BEDEN EKLEME MODALI -->

<div class="modal fade" id="yeniBedenModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white border-0 py-3 rounded-top-4">
                <h6 class="modal-title font-playfair fw-bold letter-spacing-1"><i class="fa-solid fa-plus text-gold me-2"></i> Yeni Beden Ekle</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="yb_UrunID" value="@Model.ID" />

                <div class="form-group mb-3">
                    <label class="small fw-bold text-muted mb-1 text-uppercase letter-spacing-1">Beden</label>
                    <input type="text" id="yb_Beden" class="form-control form-control-lg fw-bold border-dark-subtle" placeholder="Örn: 38, S, XL" />
                </div>

                <div class="form-group mb-4">
                    <label class="small fw-bold text-muted mb-1 text-uppercase letter-spacing-1">Başlangıç Stok Adedi</label>
                    <div class="input-group shadow-sm rounded-2">
                        <span class="input-group-text bg-light border-dark-subtle"><i class="fa-solid fa-boxes-stacked"></i></span>
                        <input type="number" id="yb_Stok" class="form-control form-control-lg text-center fw-bold border-dark-subtle" min="0" value="0" />
                    </div>
                </div>

                <button onclick="yeniBedenKaydet()" class="btn btn-dark w-100 rounded-pill fw-bold letter-spacing-1 hover-gold-bg transition-300">
                    SİSTEME EKLE
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <style>
        .text-gold { color: #D4AF37 !important; }
        .hover-gold-bg:hover { background-color: #D4AF37 !important; color: white !important; border-color: #D4AF37 !important; }
        .hover-gold:hover { color: #D4AF37 !important; transition: 0.3s; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: all 0.3s ease; }
        .border-dashed { border-style: dashed !important; border-width: 2px !important; }

        /* Custom Gallery Thumbnails */
        .thumb-item {
            cursor: pointer;
            transition: 0.3s;
            opacity: 0.6;
            min-width: 70px;
        }
        .thumb-item:hover, .thumb-item.active {
            opacity: 1;
            transform: translateY(-3px);
        }
        .thumb-item.active img {
            border: 2px solid #D4AF37 !important; 
        }

        .active-fade {
            animation: imgFade 0.4s ease-in-out;
        }

        @@keyframes imgFade {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        
        .custom-scrollbar::-webkit-scrollbar { height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f8f9fa; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #6c757d; }
    </style>

    <script>
        // GALERİ RESİM DEĞİŞTİRME MANTIĞI
        function updateMainImage(src, element) {
            const mainImg = document.getElementById('mainImage');
            mainImg.src = src;

            mainImg.classList.remove('active-fade');
            void mainImg.offsetWidth;
            mainImg.classList.add('active-fade');

            document.querySelectorAll('.thumb-item').forEach(item => item.classList.remove('active'));
            element.classList.add('active');
        }

        // HIZLI STOK GÜNCELLEME MANTIĞI (AJAX)
        let stokModal;

        function openStokModal(id, beden, mevcutStok) {
            document.getElementById('hs_VaryasyonID').value = id;
            document.getElementById('modalBedenText').innerText = beden + " Beden";
            document.getElementById('hs_YeniStok').value = mevcutStok;
            
            if (!stokModal) {
                stokModal = new bootstrap.Modal(document.getElementById('hizliStokModal'));
            }
            stokModal.show();
            
            // Modal açılınca input'a odaklan
            setTimeout(() => { document.getElementById('hs_YeniStok').focus(); }, 400);
        }

        function stokKaydet() {
            const id = document.getElementById('hs_VaryasyonID').value;
            const yeniStok = document.getElementById('hs_YeniStok').value;

            fetch('/Admin/Urunler/HizliStokGuncelle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: parseInt(id), stok: parseInt(yeniStok) })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Sayfayı yenilemeden tablodaki rozeti (badge) güncelle
                    const badge = document.getElementById('stokBadge_' + id);
                    
                    // Stoğun sayısına göre rengi ve metni ayarla
                    if(data.yeniStok > 10) {
                        badge.className = "badge rounded-pill bg-success px-4 py-2 shadow-sm fs-6";
                        badge.innerHTML = data.yeniStok + " Adet";
                    } 
                    else if (data.yeniStok > 0) {
                        badge.className = "badge rounded-pill bg-warning text-dark px-4 py-2 shadow-sm fs-6";
                        badge.innerHTML = '<i class="fa-solid fa-triangle-exclamation me-1"></i> ' + data.yeniStok + ' Adet Kaldı';
                    } 
                    else {
                        badge.className = "badge rounded-pill bg-danger px-4 py-2 shadow-sm fs-6";
                        badge.innerHTML = '<i class="fa-solid fa-xmark me-1"></i> Tükendi (0)';
                    }
                    
                    stokModal.hide();
                } else {
                    alert('Hata: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Hata:', error);
                alert('Sistemsel bir hata oluştu.');
            });
        }
        // --- YENİ BEDEN EKLEME FONKSİYONLARI ---
    let yeniBedenModalObj;

    function openYeniBedenModal() {
        // Modal açılırken içini temizle
        document.getElementById('yb_Beden').value = '';
        document.getElementById('yb_Stok').value = '0';

        if (!yeniBedenModalObj) {
            yeniBedenModalObj = new bootstrap.Modal(document.getElementById('yeniBedenModal'));
        }
        yeniBedenModalObj.show();

        // Açıldığında imleci Beden kutusuna konumlandır
        setTimeout(() => { document.getElementById('yb_Beden').focus(); }, 400);
    }

    function yeniBedenKaydet() {
        const urunId = document.getElementById('yb_UrunID').value;
        const beden = document.getElementById('yb_Beden').value.trim();
        const stok = document.getElementById('yb_Stok').value;

        if (!beden) {
            alert("Lütfen bir beden bilgisi giriniz.");
            return;
        }

        fetch('/Admin/Urunler/HizliBedenEkle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ urunId: parseInt(urunId), beden: beden, stok: parseInt(stok) })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                yeniBedenModalObj.hide();
                // İşlem başarılıysa bedeni tabloya yansıtmak için sayfayı saliseler içinde yeniler
                window.location.reload(); 
            } else {
                alert('Hata: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Hata:', error);
            alert('Sistemsel bir hata oluştu.');
        });
    }
    </script>
}