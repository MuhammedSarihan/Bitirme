@model Tasarim.Core.Entities.Urun

@{
}

<div class="container-fluid mt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="card border-0 shadow-lg rounded-4 bg-white overflow-hidden">
                <!-- Tehlike Başlığı (Kırmızı) -->
                <div class="bg-danger bg-opacity-10 border-bottom border-danger border-opacity-25 p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger text-white rounded-circle mb-3 shadow-sm" style="width: 70px; height: 70px;">
                        <i class="fa-solid fa-triangle-exclamation fs-1"></i>
                    </div>
                    <h3 class="font-playfair fw-bold text-danger mb-1">Ürünü Sil / Arşivle</h3>
                    <p class="text-danger opacity-75 small fw-bold text-uppercase letter-spacing-1 mb-0">Bu işlem geri alınamaz!</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    
                    <!-- Bilgilendirme Kutusu (Soft Delete Mantığını Açıklar) -->
                    <div class="alert bg-light border border-dark-subtle border-dashed rounded-3 p-4 mb-5 text-center">
                        <h6 class="text-dark fw-bold mb-3"><i class="fa-solid fa-shield-halved text-gold me-2"></i>Sistem Koruması Devrede</h6>
                        <p class="text-secondary small mb-0 lh-lg">
                            Müşterilerinizin eski sipariş geçmişlerinin ve fatura raporlarının bozulmaması için bu ürün sistemden <strong>kökten silinmeyecektir.</strong> <br/>
                            Bunun yerine vitrinden gizlenecek (Pasife alınacak) ve sunucuda yer kaplamaması için <strong>tüm görselleri kalıcı olarak yok edilecektir.</strong>
                        </p>
                    </div>

                    <!-- Silinecek Ürünün Kısa Özeti -->
                    <div class="d-flex align-items-center gap-4 bg-white p-3 rounded-3 border border-dark-subtle shadow-sm mb-5">
                        @if (!string.IsNullOrEmpty(Model.AnaResim))
                        {
                            <img src="/img/@Model.AnaResim" class="rounded-3 border" style="width: 80px; height: 80px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light rounded-3 d-flex justify-content-center align-items-center text-muted border" style="width: 80px; height: 80px;">
                                <i class="fa-regular fa-image fs-3 opacity-50"></i>
                            </div>
                        }
                        
                        <div>
                            <h5 class="fw-bold text-dark mb-1 font-playfair">@Model.Baslik</h5>
                            <div class="text-muted small">
                                <span class="me-3"><i class="fa-solid fa-barcode me-1"></i> @Model.UrunKod</span>
                                <span class="text-gold fw-bold">@Model.Fiyat.ToString("C2")</span>
                            </div>
                        </div>
                    </div>

                    <!-- İşlem Butonları -->
                    <form asp-action="Delete" method="post" class="d-flex justify-content-between align-items-center mt-2 border-top border-dark-subtle pt-4">
                        <input type="hidden" asp-for="ID" />
                        
                        <a asp-action="Index" class="btn btn-light border-dark-subtle px-4 rounded-pill fw-bold text-secondary transition-300">
                            <i class="fa-solid fa-arrow-left me-2"></i>Vazgeç, Geri Dön
                        </a>
                        
                        <button type="submit" class="btn btn-danger px-5 rounded-pill shadow-sm fw-bold letter-spacing-1 transition-300">
                            <i class="fa-solid fa-trash-can me-2"></i> ÜRÜNÜ ARŞİVLE
                        </button>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <style>
        .text-gold { color: #D4AF37 !important; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: all 0.3s ease; }
        .border-dashed { border-style: dashed !important; border-width: 2px !important; }
    </style>
}