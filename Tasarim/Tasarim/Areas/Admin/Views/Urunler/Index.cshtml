@{
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="mb-0 text-dark fw-bold font-playfair">
                <i class="fa-solid fa-boxes-stacked text-gold me-2"></i>Ürün Kataloğu
            </h3>
            <p class="text-muted small mt-1 mb-0 letter-spacing-1 text-uppercase">Mağazanızdaki Tüm Ürünlerin Yönetimi</p>
        </div>

        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a href="/Admin/Urunler/Create" class="btn btn-dark rounded-pill px-4 shadow-sm text-nowrap fw-bold letter-spacing-1 hover-gold-bg transition-300">
                <i class="fa-solid fa-plus me-1"></i> Yeni Ürün Ekle
            </a>
        </div>
    </div>

    <!-- Filtreleme Çubuğu -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-light">
        <div class="card-body p-3 d-flex gap-3 flex-wrap align-items-center">
            
            <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white" style="flex: 1; min-width: 250px; border: 1px solid #dee2e6;">
                <span class="input-group-text bg-white border-0 text-muted ps-3">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="filtreArama" class="form-control border-0 shadow-none" placeholder="Ürün adı, kod veya renk ara...">
            </div>

            <select id="filtreKategori" class="form-select shadow-sm rounded-pill border-0 text-muted" style="width: auto; min-width: 180px;">
                <option value="">Tüm Kategoriler</option>
                @if (ViewBag.Kategoriler != null)
                {
                    foreach (var kat in ViewBag.Kategoriler)
                    {
                        <option value="@kat.ID">@kat.KategoriAd</option>
                    }
                }
            </select>

            <select id="filtreMarka" class="form-select shadow-sm rounded-pill border-0 text-muted" style="width: auto; min-width: 180px;">
                <option value="">Tüm Markalar</option>
                @if (ViewBag.Markalar != null)
                {
                    foreach (var marka in ViewBag.Markalar)
                    {
                        <option value="@marka.ID">@marka.MarkaAd</option>
                    }
                }
            </select>

           <div class="form-check form-switch ms-1 mb-0 d-flex align-items-center gap-2">
    <input class="form-check-input cursor-pointer border-dark shadow-sm m-0" type="checkbox" id="chkSadeceAktif" style="width: 2.5em; height: 1.25em;">
    <label class="form-check-label small fw-bold text-dark cursor-pointer text-uppercase letter-spacing-1 mt-1" for="chkSadeceAktif">Sadece Aktifler</label>
</div>

        </div>
    </div>

    <!-- Ürünler Tablosu -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="fw-semibold py-3 ps-4 rounded-top-start text-uppercase small letter-spacing-1">Ürün Bilgisi</th>
                            <th class="fw-semibold text-center text-uppercase small letter-spacing-1">Renk</th>
                            <th class="fw-semibold text-uppercase small letter-spacing-1">Kategori & Marka</th>
                            <th class="fw-semibold text-uppercase small letter-spacing-1">Fiyat</th>
                            <th class="fw-semibold text-center text-uppercase small letter-spacing-1">Durum</th>
                            <th class="fw-semibold text-end pe-4 rounded-top-end text-uppercase small letter-spacing-1" style="width: 180px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody id="tabloGövdesi">
                        <tr><td colspan="6" class="text-center py-5 text-muted"><div class="spinner-border text-dark" role="status"></div><br/>Yükleniyor...</td></tr>
                    </tbody>
                </table>
            </div>
            
            <!-- Sayfalama (Pagination) -->
            <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center rounded-bottom-4">
                <div class="small text-muted fw-bold" id="kayitBilgisi">0 kayıt bulunuyor.</div>
                <nav>
                    <ul class="pagination pagination-sm mb-0" id="sayfalamaAlani">
                        <!-- JS ile dolacak -->
                    </ul>
                </nav>
            </div>

        </div>
    </div>
</div>

<!-- HIZLI FİYAT MODALI (Değişmedi) -->
<div class="modal fade" id="hizliFiyatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white border-0 py-3 rounded-top-4">
                <h6 class="modal-title font-playfair fw-bold letter-spacing-1"><i class="fa-solid fa-bolt text-gold me-2"></i> Hızlı Fiyat</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p id="modalUrunBaslik" class="small fw-bold text-muted mb-3"></p>
                <input type="hidden" id="hf_UrunID" />
                <div class="input-group mb-3">
                    <span class="input-group-text bg-light fw-bold border-dark-subtle">₺</span>
                    <input type="number" id="hf_YeniFiyat" class="form-control form-control-lg text-center fw-bold border-dark-subtle" step="0.01" />
                </div>
                <button onclick="fiyatKaydet()" class="btn btn-dark w-100 rounded-pill fw-bold letter-spacing-1 hover-gold-bg transition-300">
                    GÜNCELLE
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .text-gold { color: #D4AF37 !important; }
        .hover-gold-bg:hover { background-color: #D4AF37 !important; color: white !important; border-color: #D4AF37 !important; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: all 0.3s ease; }
        .page-link { color: #000; border-color: #dee2e6; cursor: pointer; }
        .page-item.active .page-link { background-color: #000; border-color: #000; color: white; }
    </style>
    <script>
        // SUNUCU TARAFLI ARAMA VE SAYFALAMA MİMARİSİ
    let aktifSayfa = 1;
    const sayfaBoyutu = 10; // İstersen 20 yapabilirsin
    let aramaZamanlayici;

    const filtreArama = document.getElementById('filtreArama');
    const filtreKategori = document.getElementById('filtreKategori');
    const filtreMarka = document.getElementById('filtreMarka');
    
    // YENİ: Şalter elementini alıyoruz
    const chkSadeceAktif = document.getElementById('chkSadeceAktif');

    // Tarayıcı hafızasından kullanıcının son seçimini oku
    const sayfaAnahtari = 'filtre_aktif_urunler_sayfasi';
    const kaydedilmisAyar = localStorage.getItem(sayfaAnahtari);
    
    // Eğer hafızada ayar varsa onu uygula, ilk kez giriyorsa varsayılan olarak açık (true) bırak
    if (chkSadeceAktif) {
        chkSadeceAktif.checked = kaydedilmisAyar !== null ? (kaydedilmisAyar === 'true') : true;
    }

    // Verileri API'den (Controller'dan) çekme fonksiyonu
    function urunleriGetir() {
        const arama = filtreArama.value;
        const katId = filtreKategori.value;
        const markaId = filtreMarka.value;
        
        // YENİ: Şalter açıksa sadece aktifleri (true) yolla, kapalıysa hepsini getirmesi için boş yolla
        const durum = chkSadeceAktif.checked ? 'true' : '';

        // Kullanıcının şalter seçimini tarayıcı hafızasına kaydet
        localStorage.setItem(sayfaAnahtari, chkSadeceAktif.checked);

        // Arka planda sunucuya istek atıyoruz
        const url = `/Admin/Urunler/GetUrunler?arama=${encodeURIComponent(arama)}&kategoriId=${katId}&markaId=${markaId}&durum=${durum}&sayfa=${aktifSayfa}&sayfaBoyutu=${sayfaBoyutu}`;

        fetch(url)
            .then(response => response.json())
            .then(data => {
                tabloyuCiz(data.urunler);
                sayfalamayiCiz(data.toplamSayfa, data.mevcutSayfa);
                document.getElementById('kayitBilgisi').innerText = `Toplam ${data.toplamKayit} ürün bulundu.`;
            });
    }

    // HTML tablosunu JSON verisiyle baştan çizen fonksiyon
    function tabloyuCiz(urunler) {
        const tbody = document.getElementById('tabloGövdesi');
        tbody.innerHTML = ''; // Önceki satırları temizle

        if(urunler.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5 text-muted">Arama kriterlerine uygun ürün bulunamadı.</td></tr>`;
            return;
        }

        urunler.forEach(u => {
            const resimHtml = u.anaResim 
                ? `<img src="/img/${u.anaResim}" alt="${u.baslik}" class="rounded-3 shadow-sm bg-light p-1" style="width: 60px; height: 60px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />                   <div class="bg-light rounded-3 justify-content-center align-items-center text-muted shadow-sm" style="width: 60px; height: 60px; display: none !important;"><i class="fa-solid fa-image fs-5"></i></div>`
                : `<div class="bg-light rounded-3 d-flex justify-content-center align-items-center text-muted shadow-sm border border-dashed" style="width: 60px; height: 60px;"><i class="fa-solid fa-image fs-5 opacity-50"></i></div>`;

            const renkHtml = u.renk 
                ? `<span class="badge bg-light text-dark border px-3 py-2 fs-6 shadow-sm">${u.renk}</span>` 
                : `<span class="text-muted fst-italic small">-</span>`;

            const durumHtml = u.aktifMi
                ? `<span class="badge rounded-pill bg-success px-3 shadow-sm">Aktif</span>`
                : `<span class="badge rounded-pill bg-danger px-3 shadow-sm">Pasif</span>`;

            const tr = document.createElement('tr');
            tr.innerHTML = `                <td class="ps-4">                    <div class="d-flex align-items-center gap-3">                        ${resimHtml}                        <div>                            <div class="fw-bold text-dark fs-6 mb-1">${u.baslik}</div>                            <div class="text-muted small mb-1"><i class="fa-solid fa-barcode me-1 opacity-75"></i>Kod: <strong class="text-dark">${u.urunKod}</strong></div>                            <div class="text-secondary small"><i class="fa-solid fa-link me-1 opacity-75"></i>Model: ${u.modelKodu || '-'}</div>                        </div>                    </div>                </td>                <td class="text-center">${renkHtml}</td>                <td>                    <div class="small fw-medium text-dark"><i class="fa-solid fa-layer-group text-muted me-2 opacity-75"></i>${u.kategoriAd}</div>                    <div class="small text-muted mt-1"><i class="fa-solid fa-copyright me-2 opacity-75"></i>${u.markaAd}</div>                </td>                <td>                    <span id="fiyatGosterge_${u.id}" class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fs-6 fw-bold shadow-sm">                        ${u.fiyatFormatli}                    </span>                </td>                <td class="text-center">${durumHtml}</td>                <td class="text-end pe-4">                    <div class="d-inline-flex gap-1">                        <button onclick="openHizliFiyatModal(${u.id}, '${u.baslik.replace(/'/g, "\\'")}', '${u.fiyatHam}')" class="btn btn-sm btn-outline-warning text-dark border-warning hover-gold-bg" title="Hızlı Fiyat Güncelle">                            <i class="fa-solid fa-bolt"></i>                        </button>                        <a href="/Admin/Urunler/Edit/${u.id}" class="btn btn-sm btn-outline-dark" title="Düzenle"><i class="fa-solid fa-pen"></i></a>                        <a href="/Admin/Urunler/Details/${u.id}" class="btn btn-sm btn-outline-secondary" title="Detaylar & Stok"><i class="fa-solid fa-list-check"></i></a>                        <a href="/Admin/Urunler/Delete/${u.id}" class="btn btn-sm btn-outline-danger" title="Sil"><i class="fa-solid fa-trash"></i></a>                    </div>                </td>            `;
            tbody.appendChild(tr);
        });
    }

    // Alt taraftaki (1,2,3, İleri, Geri) butonlarını çizen fonksiyon
    function sayfalamayiCiz(toplamSayfa, mevcutSayfa) {
        const ul = document.getElementById('sayfalamaAlani');
        ul.innerHTML = '';
            
        if(toplamSayfa <= 1) return;

        // Önceki Butonu
        ul.innerHTML += `<li class="page-item ${mevcutSayfa === 1 ? 'disabled' : ''}"><a class="page-link" onclick="sayfaDegistir(${mevcutSayfa - 1})"><i class="fa-solid fa-chevron-left"></i></a></li>`;
            
        // Sayfa Numaraları
        for(let i = 1; i <= toplamSayfa; i++) {
            ul.innerHTML += `<li class="page-item ${i === mevcutSayfa ? 'active' : ''}"><a class="page-link" onclick="sayfaDegistir(${i})">${i}</a></li>`;
        }

        // Sonraki Butonu
        ul.innerHTML += `<li class="page-item ${mevcutSayfa === toplamSayfa ? 'disabled' : ''}"><a class="page-link" onclick="sayfaDegistir(${mevcutSayfa + 1})"><i class="fa-solid fa-chevron-right"></i></a></li>`;
    }

    function sayfaDegistir(sayfa) {
        aktifSayfa = sayfa;
        urunleriGetir();
    }

    // FİLTRE TETİKLENMELERİ
    filtreKategori.addEventListener('change', () => { aktifSayfa = 1; urunleriGetir(); });
    filtreMarka.addEventListener('change', () => { aktifSayfa = 1; urunleriGetir(); });
    chkSadeceAktif.addEventListener('change', () => { aktifSayfa = 1; urunleriGetir(); }); // YENİ: Şalter değişimi
        
    // Klavye ile arama yaparken her harfte istek atmamak için gecikme (Debounce) ekledik
    filtreArama.addEventListener('keyup', () => {
        clearTimeout(aramaZamanlayici);
        aramaZamanlayici = setTimeout(() => {
            aktifSayfa = 1;
            urunleriGetir();
        }, 300); // Kullanıcı yazmayı bıraktıktan 0.3 saniye sonra arar
    });

    // Sayfa ilk yüklendiğinde verileri getir
    document.addEventListener('DOMContentLoaded', urunleriGetir);

    // --- HIZLI FİYAT MODALI FONKSİYONLARI ---
    let fiyatModal;
    function openHizliFiyatModal(id, baslik, mevcutFiyat) {
        document.getElementById('hf_UrunID').value = id;
        document.getElementById('modalUrunBaslik').innerText = baslik;
        document.getElementById('hf_YeniFiyat').value = mevcutFiyat;
            
        if (!fiyatModal) fiyatModal = new bootstrap.Modal(document.getElementById('hizliFiyatModal'));
        fiyatModal.show();
        setTimeout(() => { document.getElementById('hf_YeniFiyat').focus(); }, 400);
    }

    function fiyatKaydet() {
        const id = document.getElementById('hf_UrunID').value;
        const yeniFiyat = document.getElementById('hf_YeniFiyat').value;

        fetch('/Admin/Urunler/HizliFiyatGuncelle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(id), fiyat: parseFloat(yeniFiyat) })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('fiyatGosterge_' + id).innerText = data.formatliFiyat;
                fiyatModal.hide();
            } else alert('Hata: ' + data.message);
        })
        .catch(error => alert('Sistemsel bir hata oluştu.'));
    }
    </script>
    
}