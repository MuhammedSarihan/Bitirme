

@model IEnumerable<Tasarim.Core.Entities.Urun>

@{
    ViewData["Title"] = "";
}
<p>Ürün resimleri silindiğinde sunucudan da silinecek</p>
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-boxes-stacked text-primary me-2"></i>Ürün Kataloğu
            </h3>
            <p class="text-muted small mt-1 mb-0">Mağazanızdaki tüm ana ürünleri (renk ve model bazlı) buradan yönetebilirsiniz.</p>
        </div>

        <div class="d-flex gap-3 align-items-center">

            <div class="input-group shadow-sm rounded-pill overflow-hidden" style="min-width: 300px; border: 1px solid #dee2e6;">
                <span class="input-group-text bg-white border-0 text-muted ps-3">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="hizliArama" class="form-control border-0 shadow-none" placeholder="Ürün adı, kod veya renk ara...">
            </div>

            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm text-nowrap fw-medium">
                <i class="fa-solid fa-plus me-1"></i> Yeni Ürün Ekle
            </a>
        </div>
    </div>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 w-100" id="urunlerTablosu">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 ps-4">Ürün Bilgisi</th>
                            <th class="text-secondary fw-semibold text-center">Renk</th>
                            <th class="text-secondary fw-semibold">Kategori & Marka</th>
                            <th class="text-secondary fw-semibold">Fiyat</th>
                            <th class="text-secondary fw-semibold text-center">Durum</th>
                            <th class="text-secondary fw-semibold text-end pe-4" style="width: 150px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.AnaResim))
                                        {
                                            <img src="/img/@item.AnaResim" alt="@item.Baslik" class="rounded-3 shadow-sm bg-light p-1" style="width: 60px; height: 60px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                            <div class="bg-light rounded-3 justify-content-center align-items-center text-muted shadow-sm" style="width: 60px; height: 60px; display: none !important;">
                                                <i class="fa-solid fa-image fs-5"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-3 d-flex justify-content-center align-items-center text-muted shadow-sm border border-dashed" style="width: 60px; height: 60px;">
                                                <i class="fa-solid fa-image fs-5 opacity-50"></i>
                                            </div>
                                        }

                                        <div>
                                            <div class="fw-bold text-dark fs-6 mb-1">@item.Baslik</div>
                                            <div class="text-muted small mb-1">
                                                <i class="fa-solid fa-barcode me-1 opacity-75"></i>Kod: <strong class="text-dark">@item.UrunKod</strong>
                                            </div>
                                            <div class="text-primary small">
                                                <i class="fa-solid fa-link me-1 opacity-75"></i>Model: @(string.IsNullOrEmpty(item.ModelKodu) ? "-" : item.ModelKodu)
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.Renk))
                                    {
                                        <span class="badge bg-dark bg-opacity-10 text-dark border px-3 py-2 fs-6">@item.Renk</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">-</span>
                                    }
                                </td>

                                <td>
                                    <div class="small fw-medium text-dark"><i class="fa-solid fa-layer-group text-muted me-2 opacity-75"></i>@item.Kategori.KategoriAd</div>
                                    <div class="small text-muted mt-1"><i class="fa-solid fa-copyright me-2 opacity-75"></i>@item.Marka.MarkaAd</div>
                                </td>

                                <td>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fs-6 fw-bold">
                                        @item.Fiyat.ToString("C2")
                                    </span>
                                </td>

                                <td class="text-center">
                                    @if (item.AktifMi)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-75 px-3 shadow-sm">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-75 px-3 shadow-sm">Pasif</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary " title="Düzenle">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info " title="Detaylar">
                                            <i class="fa-solid fa-magnifying-glass"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger " title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#urunlerTablosu').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json',
                },
                lengthMenu: [10, 25, 50, 100],
                order: [[0, 'asc']], // İlk açılışta ürün adına göre sıralar
                dom: "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });
        });
    </script>

    <style>
        .dataTables_filter input {
            border-radius: 0.5rem;
            border: 1px solid #dee2e6;
            padding: 0.375rem 0.75rem;
        }

            .dataTables_filter input:focus {
                border-color: #86b7fe;
                outline: 0;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const aramaKutusu = document.getElementById('hizliArama');

            aramaKutusu.addEventListener('keyup', function () {
                let filtre = this.value.toLowerCase(); // Yazılanı küçük harfe çevir
                // Tablodaki tüm satırları al (thead hariç)
                let satirlar = document.querySelectorAll('#urunlerTablosu tbody tr');

                satirlar.forEach(function (satir) {
                    // Satırın içindeki tüm metni al
                    let satirMetni = satir.textContent.toLowerCase();

                    // Eğer aranan kelime satırda varsa göster, yoksa gizle
                    if (satirMetni.includes(filtre)) {
                        satir.style.display = '';
                    } else {
                        satir.style.display = 'none';
                    }
                });
            });
        });
    </script>
}