@model Tasarim.Core.Entities.Siparis
@{ 
    Layout = null; // Menü, footer vs. hiçbir şey yüklenmesin
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>Sipariş Fişi - #@Model.SiparisNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap');
        body { background: #fff; color: #000; font-family: Arial, sans-serif; padding: 20px; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .fis-container { max-width: 800px; margin: 0 auto; border: 1px solid #ddd; padding: 30px; }
        
        /* Yazıcı Ayarları */
        @@media print {
            body { padding: 0; margin: 0; }
            .fis-container { border: none; padding: 0; }
            .no-print { display: none !important; }
            @@page { margin: 1cm; }
        }
    </style>
</head>
<body onload="window.print()"> <!-- Sayfa açılır açılmaz yazdırma ekranı gelir -->

    <div class="no-print mb-4 text-center">
        <button onclick="window.print()" class="btn btn-dark rounded-0 px-4">YAZDIR</button>
        <button onclick="window.close()" class="btn btn-outline-danger rounded-0 px-4 ms-2">KAPAT</button>
    </div>

    <div class="fis-container">
        <div class="row border-bottom border-dark pb-3 mb-4">
            <div class="col-6">
                <h2 class="font-playfair fw-bold mb-0">LUVIA LUKKA</h2>
                <small class="text-uppercase" style="letter-spacing: 1px;">E-Ticaret Sipariş Fişi</small>
            </div>
            <div class="col-6 text-end">
                <h5 class="fw-bold mb-1">#@Model.SiparisNo</h5>
                <p class="mb-0 small">Tarih: @Model.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</p>
                <p class="mb-0 small fw-bold">Durum: @Model.SiparisDurumu?.DurumAd</p>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-6">
                <h6 class="fw-bold border-bottom d-inline-block pb-1">ALICI BİLGİLERİ</h6>
                <p class="mb-1 mt-2"><strong>Ad Soyad:</strong> @Model.Kullanici?.Profil?.Ad @Model.Kullanici?.Profil?.Soyad</p>
                <p class="mb-1"><strong>Telefon:</strong> @Model.Kullanici?.Profil?.TelNo</p>
                <p class="mb-0"><strong>Adres:</strong> @Model.TeslimatAdresi</p>
            </div>
        </div>

        <table class="table table-bordered table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ürün Kodu</th>
                    <th>Ürün Adı</th>
                    <th>Varyasyon</th>
                    <th class="text-center">Adet</th>
                    <th class="text-end">Tutar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.SiparisDetaylari) {
                    <tr>
                        <td>@d.Urun.UrunKod</td>
                        <td>@d.Urun.Baslik</td>
                        <td>@(d.UrunVaryasyon?.Beden ?? "-") / @(d.Urun?.Renk ?? "-")</td>
                        <td class="text-center">@d.Adet</td>
                        <td class="text-end">@d.BirimFiyat.ToString("N2") TL</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row justify-content-end mt-4">
            <div class="col-4 text-end">
                <h5 class="fw-bold">TOPLAM: @Model.ToplamTutar.ToString("N2") TL</h5>
            </div>
        </div>
        
        <div class="text-center mt-5 pt-3 border-top small text-muted">
            Bu belge LUVIA LUKKA otomasyon sistemi tarafından oluşturulmuştur.
        </div>
    </div>

</body>
</html>