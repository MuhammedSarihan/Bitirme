@model IEnumerable<Tasarim.Core.Entities.Siparis>
@{ 
    ViewData["Title"] = "Sipariş Yönetimi";
}

<div class="container-fluid py-4">
    <!-- Tablo -->
    <div class="card border-dark-subtle rounded-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="siparisTablosu">
                <thead class="bg-light border-bottom border-dark-subtle">
                    <tr>
                        <th class="ps-4">No</th>
                        <th>Müşteri</th>
                        <th>Tarih</th>
                        <th>Tutar</th>
                        <th>Durum Yönetimi</th>
                        <th class="text-end pe-4">Aksiyonlar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        var isLocked = item.SiparisDurumuID >= 4; // Teslim (4) veya İptal (5) kilitlidir.                        
                        <!-- ANA SATIR -->
                        <tr class="border-bottom border-light">
                            <td class="ps-4 fw-bold">#@item.SiparisNo</td>
                            <td>
                                <strong>@item.Kullanici?.Profil?.Ad @item.Kullanici?.Profil?.Soyad</strong><br>
                                <small class="text-muted">@item.Kullanici?.Profil?.TelNo</small>
                            </td>
                            <td>@item.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-bold text-gold">@item.ToplamTutar.ToString("N2") TL</td>
                            <td>
                                <!-- AKILLI SELECT KUTUSU -->
                                <select class="form-select form-select-sm border-dark-subtle fw-bold quick-status" 
                                        data-id="@item.ID" 
                                        @(isLocked ? "disabled" : "") style="width: 160px;">
                                    
                                    @foreach (var d in ViewBag.Durumlar) {
                                        if (d.ID >= item.SiparisDurumuID || d.ID == 5)
                                        {
                                            <option value="@d.ID" selected="@(item.SiparisDurumuID == d.ID)">@d.DurumAd</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm">
                                    <button type="button" class="btn btn-sm btn-outline-dark rounded-0" data-bs-toggle="collapse" data-bs-target="#detay-@item.ID" title="Sipariş İçeriği">
                                        <i class="fa-solid fa-chevron-down"></i>
                                    </button>
                                    
                                    <a asp-action="Detay" asp-route-id="@item.ID" class="btn btn-sm btn-dark rounded-0 text-uppercase" style="font-size: 0.75rem; padding-top: 6px;">İncele</a>
                                    
                                    <a asp-action="FisYazdir" asp-route-id="@item.ID" target="_blank" class="btn btn-sm btn-outline-dark rounded-0" title="Fiş Çıktısı Al">
                                        <i class="fa-solid fa-receipt text-gold"></i> Fiş
                                    </a>
                                </div>
                            </td>
                        </tr>

                        <!-- GİZLİ DETAY SATIRI -->
                        <tr class="collapse bg-light border-bottom border-dark" id="detay-@item.ID">
                            <td colspan="6" class="p-0">
                                <div class="p-4 border-start border-4 border-warning">
                                    <h6 class="font-playfair fw-bold mb-3 small text-uppercase text-muted"><i class="fa-solid fa-box-open me-2"></i> Sipariş İçeriği Önizlemesi</h6>
                                    <table class="table table-sm table-borderless mb-0 w-75">
                                        <thead class="text-muted small border-bottom">
                                            <tr>
                                                <th>Ürün Kodu</th>
                                                <th>Kategori</th>
                                                <th>Beden / Renk</th>
                                                <th>Adet</th>
                                                <th class="text-end">Tutar</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var d in item.SiparisDetaylari) {
                                                <tr>
                                                    <td class="fw-bold">@d.Urun.UrunKod</td>
                                                    <td>@(d.Urun.Kategori?.KategoriAd ?? "Belirtilmemiş")</td>
                                                    <td>@(d.UrunVaryasyon?.Beden ?? "-") / @(d.Urun?.Renk ?? "-")</td>
                                                    <td>@d.Adet</td>
                                                    <td class="text-end fw-bold">@((d.Adet * d.BirimFiyat).ToString("N2")) TL</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 Kütüphanesi -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        .font-playfair { font-family: 'Playfair Display', serif; }
        .text-gold { color: #D4AF37 !important; }
        .collapse.show { background-color: #fafafa; }
        /* SweetAlert LUVİA Uyumu */
        .swal2-confirm { background-color: #000 !important; border-radius: 0 !important; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; }
        .swal2-cancel { border-radius: 0 !important; text-transform: uppercase; font-size: 0.8rem; }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const selectBoxes = document.querySelectorAll('.quick-status');

            selectBoxes.forEach(function (selectBox) {
                selectBox.addEventListener('change', function () {
                    const id = this.getAttribute('data-id');
                    const yeniDurumId = this.value;
                    const originalValue = this.getAttribute('data-current') || yeniDurumId;

                    // EĞER "KARGOLANDI" SEÇİLDİYSE (ID: 3 olduğunu varsayıyorum)
                    if (yeniDurumId == "3") {
                        Swal.fire({
                            title: 'KARGO BİLGİSİ',
                            text: 'Lütfen kargo takip numarasını giriniz:',
                            input: 'text',
                            inputPlaceholder: 'Takip No (Opsiyonel)',
                            showCancelButton: true,
                            confirmButtonText: 'GÜNCELLE',
                            cancelButtonText: 'İPTAL',
                            confirmButtonColor: '#000',
                            cancelButtonColor: '#6c757d',
                        }).then((result) => {
                            if (result.isConfirmed) {
                                // Kullanıcı onayladıysa veriyi gönder
                                sendUpdate(id, yeniDurumId, result.value, selectBox);
                            } else {
                                // İptal ettiyse selectbox'ı eski haline döndür
                                window.location.reload();
                            }
                        });
                    } else {
                        // Diğer durumlar için doğrudan gönder
                        sendUpdate(id, yeniDurumId, null, selectBox);
                    }
                });
            });

            function sendUpdate(id, yeniDurumId, kargoNo, element) {
                element.disabled = true;

                const formData = new URLSearchParams();
                formData.append('id', id);
                formData.append('yeniDurumId', yeniDurumId);
                if (kargoNo) formData.append('kargoNo', kargoNo);

                fetch('/Admin/Siparis/HizliDurumGuncelle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: formData.toString()
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Başarılı',
                            text: 'Sipariş durumu güncellendi.',
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire('Hata', data.message, 'error').then(() => {
                            window.location.reload();
                        });
                    }
                })
                .catch(error => {
                    console.error('Hata:', error);
                    Swal.fire('Hata', 'İşlem başarısız oldu.', 'error').then(() => {
                        window.location.reload();
                    });
                });
            }
        });
    </script>
}