
@model Tasarim.Core.Entities.Kategori

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="alert alert-danger shadow-sm rounded-4 mb-4 border-0 border-start border-danger border-5" role="alert">
                <h5 class="alert-heading fw-bold mb-2 text-danger">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>Dikkat! Bu İşlem Geri Alınamaz
                </h5>
                <p class="mb-0 text-dark">Aşağıda detayları verilen kategoriyi kalıcı olarak silmek üzeresiniz. Lütfen bilgileri kontrol edip işleminizi onaylayın.</p>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-trash-can text-danger me-2"></i>Kategori Sil
                        </h3>
                        <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill shadow-sm">
                            Kayıt ID: @Model.ID
                        </span>
                    </div>
                    <hr class="text-muted mb-4" />

                    <div class="row g-4">
                        <div class="col-md-7">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-tag me-2"></i>@Html.DisplayNameFor(model => model.KategoriAd)</span>
                                    <span class="fw-bold text-dark fs-5">@Html.DisplayFor(model => model.KategoriAd)</span>
                                </li>

                                <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-arrow-down-1-9 me-2"></i>@Html.DisplayNameFor(model => model.SiraNo)</span>
                                    <span class="fw-medium badge bg-light border text-dark">@Html.DisplayFor(model => model.SiraNo)</span>
                                </li>

                                <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-sitemap me-2"></i>Üst Kategori</span>
                                    @if (Model.UstKategori != null)
                                    {
                                        <a asp-action="Details" asp-route-id="@Model.UstKategoriID" class="text-decoration-none fw-bold">
                                            @Model.UstKategori.KategoriAd <i class="fa-solid fa-arrow-up-right-from-square ms-1 small"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 rounded-pill">Ana Kategori</span>
                                    }
                                </li>

                                <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-power-off me-2"></i>Durum</span>
                                    @if (Model.AktifMi)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-75 px-3">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-75 px-3">Pasif</span>
                                    }
                                </li>

                                <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-bars me-2"></i>Menüde Göster</span>
                                    @if (Model.UstteGoster)
                                    {
                                        <span class="badge rounded-pill bg-info text-dark px-3">Evet</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-light text-secondary border px-3">Hayır</span>
                                    }
                                </li>
                            </ul>
                        </div>

                        <div class="col-md-5 d-flex flex-column align-items-center justify-content-center bg-light rounded-3 p-4 border border-dashed">
                            <span class="text-secondary fw-semibold mb-3">@Html.DisplayNameFor(model => model.KategoriResmi)</span>

                            @if (!string.IsNullOrEmpty(Model.KategoriResmi))
                            {
                                <img src="@Model.KategoriResmi" alt="@Model.KategoriAd" class="img-fluid rounded-3 shadow-sm mb-2 opacity-50" style="max-height: 200px; object-fit: cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                <div class="text-muted small text-break text-center" style="display:none;">
                                    <i class="fa-regular fa-image fs-1 mb-2 text-secondary opacity-50"></i><br />
                                    <span class="fst-italic">@Model.KategoriResmi</span>
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted">
                                    <i class="fa-regular fa-image fs-1 mb-2 text-secondary opacity-25"></i>
                                    <p class="small mb-0 fst-italic">Görsel Eklenmemiş</p>
                                </div>
                            }
                        </div>
                    </div>

                    <hr class="text-muted my-4" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Vazgeç
                        </a>

                        <form asp-action="Delete">
                            <input type="hidden" asp-for="ID" />
                            <button type="submit" class="btn btn-danger px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-trash-can me-2"></i>Kalıcı Olarak Sil
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>