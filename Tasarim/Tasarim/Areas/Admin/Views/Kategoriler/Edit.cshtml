
@model Tasarim.Core.Entities.Kategori

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-pen-to-square text-warning me-2"></i>Kategori Düzenle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <input type="hidden" asp-for="ID" />

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="KategoriAd" class="form-label fw-semibold text-secondary">Kategori Adı</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-tag text-muted"></i></span>
                                        <input asp-for="KategoriAd" class="form-control border-start-0 ps-0" placeholder="Örn: Abiye, Elbise..." />
                                    </div>
                                    <span asp-validation-for="KategoriAd" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="KategoriResmi" class="form-label fw-semibold text-secondary">Kategori Görseli</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-regular fa-image text-muted"></i></span>
                                        <input asp-for="KategoriResmi" class="form-control border-start-0 ps-0" placeholder="Görsel linki veya yolu" />
                                    </div>
                                    <span asp-validation-for="KategoriResmi" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="SiraNo" class="form-label fw-semibold text-secondary">Sıra Numarası</label>
                                    <input asp-for="SiraNo" class="form-control shadow-sm" type="number" />
                                    <span asp-validation-for="SiraNo" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-4">
                                    <label asp-for="UstKategoriID" class="form-label fw-semibold text-secondary">
                                        <i class="fa-solid fa-sitemap me-1"></i> Üst Kategori Seçimi
                                    </label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fa-solid fa-list-ul text-muted"></i>
                                        </span>
                                        <select asp-for="UstKategoriID" class="form-select border-start-0 ps-0" asp-items="ViewBag.Kategoriler">
                                            <option value="">-- Ana Kategori --</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="UstKategoriID" class="text-danger small"></span>
                                    <div class="form-text mt-1 text-muted">
                                        <i class="fa-solid fa-circle-info me-1"></i> Eğer bu kategori bir alt grupsa yukarıdan bağlı olduğu kategoriyi seçin.
                                    </div>
                                </div>

                                <div class="d-flex gap-4 p-3 bg-light rounded-3 shadow-sm border">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="AktifMi" id="aktifMiSwitch">
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="aktifMiSwitch">
                                            @Html.DisplayNameFor(model => model.AktifMi)
                                        </label>
                                    </div>

                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="UstteGoster" id="ustteGosterSwitch">
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="ustteGosterSwitch">
                                            @Html.DisplayNameFor(model => model.UstteGoster)
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-success px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-check me-2"></i>Değişiklikleri Kaydet
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}