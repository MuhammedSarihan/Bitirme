@model IEnumerable<Tasarim.Core.Entities.Marka>

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-copyright text-primary me-2"></i>Markaların Yönetimi
            </h3>
            <p class="text-muted small mt-1 mb-0">Sistemde kayıtlı olan ürün markalarını buradan yönetebilir ve arayabilirsiniz.</p>
        </div>

        <div class="d-flex gap-3 align-items-center">

            <div class="input-group shadow-sm rounded-pill overflow-hidden" style="min-width: 300px; border: 1px solid #dee2e6;">
                <span class="input-group-text bg-white border-0 text-muted ps-3">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="markaArama" class="form-control border-0 shadow-none" placeholder="Marka adı ara...">
            </div>

            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm text-nowrap fw-medium">
                <i class="fa-solid fa-plus me-1"></i> Yeni Ekle
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="markalarTablosu">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 ps-4">@Html.DisplayNameFor(model => model.MarkaAd)</th>
                            <th class="text-secondary fw-semibold">@Html.DisplayNameFor(model => model.Logo)</th>
                            <th class="text-secondary fw-semibold text-center">Durum</th>
                            <th class="text-secondary fw-semibold text-end pe-4" style="width: 150px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark ps-4">
                                    @Html.DisplayFor(modelItem => item.MarkaAd)
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Logo))
                                    {
                                        <img src="/img/@Html.DisplayFor(modelItem =>item.Logo)" alt"" height="30"/>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.AktifMi)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-75 px-3">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-75 px-3">Pasif</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info" title="Detaylar">
                                            <i class="fa-solid fa-magnifying-glass"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger" title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const aramaKutusu = document.getElementById('markaArama');

            aramaKutusu.addEventListener('keyup', function () {
                let filtre = this.value.toLowerCase();
                // HTML'deki tablo ID'si ile eşleşmeli
                let satirlar = document.querySelectorAll('#markalarTablosu tbody tr');

                satirlar.forEach(function (satir) {
                    let satirMetni = satir.textContent.toLowerCase();
                    if (satirMetni.includes(filtre)) {
                        satir.style.display = '';
                    } else {
                        satir.style.display = 'none';
                    }
                });
            });
        });
    </script>
}