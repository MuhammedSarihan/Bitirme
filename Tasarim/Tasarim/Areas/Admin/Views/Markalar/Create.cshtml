@model Tasarim.Core.Entities.Marka

@{
    ViewData["Title"] = "Yeni Marka Ekle";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-folder-plus text-primary me-2"></i>Yeni Marka Ekle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="MarkaAd" class="form-label fw-semibold text-secondary">Marka Adı</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-copyright text-muted"></i></span>
                                        <input asp-for="MarkaAd" class="form-control border-start-0 ps-0" placeholder="Örn: Beyoğlu Abiye, Nike..." />
                                    </div>
                                    <span asp-validation-for="MarkaAd" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Logo" class="form-label fw-semibold text-secondary">Marka Logosu</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-regular fa-image text-muted"></i></span>
                                        <input asp-for="Logo" class="form-control border-start-0 ps-0" placeholder="Logo linki veya yolu" />
                                    </div>
                                    <span asp-validation-for="Logo" class="text-danger small"></span>
                                </div>

                                <div class="d-flex gap-4 p-3 bg-light rounded-3 shadow-sm border mt-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="AktifMi" id="aktifMiSwitch" checked>
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="aktifMiSwitch">
                                            @Html.DisplayNameFor(model => model.AktifMi)
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-plus me-2"></i>Markayı Oluştur
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}