@model Tasarim.Core.Entities.Marka

@{
    ViewData["Title"] = "Marka Düzenle";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-pen-to-square text-warning me-2"></i>Marka Düzenle
                        </h3>
                        <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill shadow-sm">
                            Marka ID: @Model.ID
                        </span>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="Logo" />

                        <div class="row g-4">
                            <div class="col-md-7">
                                <div class="form-group mb-4">
                                    <label asp-for="MarkaAd" class="form-label fw-semibold text-secondary">Marka Adı</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-copyright text-muted"></i></span>
                                        <input asp-for="MarkaAd" class="form-control border-start-0 ps-0" placeholder="Örn: Beyoğlu Abiye, Nike..." />
                                    </div>
                                    <span asp-validation-for="MarkaAd" class="text-danger small"></span>
                                </div>

                                <div class="d-flex gap-4 p-3 bg-light rounded-3 shadow-sm border mt-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="AktifMi" id="aktifMiSwitch">
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="aktifMiSwitch">
                                            Müşterilere Göster (Aktif/Pasif)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-5">
                                <div class="form-group mb-3 text-center p-3 bg-light border border-dashed rounded-3">
                                    <span class="d-block text-secondary fw-semibold mb-2">Mevcut Logo</span>

                                    @if (Model.Logo != null && !string.IsNullOrWhiteSpace(Model.Logo))
                                    {
                                        <div class="mb-3">
                                            <img src="/img/@Model.Logo" alt="@Model.MarkaAd" class="img-fluid rounded shadow-sm bg-white p-2 mb-2" style="max-height: 80px; object-fit: contain;" />

                                            <div class="form-check text-start bg-danger bg-opacity-10 p-2 rounded-3 border border-danger border-opacity-25 mt-2 d-inline-block w-100">
                                                <input class="form-check-input ms-1 border-danger" type="checkbox" name="cbResmiSil" value="true" id="cbResmiSil">
                                                <label class="form-check-label ms-2 text-danger fw-bold user-select-none" for="cbResmiSil" style="cursor:pointer;">
                                                    <i class="fa-solid fa-trash-can me-1"></i> Logoyu Kalıcı Sil
                                                </label>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted fst-italic mb-3 py-3"><i class="fa-regular fa-image fs-1 opacity-25"></i><br />Logo Yok</div>
                                    }

                                    <label class="form-label fw-semibold text-secondary text-start w-100 mt-2">Logoyu Değiştir</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-upload text-muted"></i></span>
                                        <input name="Logo" type="file" class="form-control border-start-0 ps-0" accept="image/*" />
                                    </div>
                                    <div class="form-text mt-1 small text-start">Sadece yeni bir logo yüklemek istiyorsanız dosya seçin.</div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-success px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-check me-2"></i>Değişiklikleri Kaydet
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}