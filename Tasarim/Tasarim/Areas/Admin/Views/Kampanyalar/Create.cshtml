@model Tasarim.Core.Entities.Kampanya

@{
    ViewData["Title"] = "Yeni Kampanya Oluştur";
}

<div class="container-fluid mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-bullhorn text-primary me-2"></i>Yeni Kampanya veya Duyuru Ekle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4 opacity-25" />

                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <div class="row g-5">
                            <div class="col-md-6 d-flex flex-column">
                                <h5 class="text-primary mb-3"><i class="fa-solid fa-tag me-2"></i>Kampanya Bilgileri</h5>

                                <div class="form-group mb-3">
                                    <label asp-for="KampanyaAd" class="form-label fw-bold text-dark">Kampanya Başlığı</label>
                                    <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-heading text-muted"></i></span>
                                        <input asp-for="KampanyaAd" class="form-control border-start-0 ps-0" placeholder="Örn: 2024 İlkbahar Sezonu İndirimi" />
                                    </div>
                                    <span asp-validation-for="KampanyaAd" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group mb-3 flex-grow-1">
                                    <label asp-for="Aciklama" class="form-label fw-semibold text-secondary">Kampanya Detayları</label>
                                    <div class="input-group shadow-sm h-100">
                                        <span class="input-group-text bg-light border-end-0 align-items-start pt-3"><i class="fa-solid fa-file-lines text-muted"></i></span>
                                        <textarea asp-for="Aciklama" class="form-control border-start-0 ps-0" rows="5" placeholder="Müşterilerinize kampanyanın avantajlarından ve detaylarından bahsedin..."></textarea>
                                    </div>
                                    <span asp-validation-for="Aciklama" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="row g-3 mt-1">
                                    <div class="col-sm-6">
                                        <label asp-for="IndirimTipi" class="form-label fw-bold text-dark">İndirim Tipi</label>
                                        <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-percent text-muted"></i></span>
                                            <select asp-for="IndirimTipi" class="form-select border-start-0 ps-0">
                                                <option value="1">Yüzde (%)</option>
                                                <option value="2">Sabit Tutar (₺)</option>
                                            </select>
                                        </div>
                                        <span asp-validation-for="IndirimTipi" class="text-danger small mt-1 d-block"></span>
                                    </div>

                                    <div class="col-sm-6">
                                        <label asp-for="IndirimTutari" class="form-label fw-bold text-dark">İndirim Tutarı / Oranı</label>
                                        <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-coins text-muted"></i></span>
                                            <input asp-for="IndirimTutari" type="number" step="0.01" class="form-control border-start-0 ps-0" placeholder="Örn: 15 veya 200" />
                                        </div>
                                        <span asp-validation-for="IndirimTutari" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="d-flex gap-4 p-3 bg-light rounded-3 shadow-sm border mt-3">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="KampanyaAktifMi" id="aktifMiSwitch" checked style="cursor: pointer;">
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="aktifMiSwitch">
                                            Kampanyayı Hemen Yayına Al (Aktif)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-info mb-3"><i class="fa-solid fa-image me-2"></i>Kampanya Görseli</h5>

                                <div class="form-group h-100 d-flex flex-column justify-content-center p-4 bg-light border border-dashed border-2 rounded-4 shadow-sm text-center" style="min-height: 250px;">

                                    <div class="mb-3">
                                        <i class="fa-solid fa-cloud-arrow-up fs-1 text-primary opacity-75 mb-3"></i>
                                        <label asp-for="KampanyaResmi" class="form-label fw-bold text-dark w-100">Görsel Yükle</label>
                                    </div>

                                    <div class="input-group shadow-sm mt-auto">
                                        <input name="AnaResimDosyasi" asp-for="KampanyaResmi" type="file" class="form-control form-control-lg bg-white" accept="image/*" />
                                    </div>
                                    <span asp-validation-for="KampanyaResmi" class="text-danger small mt-2 d-block text-start"></span>

                                    <div class="form-text mt-3 small text-muted text-start">
                                        <i class="fa-solid fa-circle-info me-1"></i>Kullanıcıların göreceği ilgi çekici kampanya görselini bilgisayarınızdan seçin.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-4">
                            <hr class="text-muted mb-4 opacity-25" />
                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
                                <a asp-action="Index" class="btn btn-light border px-4 py-2 rounded-pill fw-medium text-secondary w-100 w-sm-auto text-center transition-all hover-shadow">
                                    <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                                </a>
                                <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-sm fw-bold w-100 w-sm-auto transition-all">
                                    <i class="fa-solid fa-plus me-2"></i>Kampanyayı Kaydet
                                </button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}