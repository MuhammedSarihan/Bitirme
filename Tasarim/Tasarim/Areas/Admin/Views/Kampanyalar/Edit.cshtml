@model Tasarim.Core.Entities.Kampanya

@{
    ViewData["Title"] = "Kampanya Düzenle";
}

<div class="container-fluid mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-bullhorn text-warning me-2"></i>Kampanya Bilgilerini Güncelle
                        </h3>
                    </div>
                    <hr class="text-muted mb-4 opacity-25" />

                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>

                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="KampanyaResmi" />


                        <div class="row g-4">
                            <div class="col-md-6 d-flex flex-column">
                                <div class="form-group mb-3">
                                    <label asp-for="KampanyaAd" class="form-label fw-semibold text-secondary">Kampanya Başlığı</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-tag text-muted"></i></span>
                                        <input asp-for="KampanyaAd" class="form-control border-start-0 ps-0" placeholder="Örn: 2024 İlkbahar Sezonu İndirimi" />
                                    </div>
                                    <span asp-validation-for="KampanyaAd" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group mb-3 flex-grow-1">
                                    <label asp-for="Aciklama" class="form-label fw-semibold text-secondary">Kampanya Detayları ve Açıklaması</label>
                                    <div class="input-group shadow-sm h-100">
                                        <span class="input-group-text bg-light border-end-0 align-items-start pt-3"><i class="fa-solid fa-file-lines text-muted"></i></span>
                                        <textarea asp-for="Aciklama" class="form-control border-start-0 ps-0" rows="5" placeholder="Müşterilerinize kampanyanın avantajlarından ve detaylarından bahsedin..."></textarea>
                                    </div>
                                    <span asp-validation-for="Aciklama" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="row g-3 mt-1">
                                    <div class="col-sm-6">
                                        <label asp-for="IndirimTipi" class="form-label fw-bold text-dark">İndirim Tipi</label>
                                        <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-percent text-muted"></i></span>
                                            <select asp-for="IndirimTipi" class="form-select border-start-0 ps-0">
                                                <option value="1">Yüzde (%)</option>
                                                <option value="2">Sabit Tutar (₺)</option>
                                            </select>
                                        </div>
                                        <span asp-validation-for="IndirimTipi" class="text-danger small mt-1 d-block"></span>
                                    </div>

                                    <div class="col-sm-6">
                                        <label asp-for="IndirimTutari" class="form-label fw-bold text-dark">İndirim Tutarı / Oranı</label>
                                        <div class="input-group shadow-sm border border-primary border-opacity-25 rounded-3">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-coins text-muted"></i></span>
                                            <input asp-for="IndirimTutari" type="number" step="0.01" class="form-control border-start-0 ps-0" placeholder="Örn: 15 veya 200" />
                                        </div>
                                        <span asp-validation-for="IndirimTutari" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                                <div class="d-flex gap-4 p-3 bg-light rounded-3 shadow-sm border mt-3">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" role="switch" asp-for="KampanyaAktifMi" id="aktifMiSwitch" style="cursor: pointer;">
                                        <label class="form-check-label fw-semibold text-dark user-select-none" style="cursor: pointer;" for="aktifMiSwitch">
                                            Kampanyayı Yayına Al (Aktif/Pasif)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group h-100 p-4 bg-light border border-dashed border-2 rounded-4 shadow-sm d-flex flex-column justify-content-center">

                                    @if (!string.IsNullOrEmpty(Model.KampanyaResmi))
                                    {
                                        <div class="mb-4">
                                            <label class="form-label fw-semibold text-secondary text-start w-100 mb-3">Mevcut Kampanya Görseli</label>

                                            <div class="d-flex justify-content-center align-items-center bg-white rounded-3 shadow-sm border p-2 w-100" style="min-height: 250px;">
                                                <img src="/img/@Model.KampanyaResmi" alt="@Model.KampanyaAd" class="img-fluid rounded" style="max-height: 240px; max-width: 100%; object-fit: contain;" />
                                            </div>

                                            <div class="form-check text-start bg-white p-3 rounded-3 border border-danger border-opacity-50 mt-3 shadow-sm transition-all">
                                                <input class="form-check-input ms-1 border-danger" type="checkbox" name="cbResmiSil" value="true" id="cbResmiSil" style="cursor:pointer;">
                                                <label class="form-check-label ms-2 text-danger fw-bold user-select-none" for="cbResmiSil" style="cursor:pointer;">
                                                    <i class="fa-solid fa-trash-can me-1"></i> Mevcut Görseli Sistemden Sil
                                                </label>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted fst-italic mb-4 py-5 text-center bg-white rounded-3 border shadow-sm d-flex flex-column justify-content-center align-items-center" style="min-height: 250px;">
                                            <i class="fa-regular fa-image fs-1 text-secondary opacity-50 mb-2"></i>
                                            <span class="fw-medium">Görsel Bulunmuyor</span>
                                        </div>
                                    }

                                    <div class="mt-auto">
                                        <label class="form-label fw-semibold text-secondary text-start w-100">Görseli Değiştir veya Ekle</label>
                                        <div class="input-group shadow-sm">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-cloud-arrow-up text-primary"></i></span>
                                            <input name="AnaResimDosyasi" type="file" class="form-control border-start-0 ps-0" accept="image/*" />
                                        </div>
                                        <div class="form-text mt-2 small text-muted">
                                            <i class="fa-solid fa-circle-info me-1"></i>Mevcut kampanya görselini değiştirmek için yeni bir dosya seçebilirsiniz.
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <hr class="text-muted my-4 opacity-25" />
                                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
                                    <a asp-action="Index" class="btn btn-light border px-4 py-2 rounded-pill fw-medium text-secondary w-100 w-sm-auto text-center transition-all hover-shadow">
                                        <i class="fa-solid fa-arrow-left me-2"></i>Kampanya Listesine Dön
                                    </a>
                                    <button type="submit" class="btn btn-success px-5 py-2 rounded-pill shadow-sm fw-bold w-100 w-sm-auto transition-all">
                                        <i class="fa-solid fa-check-circle me-2"></i>Güncellemeleri Kaydet
                                    </button>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}