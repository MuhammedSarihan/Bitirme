@model Tasarim.Core.Entities.Kampanya

@{
}

<div class="container-fluid py-5 my-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-5">
                        <h2 class="font-playfair fw-bold text-dark text-uppercase letter-spacing-1">Kampanya Güncelle</h2>
                        <div style="width: 50px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="mt-3"></div>
                    </div>

                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4 text-center"></div>

                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="KampanyaResmi" />

                        <div class="row g-5">
                            <div class="col-md-7 d-flex flex-column">
                                <h6 class="text-uppercase fw-bold letter-spacing-1 text-muted mb-4 pb-2 border-bottom">Kampanya Bilgileri</h6>

                                <div class="form-group mb-4">
                                    <label asp-for="KampanyaAd" class="form-label small text-uppercase fw-bold letter-spacing-1">Kampanya Başlığı</label>
                                    <input asp-for="KampanyaAd" class="form-control rounded-0 border-light-subtle py-2" placeholder="Örn: Sezon Sonu İndirimi" />
                                    <span asp-validation-for="KampanyaAd" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group mb-4 flex-grow-1">
                                    <label asp-for="Aciklama" class="form-label small text-uppercase fw-bold letter-spacing-1">Açıklama ve Detaylar</label>
                                    <textarea asp-for="Aciklama" class="form-control rounded-0 border-light-subtle py-2" rows="6" placeholder="Kampanya detaylarını buraya girin..."></textarea>
                                    <span asp-validation-for="Aciklama" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-sm-6">
                                        <label asp-for="IndirimTipi" class="form-label small text-uppercase fw-bold letter-spacing-1">İndirim Tipi</label>
                                        <select asp-for="IndirimTipi" class="form-select rounded-0 border-light-subtle py-2">
                                            <option value="1">Yüzde (%)</option>
                                            <option value="2">Sabit Tutar (₺)</option>
                                        </select>
                                        <span asp-validation-for="IndirimTipi" class="text-danger small mt-1 d-block"></span>
                                    </div>

                                    <div class="col-sm-6">
                                        <label asp-for="IndirimTutari" class="form-label small text-uppercase fw-bold letter-spacing-1">Tutar / Oran</label>
                                        <input asp-for="IndirimTutari" type="number" step="0.01" class="form-control rounded-0 border-light-subtle py-2" />
                                        <span asp-validation-for="IndirimTutari" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mt-2">
                                    <div class="form-check rounded-0">
                                        <input class="form-check-input rounded-0 border-dark custom-checkbox" type="checkbox" asp-for="KampanyaAktifMi" id="aktifMiCheck" style="cursor: pointer;">
                                        <label class="form-check-label small fw-bold text-uppercase letter-spacing-1 ms-2" style="cursor: pointer; margin-top: 2px;" for="aktifMiCheck">
                                            Kampanya Yayında (Aktif)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-5">
                                <h6 class="text-uppercase fw-bold letter-spacing-1 text-muted mb-4 pb-2 border-bottom">Kampanya Görseli</h6>

                                <div class="form-group h-100 d-flex flex-column">
                                    @if (!string.IsNullOrEmpty(Model.KampanyaResmi))
                                    {
                                        <div class="mb-4">
                                            <label class="form-label small text-uppercase fw-bold letter-spacing-1 text-muted mb-2">Mevcut Görsel</label>
                                            <div class="position-relative bg-light p-2 border border-light-subtle shadow-sm">
                                                <img src="/img/@Model.KampanyaResmi" alt="@Model.KampanyaAd" class="img-fluid w-100" style="max-height: 250px; object-fit: contain;" />
                                            </div>

                                            <div class="form-check mt-3 p-2 border border-danger border-opacity-25 bg-danger bg-opacity-10 d-flex align-items-center">
                                                <input class="form-check-input ms-1 border-danger" type="checkbox" name="cbResmiSil" value="true" id="cbResmiSil" style="cursor:pointer;">
                                                <label class="form-check-label ms-2 text-danger small fw-bold text-uppercase letter-spacing-1" for="cbResmiSil" style="cursor:pointer; margin-top:2px;">
                                                    <i class="fa-solid fa-trash-can me-1"></i> Görseli Kaldır
                                                </label>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-5 bg-light border border-dashed mb-4">
                                            <i class="fa-regular fa-image fs-1 text-muted opacity-25 mb-2"></i>
                                            <div class="small text-muted text-uppercase letter-spacing-1">Görsel Yok</div>
                                        </div>
                                    }

                                    <div class="mt-auto pt-3 border-top border-light-subtle">
                                        <label class="form-label small text-uppercase fw-bold letter-spacing-1">Görseli Güncelle</label>
                                        <div class="custom-file-upload p-4 text-center bg-light border border-dashed">
                                            <input name="AnaResimDosyasi" type="file" class="form-control form-control-sm rounded-0 bg-white" accept="image/*" />
                                            <div class="form-text small text-muted mt-2 mt-sm-3 d-none d-sm-block">
                                                Yeni bir görsel seçerek mevcut olanı değiştirebilirsiniz.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-5 pt-4 border-top">
                            <div class="col-sm-6 mb-3 mb-sm-0">
                                <a asp-action="Index" class="btn btn-outline-dark w-100 rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 transition-300">
                                    < Listeye Geri Dön
                                </a>
                            </div>
                            <div class="col-sm-6">
                                <button type="submit" class="btn btn-dark w-100 rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 transition-300 hover-gold-bg border-0">
                                    Değişiklikleri Uygula
                                </button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .font-playfair { font-family: 'Playfair Display', serif; }
    .letter-spacing-1 { letter-spacing: 1px; }
    .hover-gold-bg:hover { background-color: #D4AF37 !important; color: #fff !important; }
    .transition-300 { transition: all 0.3s ease; }
    .form-control:focus, .form-select:focus { border-color: #D4AF37; box-shadow: none; }
    .custom-file-upload { transition: all 0.3s; }
    .custom-file-upload:hover { border-color: #D4AF37; background-color: #fdfdfd !important; }
    .custom-checkbox:checked { background-color: #D4AF37; border-color: #D4AF37; }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}