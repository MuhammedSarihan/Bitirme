@model Tasarim.Core.Entities.Kampanya

@{
    ViewData["Title"] = Model.KampanyaAd + " - Kampanya Detayları";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-circle-info text-info me-2"></i>Kampanya Detayları
                        </h3>
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex gap-2">
                                <a asp-action="Index" class="btn btn-light border px-3 rounded-pill text-secondary" title="Listeye Dön">
                                    <i class="fa-solid fa-arrow-left"> Listeye Dön</i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn btn-primary px-3 rounded-pill shadow-sm" title="Kampanyayı Düzenle">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                    <hr class="text-muted mb-4" />

                    <div class="row g-5">
                        <div class="col-md-7">
                            <h4 class="fw-bold text-dark mb-1">@Html.DisplayFor(model => model.KampanyaAd)</h4>
                            <ul class="list-group list-group-flush shadow-sm rounded-3 border mb-4">
                                <li class="list-group-item px-4 pt-4 pb-3 d-flex justify-content-between align-items-center">
                                    @if (Model.KampanyaAktifMi)
                                    {
                                        <span class="badge rounded-pill bg-success px-4 py-2 fs-6 shadow-sm">Aktif </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger px-4 py-2 fs-6 shadow-sm"> Aktif Değil </span>
                                    }
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-secondary"><i class="fa-solid fa-tags me-2"></i>İndirim Tipi</span>
                                    <span class="fw-semibold text-dark fs-6">
                                        @((int)Model.IndirimTipi == 1 ? "Yüzdelik İndirim (%)" : "Sabit Tutar İndirimi (₺)")
                                    </span>
                                </li>

                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-secondary"><i class="fa-solid fa-coins me-2"></i>İndirim Miktarı</span>
                                    <span class="badge bg-primary px-3 py-2 fs-6 shadow-sm">
                                        @((int)Model.IndirimTipi == 1 ? "%" + Model.IndirimTutari.ToString("0.##") : Model.IndirimTutari.ToString("c"))
                                    </span>
                                </li>
                            </ul>

                            <div class="bg-light p-4 rounded-3 border">
                                <h5 class="text-dark fw-bolder mb-3"><i class="fa-solid fa-align-left me-2"></i>Açıklama</h5>
                                <p class="mb-0 text-dark fs-5 lh-base">
                                    @(string.IsNullOrEmpty(Model.Aciklama) ? "Bu ürün için henüz bir açıklama girilmemiş." : Model.Aciklama)
                                </p>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="sticky-top" style="top: 20px;">
                                <div class="bg-white p-3 rounded-4 shadow-sm border mb-3 text-center d-flex align-items-center justify-content-center" style="min-height: 400px;">
                                    @if (!string.IsNullOrEmpty(Model.KampanyaResmi))
                                    {
                                        <img src="/img/@Model.KampanyaResmi" id="mainImage" alt="@Model.KampanyaAd" class="img-fluid rounded-3 active-fade" style="max-height: 380px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                        <div class="text-muted small text-center" style="display:none;">
                                            <i class="fa-regular fa-image fs-1 mb-2 text-secondary opacity-50"></i><br />
                                            <span>Görsel Yüklenemedi</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-5">
                                            <i class="fa-regular fa-image fs-1 mb-3 opacity-25" style="font-size: 4rem !important;"></i>
                                            <p class="small mb-0 fst-italic">Görsel Eklenmemiş</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr class="text-muted my-5" />
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .thumb-item {
        cursor: pointer;
        transition: 0.3s;
        opacity: 0.6;
        min-width: 70px;
    }

        .thumb-item:hover, .thumb-item.active {
            opacity: 1;
            transform: translateY(-3px);
        }

            .thumb-item.active img {
                border: 2px solid #0d6efd !important;
            }

    .active-fade {
        animation: imgFade 0.4s ease-in-out;
    }

    @@keyframes imgFade {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

@section Scripts {
    <script>
        function updateMainImage(src, element) {
            const mainImg = document.getElementById('mainImage');
            mainImg.src = src;

            // Animasyonu Yenile
            mainImg.classList.remove('active-fade');
            void mainImg.offsetWidth;
            mainImg.classList.add('active-fade');

            // Aktif Sınıfını Güncelle
            document.querySelectorAll('.thumb-item').forEach(item => item.classList.remove('active'));
            element.classList.add('active');
        }
    </script>
}