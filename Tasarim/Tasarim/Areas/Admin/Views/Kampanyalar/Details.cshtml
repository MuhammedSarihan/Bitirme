@model Tasarim.Core.Entities.Kampanya

@{
}

<div class="container-fluid py-5 my-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5">
                        <div class="text-center text-md-start mb-3 mb-md-0">
                            <h2 class="font-playfair fw-bold text-dark text-uppercase letter-spacing-1 mb-0">Kampanya Detayı</h2>
                            <div style="width: 40px; height: 2px; background-color: #D4AF37;" class="mt-2 mx-auto mx-md-0"></div>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-action="Index" class="btn btn-outline-dark rounded-0 px-4 py-2 text-uppercase fw-bold letter-spacing-1 small transition-300" title="Listeye Dön">
                                <i class="fa-solid fa-arrow-left me-2"></i> Listeye Dön
                            </a>
                            <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn btn-dark rounded-0 px-4 py-2 text-uppercase fw-bold letter-spacing-1 small transition-300 hover-gold-bg border-0" title="Düzenle">
                                <i class="fa-solid fa-pen me-2"></i> Düzenle
                            </a>
                        </div>
                    </div>

                    <div class="row g-5">
                        <div class="col-md-7">
                            <h4 class="fw-bold text-dark mb-4 text-uppercase letter-spacing-1">@Html.DisplayFor(model => model.KampanyaAd)</h4>
                            
                            <div class="border border-light-subtle p-0 mb-4">
                                <ul class="list-group list-group-flush rounded-0">
                                    <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center border-bottom-0">
                                        <span class="small text-uppercase fw-bold letter-spacing-1 text-muted">Durum</span>
                                        @if (Model.KampanyaAktifMi)
                                        {
                                            <span class="badge rounded-0 bg-dark text-white px-3 py-2 text-uppercase letter-spacing-1 shadow-sm">Yayında</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-0 bg-light text-muted border px-3 py-2 text-uppercase letter-spacing-1">Pasif</span>
                                        }
                                    </li>
                                    <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center border-bottom-0 border-top">
                                        <span class="small text-uppercase fw-bold letter-spacing-1 text-muted">İndirim Tipi</span>
                                        <span class="fw-bold text-dark">
                                            @((int)Model.IndirimTipi == 1 ? "Yüzdelik (%)" : "Sabit Tutar (₺)")
                                        </span>
                                    </li>
                                    <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center border-top">
                                        <span class="small text-uppercase fw-bold letter-spacing-1 text-muted">İndirim Miktarı</span>
                                        <span class="fw-bold text-dark" style="color: #D4AF37 !important; font-size: 1.1rem;">
                                            @((int)Model.IndirimTipi == 1 ? "%" + Model.IndirimTutari.ToString("0.##") : Model.IndirimTutari.ToString("c"))
                                        </span>
                                    </li>
                                </ul>
                            </div>

                            <div class="bg-light p-4 border border-light-subtle border-start-0 border-end-0 border-bottom-0" style="border-top-width: 3px !important; border-top-color: #111 !important;">
                                <h6 class="text-uppercase fw-bold letter-spacing-1 text-muted mb-3">Açıklama ve Notlar</h6>
                                <p class="mb-0 text-dark lh-lg" style="text-align: justify;">
                                    @(string.IsNullOrEmpty(Model.Aciklama) ? "Bu kampanya için henüz bir açıklama girilmemiş." : Model.Aciklama)
                                </p>
                            </div>
                        </div>

                        <div class="col-md-5">
                            <div class="sticky-top" style="top: 20px;">
                                <h6 class="text-uppercase fw-bold letter-spacing-1 text-muted mb-3">Kampanya Görseli</h6>
                                <div class="bg-light p-3 border border-light-subtle text-center d-flex align-items-center justify-content-center active-fade" style="min-height: 400px;">
                                    @if (!string.IsNullOrEmpty(Model.KampanyaResmi))
                                    {
                                        <img src="/img/@Model.KampanyaResmi" id="mainImage" alt="@Model.KampanyaAd" class="img-fluid shadow-sm" style="max-height: 380px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                        <div class="text-muted small text-center" style="display:none;">
                                            <i class="fa-regular fa-image fs-1 mb-2 text-secondary opacity-50"></i><br />
                                            <span class="text-uppercase letter-spacing-1">Görsel Yüklenemedi</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-5">
                                            <i class="fa-regular fa-image fs-1 mb-3 opacity-25" style="font-size: 3rem !important;"></i>
                                            <p class="small mb-0 text-uppercase letter-spacing-1">Görsel Eklenmemiş</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .font-playfair { font-family: 'Playfair Display', serif; }
    .letter-spacing-1 { letter-spacing: 1px; }
    .hover-gold-bg:hover { background-color: #D4AF37 !important; color: #fff !important; }
    .transition-300 { transition: all 0.3s ease; }
    
    .active-fade {
        animation: imgFade 0.6s ease-in-out;
    }

    @@keyframes imgFade {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>