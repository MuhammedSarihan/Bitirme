@model IEnumerable<Tasarim.Core.Entities.Kampanya>

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-bullhorn text-primary me-2"></i>Kampanya Yönetimi
            </h3>
            <p class="text-muted small mt-1 mb-0">Mağazanızdaki tüm kampanya ve duyuruları buradan yönetebilirsiniz.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-1"></i> Yeni Oluştur
        </a>
    </div>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 w-100" id="kampanyalarTablosu">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold">Kampanya Resmi</th>
                            <th class="text-secondary fw-semibold">Kampanya Adı</th>
                            <th class="text-secondary fw-semibold">Açıklama</th>
                            <th class="text-secondary fw-semibold">Durum</th>
                            <th class="text-secondary fw-semibold" style="width: 150px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.KampanyaResmi))
                                        {
                                            <img src="/img/@item.KampanyaResmi" alt="@item.KampanyaAd" class="rounded-3 shadow-sm bg-light p-1" style="width: 60px; height: 60px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                            <div class="bg-light rounded-3 justify-content-center align-items-center text-muted shadow-sm" style="width: 60px; height: 60px; display: none !important;">
                                                <i class="fa-solid fa-image fs-5"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-3 d-flex justify-content-center align-items-center text-muted shadow-sm border border-dashed" style="width: 60px; height: 60px;">
                                                <i class="fa-solid fa-image fs-5 opacity-50"></i>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-semibold text-dark fs-6 mb-1">@item.KampanyaAd</div>
                                </td>

                                <td>
                                    <div class="small fw-medium text-dark"><i class="fa-solid fa-bullhorn text-muted me-2 opacity-75"></i>@item.Aciklama</div>
                                </td>

                                <td class="text-center">
                                    @if (item.KampanyaAktifMi)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-75 px-3 shadow-sm">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-75 px-3 shadow-sm">Pasif</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary " title="Düzenle">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info " title="Detaylar">
                                            <i class="fa-solid fa-magnifying-glass"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger " title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#kampanyalarTablosu').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json',
                },
                lengthMenu: [10, 25, 50, 100],
            });
        });
    </script>

    <style>
        .dataTables_filter input {
            border-radius: 0.5rem;
            border: 1px solid #dee2e6;
            padding: 0.375rem 0.75rem;
        }

            .dataTables_filter input:focus {
                border-color: #86b7fe;
                outline: 0;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            }
    </style>
}
