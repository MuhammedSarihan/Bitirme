@model Tasarim.Areas.Admin.Models.GostergePaneliViewModel

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-chart-pie text-primary me-2"></i>Mağaza Özeti ve Geribildirim Analizi
            </h3>
            <p class="text-muted small mt-1 mb-0">
                Gösterilen Veri: <strong class="text-dark">@(string.IsNullOrEmpty(Model.SeciliUrunAd) ? "Tüm Mağaza Genel Görünümü" : Model.SeciliUrunAd + " İstatistikleri")</strong>
            </p>
        </div>

        <div class="d-flex align-items-center gap-3 flex-wrap">

            @*Yorum Analiz Butonu ve Yorum Sayısı sadece ana ekranda olcak şekilde filtrelendi*@
            @if (!Model.SeciliUrunId.HasValue)
            {
  
                  <div class="card border-0 shadow-sm rounded-4 bg-warning bg-opacity-10 border-start border-4 border-warning">
                       <div class="card-body p-3 d-flex align-items-center">
                            <div class="bg-warning bg-opacity-25 text-warning rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                                    <i class="fa-solid fa-hourglass-half fs-5"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 text-dark fw-bold">Analiz Bekleyen Yorum Sayısı</h6>
                                <span class="fs-4 fw-bold text-warning">@Model.BekleyenYorumSayisi</span>
                                <span class="text-muted small ms-1">Adet</span>
                            </div>
                       </div>
                  </div>
                <form asp-controller="Main" asp-action="BekleyenleriAnalizEt" method="post" class="m-0">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm text-nowrap fw-medium">
                        <i class="fa-solid fa-robot me-1"></i> Analizi Güncelle
                    </button>
                </form>
            }

            @*Dropdown ile Ürünler Listesi*@
            <form method="get" class="d-flex align-items-center m-0" style="min-width: 250px;">
                <select name="urunId" class="form-select shadow-sm" id="urunSecici" onchange="this.form.submit()">
                    <option value="">-- Tüm Mağazayı Göster --</option>
                    @if (Model.UrunlerListesi != null)
                    {
                        foreach (var urun in Model.UrunlerListesi)
                        {
                            <option value="@urun.Value" selected="@(Model.SeciliUrunId.ToString() == urun.Value ? "selected" : null)">
                                @urun.Text
                            </option>
                        }
                    }
                </select>
            </form>
        </div>
    </div>


    @*--------------------- ÜRÜN SEÇİLMEDİĞİNDE GÖSTERİLECEK BÖLÜM (ANA EKRAN) ---------------------*@

    @*Siparişler Tablosu*@
    @if (!Model.SeciliUrunId.HasValue)
    {

        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0 text-dark fw-bold">
                                <i class="fa-solid fa-shopping-bag text-primary me-2"></i>Son Siparişler
                            </h5>
                            <span class="badge bg-light text-dark border">Son 10 İşlem</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3 text-secondary fw-semibold">Sipariş No</th>
                                        <th class="text-secondary fw-semibold">Müşteri</th>
                                        <th class="text-secondary fw-semibold">Tarih</th>
                                        <th class="text-secondary fw-semibold">Tutar</th>
                                        <th class="text-secondary fw-semibold">Durum</th>
                                        <th class="text-end pe-3 text-secondary fw-semibold">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.SonSiparisler != null && Model.SonSiparisler.Any())
                                    {
                                        foreach (var siparis in Model.SonSiparisler)
                                        {
                                            <tr>
                                                <td class="ps-3 fw-bold text-primary">#@siparis.SiparisNo</td>
                                                <td class="text-dark">@siparis.Kullanici?.KullaniciAd</td>
                                                <td class="text-muted small">@siparis.SiparisTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                                <td class="fw-bold">@siparis.ToplamTutar.ToString("C2")</td>
                                                <td>
                                                    @{
                                                        var statusClass = siparis.SiparisDurumuID == 1 ? "warning" : siparis.SiparisDurumuID == 2 ? "info" : "success";
                                                    }
                                                    <span class="badge bg-@statusClass bg-opacity-10 text-@statusClass border border-@statusClass px-3 py-1 rounded-pill">
                                                        @siparis.SiparisDurumu?.DurumAd
                                                    </span>
                                                </td>
                                                <td class="text-end pe-3">
                                                    <a href="/Admin/Siparis/Detay/@siparis.ID" class="btn btn-sm btn-outline-secondary rounded-pill">
                                                        <i class="fa-solid fa-magnifying-glass"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center py-4 text-muted fst-italic">Henüz bir sipariş bulunmuyor.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        // Alt Grafikler: En Pozitif ve En Negatif Dönüş Alan Ürünler
        <div class="row g-4 mb-4">
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h5 class="mb-4 text-dark fw-bold">
                            <i class="fa-solid fa-trophy text-success me-2"></i>En Pozitif Dönüş Alan Ürünler
                        </h5>
                        @if (Model.EnPozitifUrunAdlari != null && Model.EnPozitifUrunAdlari.Any())
                        {
                            <div style="height: 300px; width: 100%;">
                                <canvas id="topProductsChart"></canvas>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column justify-content-center align-items-center text-muted bg-light rounded-4" style="height: 300px;">
                                <i class="fa-solid fa-chart-bar fs-1 mb-3 opacity-25"></i>
                                <span class="small fw-medium">Pozitif ürün eşleşmesi bulunamadı.</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h5 class="mb-4 text-dark fw-bold">
                            <i class="fa-solid fa-triangle-exclamation text-danger me-2"></i>Müdahale Gerektiren Ürünler
                        </h5>
                        @if (Model.EnNegatifUrunAdlari != null && Model.EnNegatifUrunAdlari.Any())
                        {
                            <div style="height: 300px; width: 100%;">
                                <canvas id="negativeProductsChart"></canvas>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column justify-content-center align-items-center text-muted bg-light rounded-4" style="height: 300px;">
                                <i class="fa-solid fa-chart-line fs-1 mb-3 opacity-25"></i>
                                <span class="small fw-medium">Negatif ürün eşleşmesi bulunamadı.</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    // ---------------------ÜRÜN SEÇİLDİĞİNDE GÖSTERİLECEK BÖLÜM----------------------
    else
    {

        // Duygu Dağılımı Grafiği
        <div class="row mb-4 g-4">
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0 text-dark fw-bold">
                                <i class="fa-solid fa-brain text-primary me-2"></i>Duygu Dağılımı
                            </h5>
                            <span class="badge bg-dark bg-opacity-10 text-dark border px-3 py-2 rounded-pill fs-6">
                                Toplam @Model.ToplamYorum Yorum
                            </span>
                        </div>
                        <div class="row align-items-center">
                            <div class="col-md-5 text-center mb-4 mb-md-0">
                                <div style="position: relative; height: 160px; width: 160px; margin: auto;">
                                    <canvas id="sentimentChart"></canvas>
                                </div>
                            </div>
                            <div class="col-md-7">
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between small mb-2">
                                        <span class="fw-medium text-dark"><i class="fa-solid fa-circle text-success small me-2"></i>Pozitif (@Model.ToplamPozitif)</span>
                                        <span class="fw-bold text-success">%@Model.PozitifYuzde</span>
                                    </div>
                                    <div class="progress rounded-pill bg-success bg-opacity-10" style="height: 8px;">
                                        <div class="progress-bar bg-success rounded-pill" style="width: @(Model.PozitifYuzde)%;"></div>
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between small mb-2">
                                        <span class="fw-medium text-dark"><i class="fa-solid fa-circle text-secondary small me-2"></i>Nötr (@Model.ToplamNotr)</span>
                                        <span class="fw-bold text-secondary">%@Model.NotrYuzde</span>
                                    </div>
                                    <div class="progress rounded-pill bg-secondary bg-opacity-10" style="height: 8px;">
                                        <div class="progress-bar bg-secondary rounded-pill" style="width: @(Model.NotrYuzde)%;"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="d-flex justify-content-between small mb-2">
                                        <span class="fw-medium text-dark"><i class="fa-solid fa-circle text-danger small me-2"></i>Negatif (@Model.ToplamNegatif)</span>
                                        <span class="fw-bold text-danger">%@Model.NegatifYuzde</span>
                                    </div>
                                    <div class="progress rounded-pill bg-danger bg-opacity-10" style="height: 8px;">
                                        <div class="progress-bar bg-danger rounded-pill" style="width: @(Model.NegatifYuzde)%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            @*Öne Çıkan Geri Bildirimler*@
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <h5 class="mb-4 text-dark fw-bold">
                            <i class="fa-solid fa-list-check text-primary me-2"></i>Öne Çıkan Geri Bildirimler
                        </h5>
                        <div class="row">
                            <div class="col-md-6 mb-4 mb-md-0">
                                <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 28px; height: 28px;">
                                        <i class="fa-solid fa-plus small"></i>
                                    </div>
                                    <span class="fw-bold text-success">Müşterilerin Sevdiği</span>
                                </div>
                                <ul class="list-unstyled mb-0 ps-1">
                                    @if (Model.Top5Artilar != null && Model.Top5Artilar.Any())
                                    {
                                        foreach (var arti in Model.Top5Artilar)
                                        {
                                            <li class="mb-3 d-flex align-items-center">
                                                <i class="fa-solid fa-check text-success opacity-75 me-2"></i>
                                                <span class="text-dark small fw-medium">@arti</span>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="text-muted small fst-italic"><i class="fa-solid fa-circle-info me-1"></i>Veri bulunamadı.</li>
                                    }
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 28px; height: 28px;">
                                        <i class="fa-solid fa-minus small"></i>
                                    </div>
                                    <span class="fw-bold text-danger">Gelişim Alanları</span>
                                </div>
                                <ul class="list-unstyled mb-0 ps-1">
                                    @if (Model.Top5Eksiler != null && Model.Top5Eksiler.Any())
                                    {
                                        foreach (var eksi in Model.Top5Eksiler)
                                        {
                                            <li class="mb-3 d-flex align-items-center">
                                                <i class="fa-solid fa-xmark text-danger opacity-75 me-2"></i>
                                                <span class="text-dark small fw-medium">@eksi</span>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="text-muted small fst-italic"><i class="fa-solid fa-circle-info me-1"></i>Veri bulunamadı.</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
        // Ürün seçici için Select2 eklentisi başlat
        if ($.fn.select2) {
        $('#urunSecici').select2({
        theme: 'bootstrap-5',
        placeholder: 'Ürün ara veya seç...',
        width: '100%',
        language: { noResults: () => "Ürün bulunamadı" }
        });
        }

        // Bar Grafik Çizici En pozitif ve en negatif ürünler için
        function initBarChart(canvasId, labels, data, bgColor, borderColor, labelName) {
        const canvas = document.getElementById(canvasId);
        if (!canvas || labels.length === 0) return;

        new Chart(canvas.getContext('2d'), {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{
        label: labelName,
        data: data,
        backgroundColor: bgColor,
        borderColor: borderColor,
        borderWidth: 1,
        borderRadius: 6
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
        y: {
        beginAtZero: true,
        ticks: {
        precision: 0, // Sadece tam sayılar
        stepSize: 1 //1.2 gibi ondalık değerler göstermesin diye
        }
        }
        }
        }
        });
        }

        // Duygu Dağılımı için Pasta Grafiği
        const ctxSentiment = document.getElementById('sentimentChart');
        if (ctxSentiment) {
        new Chart(ctxSentiment.getContext('2d'), {
        type: 'doughnut',
        data: {
        labels: ['Pozitif', 'Nötr', 'Negatif'],
        datasets: [{
        data: [@Model.ToplamPozitif, @Model.ToplamNotr, @Model.ToplamNegatif],
        backgroundColor: ['#198754', '#6c757d', '#dc3545'],
        borderWidth: 2, borderColor: '#ffffff', cutout: '75%', hoverOffset: 4
        }]
        },
        options: {
        plugins: { legend: { display: false } },
        responsive: true, maintainAspectRatio: false
        }
        });
        }

        // Alt Grafikler (Parse hatası almasın diye böyle kundakladım bozmayın sakın)
        const topNames = JSON.parse('@Html.Raw(Json.Serialize(Model.EnPozitifUrunAdlari ?? new List<string>()))');
        const topScores = JSON.parse('@Html.Raw(Json.Serialize(Model.EnPozitifUrunSkorlari ?? new List<int>()))');
        initBarChart('topProductsChart', topNames, topScores, 'rgba(25, 135, 84, 0.8)', 'rgba(25, 135, 84, 1)', 'Pozitif Yorum');

        const negativeNames = JSON.parse('@Html.Raw(Json.Serialize(Model.EnNegatifUrunAdlari ?? new List<string>()))');
        const negativeScores = JSON.parse('@Html.Raw(Json.Serialize(Model.EnNegatifUrunSkorlari ?? new List<int>()))');
        initBarChart('negativeProductsChart', negativeNames, negativeScores, 'rgba(220, 53, 69, 0.8)', 'rgba(220, 53, 69, 1)', 'Negatif Yorum');

        });
    </script>
}