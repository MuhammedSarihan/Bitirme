@model IEnumerable<Tasarim.Core.Entities.Profil>

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-users-gear text-primary me-2"></i>Müşteri Profilleri
            </h3>
        </div>

        <div class="d-flex gap-3 align-items-center">

            <div class="input-group shadow-sm rounded-pill overflow-hidden" style="min-width: 300px; border: 1px solid #dee2e6;">
                <span class="input-group-text bg-white border-0 text-muted ps-3">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="musteriArama" class="form-control border-0 shadow-none" placeholder="İsim, e-posta veya semt ara...">
            </div>

            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm text-nowrap fw-medium">
                <i class="fa-solid fa-user-plus me-1"></i> Yeni Profil
            </a>
        </div>
    </div>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="musterilerTablosu">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 ps-4">Müşteri Bilgisi</th>
                            <th class="text-secondary fw-semibold">İletişim</th>
                            <th class="text-secondary fw-semibold text-center">Detaylar (Y/B/K)</th>
                            <th class="text-secondary fw-semibold text-center">Cinsiyet</th>
                            <th class="text-secondary fw-semibold">Kullanıcı Adı</th>
                            <th class="text-secondary fw-semibold text-end pe-4" style="width: 150px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Ad @item.Soyad</div>
                                    <small class="text-muted"><i class="fa-solid fa-location-dot me-1 small"></i>@item.Adres</small>
                                </td>
                                <td>
                                    <div class="small"><i class="fa-solid fa-envelope me-2 text-muted"></i>@item.Mail</div>
                                    <div class="small"><i class="fa-solid fa-phone me-2 text-muted"></i>@item.TelNo</div>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-light text-dark border px-2">Yaş: @item.Yas</span>
                                    <span class="badge rounded-pill bg-light text-dark border px-2">Boy: @item.Boy</span>
                                    <span class="badge rounded-pill bg-light text-dark border px-2">Kilo: @item.Kilo</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Cinsiyet == "Kadın")
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3"><i class="fa-solid fa-venus me-1"></i>Kadın</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3"><i class="fa-solid fa-mars me-1"></i>Erkek</span>
                                    }
                                </td>
                                <td>
                                    <span class="fw-medium">@item.Kullanici?.KullaniciAd</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary " title="Düzenle">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info " title="Detaylar">
                                            <i class="fa-solid fa-magnifying-glass"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger " title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const aramaKutusu = document.getElementById('musteriArama');
            
            aramaKutusu.addEventListener('keyup', function () {
                let filtre = this.value.toLowerCase();
                // Tabloya id="musterilerTablosu" eklediğinden emin ol
                let satirlar = document.querySelectorAll('#musterilerTablosu tbody tr'); 

                satirlar.forEach(function (satir) {
                    let satirMetni = satir.textContent.toLowerCase();
                    if (satirMetni.includes(filtre)) {
                        satir.style.display = '';
                    } else {
                        satir.style.display = 'none';
                    }
                });
            });
        });
    </script>
}