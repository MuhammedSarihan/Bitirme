@model IEnumerable<Tasarim.Core.Entities.Profil>

@{
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 font-playfair fw-bold text-dark">
                <i class="fa-solid fa-users me-2 text-gold"></i> Müşteri Profilleri
            </h3>
            
            <!-- Dinamik Bilgi Mesajı -->
            @if (string.IsNullOrEmpty(ViewBag.ArananKelime))
            {
                <p class="text-muted small mt-1 mb-0">Sisteme kayıtlı son 10 müşteri listelenmektedir.</p>
            }
            else
            {
                <p class="text-muted small mt-1 mb-0">"<span class="fw-bold text-dark">@ViewBag.ArananKelime</span>" için arama sonuçları gösteriliyor.</p>
            }
        </div>

        <div class="d-flex gap-3 align-items-center">
            
            <!-- SERVER-SIDE ARAMA FORMU -->
            <form asp-action="Index" method="get" class="m-0">
                <div class="input-group shadow-sm rounded-0 border-dark-subtle" style="min-width: 350px; border: 1px solid #000;">
                    <input type="text" name="arama" value="@ViewBag.ArananKelime" class="form-control border-0 shadow-none rounded-0" placeholder="İsim, E-posta veya Tel ara...">
                    <button type="submit" class="btn btn-dark rounded-0 px-3">
                        <i class="fa-solid fa-magnifying-glass text-gold"></i>
                    </button>
                    <!-- Arama yapıldıysa temizleme butonu çıkar -->
                    @if (!string.IsNullOrEmpty(ViewBag.ArananKelime))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-0 px-3" title="Aramayı Temizle">
                            <i class="fa-solid fa-xmark"></i>
                        </a>
                    }
                </div>
            </form>

            <a asp-action="Create" class="btn btn-dark rounded-0 px-4 shadow-sm text-nowrap fw-medium text-uppercase letter-spacing-1">
                <i class="fa-solid fa-user-plus text-gold me-1"></i> Yeni Profil
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom border-dark">
                    <tr>
                        <th class="text-dark fw-bold py-3 ps-4 text-uppercase small letter-spacing-1">Müşteri</th>
                        <th class="text-dark fw-bold text-uppercase small letter-spacing-1">İletişim</th>
                        <th class="text-dark fw-bold text-center text-uppercase small letter-spacing-1">Fiziksel Profil</th>
                        <th class="text-dark fw-bold text-center text-uppercase small letter-spacing-1">Cinsiyet</th>
                        <th class="text-dark fw-bold text-uppercase small letter-spacing-1">Kullanıcı Adı</th>
                        <th class="text-dark fw-bold text-end pe-4 text-uppercase small letter-spacing-1" style="width: 170px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-user-xmark fs-1 mb-3"></i>
                                <h5>Kayıt Bulunamadı</h5>
                                <p>Arama kriterlerinize uygun müşteri profili sistemde mevcut değil.</p>
                            </td>
                        </tr>
                    }
                    
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom border-light">
                            <td class="ps-4">
                                <div class="fw-bold text-dark fs-6">@item.Ad @item.Soyad</div>
                            </td>
                            <td>
                                <div class="small"><i class="fa-solid fa-envelope me-2 text-gold"></i>@item.Mail</div>
                                <div class="small mt-1"><i class="fa-solid fa-phone me-2 text-gold"></i>@item.TelNo</div>
                            </td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-1">
                                    <span class="badge bg-dark rounded-0 fw-normal">Yaş: @item.Yas</span>
                                    <span class="badge bg-dark rounded-0 fw-normal">Boy: @item.Boy</span>
                                    <span class="badge bg-dark rounded-0 fw-normal">Kilo: @item.Kilo</span>
                                </div>
                            </td>
                            <td class="text-center">
                                @if (item.Cinsiyet == "Kadın")
                                {
                                    <span class="badge bg-light text-dark border border-dark rounded-0 px-3"><i class="fa-solid fa-venus me-1 text-gold"></i>Kadın</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border border-dark rounded-0 px-3"><i class="fa-solid fa-mars me-1 text-gold"></i>Erkek</span>
                                }
                            </td>
                            <td>
                                <span class="fw-medium text-muted">@item.Kullanici?.KullaniciAd</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-dark rounded-0" title="Düzenle">
                                        <i class="fa-solid fa-pen text-gold"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-dark rounded-0" title="Detaylar">
                                        <i class="fa-solid fa-magnifying-glass"></i> İncele
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger rounded-0" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.ToplamSayfa > 1)
{
    <nav aria-label="Sayfalama" class="mt-4 d-flex justify-content-center">
        <ul class="pagination shadow-sm">
            
            <!-- ÖNCEKİ BUTONU -->
            <li class="page-item @(ViewBag.MevcutSayfa == 1 ? "disabled" : "")">
                <a class="page-link rounded-0 border-dark text-dark" 
                   asp-action="Index" 
                   asp-route-arama="@ViewBag.ArananKelime" 
                   asp-route-sayfa="@(ViewBag.MevcutSayfa - 1)">
                    <i class="fa-solid fa-chevron-left text-gold me-1"></i> Önceki
                </a>
            </li>

            <!-- SAYFA NUMARALARI -->
            @for (int i = 1; i <= ViewBag.ToplamSayfa; i++)
            {
                <li class="page-item @(i == ViewBag.MevcutSayfa ? "active" : "")">
                    <a class="page-link rounded-0 border-dark @(i == ViewBag.MevcutSayfa ? "bg-dark text-gold" : "text-dark bg-white")" 
                       asp-action="Index" 
                       asp-route-arama="@ViewBag.ArananKelime" 
                       asp-route-sayfa="@i">
                        @i
                    </a>
                </li>
            }

            <!-- SONRAKİ BUTONU -->
            <li class="page-item @(ViewBag.MevcutSayfa == ViewBag.ToplamSayfa ? "disabled" : "")">
                <a class="page-link rounded-0 border-dark text-dark" 
                   asp-action="Index" 
                   asp-route-arama="@ViewBag.ArananKelime" 
                   asp-route-sayfa="@(ViewBag.MevcutSayfa + 1)">
                    Sonraki <i class="fa-solid fa-chevron-right text-gold ms-1"></i>
                </a>
            </li>

        </ul>
    </nav>
}
@section Scripts {
    <style>
        .font-playfair { font-family: 'Playfair Display', serif; }
        .text-gold { color: #D4AF37 !important; }
        .letter-spacing-1 { letter-spacing: 1px; }
        
        .form-control:focus {
            border-color: #000 !important;
            box-shadow: none !important;
            outline: none !important;
        }
    </style>
}