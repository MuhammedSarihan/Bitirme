@model Tasarim.Core.Entities.Profil

@{
    ViewData["Title"] = "";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-user-plus text-primary me-2"></i>Yeni Müşteri Profili Oluştur
                        </h3>
                    </div>
                    <hr class="text-muted mb-4" />

                    <form asp-action="Create">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger rounded-3 shadow-sm" role="alert"></div>
                        }

                        <div class="row g-5">
                            <div class="col-md-6">
                                <h5 class="text-primary mb-3"><i class="fa-solid fa-address-card me-2"></i>Kişisel Bilgiler</h5>

                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="Ad" class="form-label fw-semibold text-secondary">Ad <span class="text-danger fw-bold">*</span></label>
                                        <div class="input-group shadow-sm">
                                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                                            <input asp-for="Ad" class="form-control border-start-0 ps-0" placeholder="Müşteri Adı"
                                                   required
                                                   oninvalid="this.setCustomValidity('Lütfen müşterinin adını giriniz.')"
                                                   oninput="this.setCustomValidity('')" />
                                        </div>
                                        <span asp-validation-for="Ad" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="Soyad" class="form-label fw-semibold text-secondary">Soyad <span class="text-danger fw-bold">*</span></label>
                                        <input asp-for="Soyad" class="form-control shadow-sm" placeholder="Müşteri Soyadı"
                                               required
                                               oninvalid="this.setCustomValidity('Lütfen müşterinin soyadını giriniz.')"
                                               oninput="this.setCustomValidity('')" />
                                        <span asp-validation-for="Soyad" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Mail" class="form-label fw-semibold text-secondary">E-Posta Adresi <span class="text-danger fw-bold">*</span></label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                                        <input asp-for="Mail" type="email" class="form-control border-start-0 ps-0" placeholder="ornek@mail.com"
                                               required
                                               oninvalid="this.setCustomValidity('Lütfen müşterinin geçerli bir e-posta adresini giriniz.')"
                                               oninput="this.setCustomValidity('')" />
                                    </div>
                                    <span asp-validation-for="Mail" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="TelNo" class="form-label fw-semibold text-secondary">Telefon Numarası</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
                                        <input asp-for="TelNo" class="form-control border-start-0 ps-0" placeholder="05XX XXX XX XX" />
                                    </div>
                                    <span asp-validation-for="TelNo" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Adres" class="form-label fw-semibold text-secondary">Açık Adres</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-location-dot text-muted"></i></span>
                                        <textarea asp-for="Adres" class="form-control border-start-0 ps-0" rows="2" placeholder="Teslimat adresi detayları..."></textarea>
                                    </div>
                                    <span asp-validation-for="Adres" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-info mb-3"><i class="fa-solid fa-person-half-dress me-2"></i>Fiziksel Özellikler & Hesap</h5>

                                <div class="form-group mb-3">
                                    <label asp-for="Cinsiyet" class="form-label fw-semibold text-secondary">Cinsiyet</label>
                                    <div class="input-group shadow-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-venus-mars text-muted"></i></span>
                                        <select asp-for="Cinsiyet" class="form-select border-start-0 ps-0">
                                            <option value="">-- Cinsiyet Seçin --</option>
                                            <option value="Kadın">Kadın</option>
                                            <option value="Erkek">Erkek</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="Cinsiyet" class="text-danger small"></span>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-md-4">
                                        <label asp-for="Yas" class="form-label fw-semibold text-secondary">Yaş</label>
                                        <input asp-for="Yas" class="form-control shadow-sm" type="number" placeholder="Örn: 28" />
                                        <span asp-validation-for="Yas" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="Boy" class="form-label fw-semibold text-secondary">Boy (cm)</label>
                                        <input asp-for="Boy" class="form-control shadow-sm" type="number" placeholder="Örn: 187" />
                                        <span asp-validation-for="Boy" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="Kilo" class="form-label fw-semibold text-secondary">Kilo (kg)</label>
                                        <input asp-for="Kilo" class="form-control shadow-sm" type="number" placeholder="Örn: 75" />
                                        <span asp-validation-for="Kilo" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="form-group mb-3 p-4 bg-light rounded-3 border">
                                    <h6 class="text-dark fw-bold mb-3 border-bottom pb-2">
                                        <i class="fa-solid fa-user-shield me-2 text-primary"></i>Sistem Giriş Bilgileri
                                    </h6>

                                    <div class="alert alert-info py-2 small mb-4 border-0 border-start border-info border-4">
                                        <i class="fa-solid fa-circle-info me-1"></i> Müşterinin sisteme giriş yapabilmesi için benzersiz bir kullanıcı adı ve geçici şifre belirleyin.
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="Kullanici.KullaniciAd" class="form-label fw-semibold text-secondary">Kullanıcı Adı</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-at text-muted"></i></span>
                                                <input asp-for="Kullanici.KullaniciAd" class="form-control border-start-0 ps-0" placeholder="Örn: musteri123" required />
                                            </div>
                                            <span asp-validation-for="Kullanici.KullaniciAd" class="text-danger small"></span>
                                        </div>

                                        <div class="col-md-6">
                                            <label asp-for="Kullanici.Sifre" class="form-label fw-semibold text-secondary">Geçici Şifre</label>
                                            <div class="input-group shadow-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-key text-muted"></i></span>
                                                <input asp-for="Kullanici.Sifre" type="password" class="form-control border-start-0 ps-0" placeholder="Şifre belirleyin" required />
                                            </div>
                                            <span asp-validation-for="Kullanici.Sifre" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted my-4" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fa-solid fa-plus me-2"></i>Profili Oluştur
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}