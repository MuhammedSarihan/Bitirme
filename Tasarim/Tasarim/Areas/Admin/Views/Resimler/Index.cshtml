@model IEnumerable<Tasarim.Core.Entities.Resim>

@{
    ViewData["Title"] = "Ürün Galerisi Yönetimi";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 text-dark fw-bold">
                <i class="fa-solid fa-images text-primary me-2"></i>Geçici olarak var ileride kaldıracağızzzzz
            </h3>
            <p class="text-muted small mt-1 mb-0">Ürünlerinize ait çoklu fotoğrafları ve sıralamalarını buradan yönetin.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-1"></i> Yeni Fotoğraf Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 w-100" id="resimlerTablosu">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 ps-4">Görsel Önizleme</th>
                            <th class="text-secondary fw-semibold">Bağlı Olduğu Ürün</th>
                            <th class="text-secondary fw-semibold text-center">Sıra No</th>
                            <th class="text-secondary fw-semibold text-end pe-4" style="width: 150px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (!string.IsNullOrEmpty(item.ResimYolu))
                                    {
                                        <img src="/img/@item.ResimYolu" alt="Ürün Görseli" class="rounded-3 shadow-sm bg-light p-1" style="width: 80px; height: 80px; object-fit: contain;" onerror="this.style.display='none';" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-3 d-flex justify-content-center align-items-center text-muted shadow-sm border border-dashed" style="width: 80px; height: 80px;">
                                            <i class="fa-solid fa-image-slash fs-4 opacity-50"></i>
                                        </div>
                                    }
                                </td>

                                <td class="fw-bold text-dark fs-6">
                                    @item.Urun?.Baslik
                                </td>

                                <td class="text-center">
                                    <span class="badge bg-dark bg-opacity-10 text-dark border px-3 py-2 fs-6">@item.SiraNo</span>
                                </td>

                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary border-0" title="Düzenle">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-info border-0" title="Detaylar">
                                            <i class="fa-solid fa-magnifying-glass"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger border-0" title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#resimlerTablosu').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json' },
                lengthMenu: [10, 25, 50],
                order: [[1, 'asc'], [2, 'asc']], // Önce Ürün adına, sonra Sıra Numarasına göre dizer
                dom: "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });
        });
    </script>
}