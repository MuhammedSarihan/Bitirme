@model Tasarim.Core.Entities.Resim

@{
    ViewData["Title"] = "Fotoğraf Detayları";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0 text-dark fw-bold">
                            <i class="fa-solid fa-circle-info text-info me-2"></i>Fotoğraf Detayları
                        </h3>
                        <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill shadow-sm">
                            Foto ID: @Model.ID
                        </span>
                    </div>
                    <hr class="text-muted mb-4" />

                    <div class="row g-5 align-items-center">
                        <div class="col-md-6">
                            <h5 class="text-primary mb-3"><i class="fa-solid fa-link me-2"></i>Bağlantı Bilgileri</h5>

                            <ul class="list-group list-group-flush shadow-sm rounded-3 border mb-4">
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center bg-light">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-box me-2"></i>Bağlı Ürün</span>
                                    <span class="fw-bold text-dark">@Html.DisplayFor(model => model.Urun.Baslik)</span>
                                </li>
                                <li class="list-group-item px-4 py-3 d-flex justify-content-between align-items-center bg-light">
                                    <span class="text-secondary fw-semibold"><i class="fa-solid fa-arrow-down-1-9 me-2"></i>Gösterim Sırası</span>
                                    <span class="badge bg-dark bg-opacity-10 text-dark px-3 py-2 fs-6">Sıra: @Html.DisplayFor(model => model.SiraNo)</span>
                                </li>
                            </ul>
                        </div>

                        <div class="col-md-6 text-center">
                            <div class="bg-light p-3 rounded-3 border border-dashed shadow-sm h-100 d-flex flex-column justify-content-center">
                                @if (!string.IsNullOrEmpty(Model.ResimYolu))
                                {
                                    <img src="/img/@Model.ResimYolu" alt="Ürün Görseli" class="img-fluid rounded-3 bg-white p-2 shadow-sm mx-auto" style="max-height: 250px; object-fit: contain;" />
                                }
                                else
                                {
                                    <div class="text-muted fst-italic py-5"><i class="fa-regular fa-image fs-1 opacity-25"></i><br />Görsel Yok</div>
                                }
                            </div>
                        </div>
                    </div>

                    <hr class="text-muted my-5" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-light border px-4 rounded-pill fw-medium text-secondary">
                            <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                            <i class="fa-solid fa-pen me-2"></i>Düzenle
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>