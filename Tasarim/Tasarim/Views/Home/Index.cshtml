@model HomePageViewModel
@{
    ViewData["Title"] = "Anasayfa";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<partial name="_Slider" model="Model.sliderListesi" />

<div class="container mt-4">
    <div class="row g-3">
        <div class="col-md-3"><div class="campaign-banner bg-pink"><h3>Hesaplı Yaz</h3><span>%30'a Varan İndirim</span></div></div>
        <div class="col-md-3"><div class="campaign-banner bg-blue"><h3>Fırsatları Kaçırma</h3><span>Sezon Sonu İndirimi</span></div></div>
        <div class="col-md-3"><div class="campaign-banner bg-green"><h3>Zarafetin Işıltısı</h3><span>Abiye Şıklığını Yakala</span></div></div>
        <div class="col-md-3"><div class="campaign-banner bg-pink"><h3>%60</h3><span>ve üzeri indirim</span></div></div>
    </div>
</div>

<div class="container my-5">
    <div class="d-flex justify-content-between mb-2">
        <h4 class="fw-bold">Sana Özel Ürünler</h4>
        <a href="#" class="text-decoration-none text-dark">Tümünü Gör ></a>
    </div>

    <div class="swiper product-swiper">
        <div class="swiper-wrapper">
            @foreach (var item in Model.Urunler)
            {
                <div class="swiper-slide">
                    <partial name="_UrunView" model="item" />
                </div>
            }
        </div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
    </div>
</div>
<div class="my-5">
    <h1 class="text-center">Kampanyalarımız</h1>

        <div class="row gx-4 gx-lg-5 row-cols-2 justify-content-center">
            @foreach (var item in Model.Kampanyalar)
            {
                <partial name="_KampanyaView" model="item" />
            }
        </div>

</div>
<style>
    .campaign-banner {
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        color: #fff;
        font-weight: bold;
        transition: transform 0.3s;
    }

        .campaign-banner:hover {
            transform: scale(1.05);
        }

    .bg-pink {
        background-color: #fce4ec;
        color: #d81b60;
    }

    .bg-green {
        background-color: #e8f5e9;
        color: #2e7d32;
    }

    .bg-blue {
        background-color: #e3f2fd;
        color: #1565c0;
    }

    .product-swiper {
        padding: 20px 0;
    }

    .swiper-button-next, .swiper-button-prev {
        background: white;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

        .swiper-button-next:after, .swiper-button-prev:after {
            font-size: 18px;
            color: #f27a1a;
        }
</style>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    var swiper = new Swiper(".product-swiper", {
        slidesPerView: 4, // Masaüstünde yan yana 4 ürün gösterir
        spaceBetween: 20, // Ürünler arası boşluk
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
        // Ekran küçüldüğünde ürün sayısını otomatik ayarlar
        breakpoints: {
            320: { slidesPerView: 1 },
            768: { slidesPerView: 3 },
            1024: { slidesPerView: 4 }
        }
    });

</script>