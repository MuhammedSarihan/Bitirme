@{
    ViewData["Title"] = "İletişim";
}

<div class="container my-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="text-center mb-5 pb-2">
                <h2 class="font-playfair fw-bold text-dark display-5">Bize Ulaşın</h2>
                <div style="width: 60px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="my-4"></div>
                <p class="text-muted mx-auto" style="max-width: 500px;">
                    Koleksiyonlarımız, özel dikim talepleriniz veya siparişlerinizle ilgili her türlü sorunuz için buradayız.
                </p>
            </div>

            <div class="d-flex flex-column gap-3 mb-5">

                <div class="d-flex align-items-center p-4 border rounded-0 bg-light bg-opacity-50">
                    <i class="fa-solid fa-location-dot fs-3 text-gold me-4"></i>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Mağaza Adresimiz</h6>
                        <p class="text-muted mb-0 small">Osmanağa Mah. Söğütlüçeşme Cad. No: 123/A Kadıköy, İstanbul</p>
                    </div>
                </div>

                <div class="d-flex align-items-center p-4 border rounded-0 bg-light bg-opacity-50">
                    <i class="fa-solid fa-phone fs-3 text-gold me-4"></i>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">Telefon</h6>
                        <a href="tel:+905551234567" class="text-muted small text-decoration-none hover-gold">+90 (555) 123 45 67</a>
                    </div>
                </div>

                <div class="d-flex align-items-center p-4 border rounded-0 bg-light bg-opacity-50">
                    <i class="fa-solid fa-envelope fs-3 text-gold me-4"></i>
                    <div>
                        <h6 class="fw-bold mb-1 text-dark">E-Posta</h6>
                        <a href="mailto:info@luvialukka.com" class="text-muted small text-decoration-none hover-gold">info@luvialukka.com</a>
                    </div>
                </div>

            </div>

            <div class="mb-5 pt-3">
                <h4 class="font-playfair fw-bold mb-4 text-center">Mesaj Gönderin</h4>

                <form action="/Home/MesajGonder" method="post" class="mt-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Adınız Soyadınız</label>
                            <input type="text" class="form-control rounded-0 p-3 border-secondary bg-transparent" name="AdSoyad" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">E-Posta Adresiniz</label>
                            <input type="email" class="form-control rounded-0 p-3 border-secondary bg-transparent" name="Email" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">Konu</label>
                            <input type="text" class="form-control rounded-0 p-3 border-secondary bg-transparent" name="Konu" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">Mesajınız</label>
                            <textarea class="form-control rounded-0 p-3 border-secondary bg-transparent" name="Mesaj" style="height: 150px" required></textarea>
                        </div>
                        <div class="col-12 mt-5">
                            <button class="btn btn-dark w-100 rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0" type="submit">
                                Mesajı İlet
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="w-100 mt-5 border p-2 bg-light">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3011.6558485293457!2d29.0270632!3d40.9890253!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cab863f6050b1d%3A0x6b40bd491bd0bc50!2sS%C3%B6%C4%9F%C3%BCtl%C3%BC%C3%A7e%C5%9Fme%20Cd.%2C%20Kad%C4%B1k%C3%B6y%2F%C4%B0stanbul!5e0!3m2!1str!2str!4v1700000000000!5m2!1str!2str"
                        width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <style>
        .text-gold {
            color: #D4AF37 !important;
        }

        .hover-gold:hover {
            color: #D4AF37 !important;
            transition: 0.3s;
        }

        .hover-gold-bg:hover {
            background-color: #D4AF37 !important;
            color: #fff !important;
            transition: 0.3s;
        }

        .font-playfair {
            font-family: 'Playfair Display', serif;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        /* Input Tıklanınca Siyah Çerçeve Gelsin */
        .form-control:focus {
            border-color: #000;
            box-shadow: none;
            background-color: #fff !important;
        }
    </style>
}