@{
    ViewData["Title"] = "Hakkımızda";
}

<div class="container my-5 pt-4">

    <div class="text-center mb-5">
        <h1 class="display-6 font-playfair fw-bold mb-2">Hikayemiz</h1>
        <div class="mx-auto bg-dark" style="height: 2px; width: 60px;"></div>
        <p class="text-muted mt-3 small text-uppercase letter-spacing-1">Zarafetin ve Şıklığın Yeni Adresi</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="bg-white p-4 p-md-5 border shadow-sm rounded-4">

                <div class="text-center mb-5">
                    <h3 class="font-playfair fw-bold text-dark mb-4">LUVIA LUKKA'ya Hoş Geldiniz</h3>
                    <p class="text-muted" style="line-height: 1.9; font-size: 1.05rem;">
                        <strong>LUVIA LUKKA</strong>, modern kadının zarafetini, güçlü duruşunu ve özgün tarzını kıyafetlere yansıtmak tutkusuyla doğmuş premium bir giyim markasıdır. En özel günlerinizden günlük şıklığınıza kadar, her anınızda kendinizi özel ve güvende hissetmeniz için özenle tasarlanmış koleksiyonlar sunuyoruz. Yüksek kaliteli kumaşları, kusursuz kalıplar ve usta el işçiliğiyle buluşturarak modayı sadece giyilen bir ürün değil, bir yaşam tarzı olarak yeniden tanımlıyoruz.
                    </p>
                </div>

                <div class="row g-5 mt-2">
                    <div class="col-md-6">
                        <div class="d-flex flex-column align-items-center text-center p-4 h-100 bg-light rounded-4 border-0">
                            <i class="fa-solid fa-gem text-gold fs-1 mb-3"></i>
                            <h5 class="font-playfair fw-bold text-dark mb-3">Misyonumuz</h5>
                            <p class="text-muted mb-0 small" style="line-height: 1.8;">
                                Estetik ve kaliteyi ulaşılabilir kılarak, müşterilerimizin gardıroplarına zamansız parçalar kazandırmak. Her bir tasarımımızla, kadınların kendilerini en güzel ve en özgüvenli halleriyle ifade etmelerine ilham olmak.
                            </p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="d-flex flex-column align-items-center text-center p-4 h-100 bg-light rounded-4 border-0">
                            <i class="fa-solid fa-eye text-gold fs-1 mb-3"></i>
                            <h5 class="font-playfair fw-bold text-dark mb-3">Vizyonumuz</h5>
                            <p class="text-muted mb-0 small" style="line-height: 1.8;">
                                Yenilikçi tasarım anlayışımız ve müşteri odaklı hizmet kalitemizle, Türkiye'de ve dünyada şıklık denildiğinde akla gelen ilk, en prestijli ve en güvenilir moda markalarından biri olmak.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top">
                    <h4 class="font-playfair fw-bold mb-4 text-dark text-center">Neden LUVIA LUKKA?</h4>
                    <div class="row g-4 mt-2">
                        <div class="col-md-4 text-center">
                            <i class="fa-solid fa-check-double text-gold fs-3 mb-2"></i>
                            <h6 class="fw-bold text-dark">Kusursuz Kalite</h6>
                            <p class="text-muted small">Kumaş seçiminden dikiş detaylarına kadar her aşamada en üst düzey kalite standartlarını uyguluyoruz.</p>
                        </div>
                        <div class="col-md-4 text-center">
                            <i class="fa-solid fa-palette text-gold fs-3 mb-2"></i>
                            <h6 class="fw-bold text-dark">Özgün Tasarımlar</h6>
                            <p class="text-muted small">Moda trendlerini kendi lüks çizgimizle harmanlayarak, size özel ve benzersiz koleksiyonlar üretiyoruz.</p>
                        </div>
                        <div class="col-md-4 text-center">
                            <i class="fa-solid fa-heart text-gold fs-3 mb-2"></i>
                            <h6 class="fw-bold text-dark">Müşteri Memnuniyeti</h6>
                            <p class="text-muted small">Alışverişinizin her adımında ve satış sonrasında, güler yüzlü ekibimizle her zaman yanınızdayız.</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .font-playfair {
            font-family: 'Playfair Display', serif;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        .text-gold {
            color: #D4AF37 !important;
        }
    </style>
}