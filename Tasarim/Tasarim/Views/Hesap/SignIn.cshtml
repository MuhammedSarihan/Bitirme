@using Tasarim.Models.Hesap
@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">

            <div class="text-center mb-5">
                <h2 class="font-playfair fw-bold text-dark display-6">Hoş Geldiniz</h2>
                <div style="width: 50px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="my-3"></div>
                <p class="text-muted small">Luvia Lukka hesabınıza giriş yaparak alışverişinize kaldığınız yerden devam edin.</p>
            </div>

            <div class="card border-0 shadow-sm rounded-0 bg-light bg-opacity-50">
                <div class="card-body p-4 p-md-5">

                    <form asp-action="SignIn">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-0 small"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="KullaniciAd" class="form-control rounded-0 border-secondary bg-transparent" placeholder="Kullanıcı Adı" />
                            <label asp-for="KullaniciAd" class="text-muted">Kullanıcı Adı</label>
                            <span asp-validation-for="KullaniciAd" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Sifre" type="password" class="form-control rounded-0 border-secondary bg-transparent" placeholder="Şifre" />
                            <label asp-for="Sifre" class="text-muted">Şifre</label>
                            <span asp-validation-for="Sifre" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 small">
                            <div class="form-check">
                                <input class="form-check-input rounded-0 border-secondary cursor-pointer" type="checkbox" id="beniHatirla">
                                <label class="form-check-label text-muted cursor-pointer" for="beniHatirla">
                                    Beni Hatırla
                                </label>
                            </div>
                            <a href="#" class="text-decoration-none text-muted hover-gold">Şifremi Unuttum</a>
                        </div>

                        <div class="d-grid gap-2 mt-2">
                            <button type="submit" class="btn btn-dark btn-lg rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0">
                                Giriş Yap
                            </button>
                        </div>
                    </form>

                    <hr class="my-5 border-secondary opacity-25">

                    <div class="text-center">
                        <span class="text-muted small">Henüz Luvia Lukka üyesi değil misiniz?</span>
                        <br class="d-md-none" />
                        <a asp-action="SignUp" class="text-decoration-none text-dark fw-bold ms-md-1 hover-gold text-uppercase small letter-spacing-1 d-inline-block mt-2 mt-md-0">
                            Hemen Kayıt Olun
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <style>
        .text-gold {
            color: #D4AF37 !important;
        }

        .hover-gold:hover {
            color: #D4AF37 !important;
            transition: 0.3s;
        }

        .hover-gold-bg:hover {
            background-color: #D4AF37 !important;
            color: #fff !important;
            transition: 0.3s;
        }

        .font-playfair {
            font-family: 'Playfair Display', serif;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        .cursor-pointer {
            cursor: pointer;
        }

        /* Input Focus Renkleri (Tıklandığında siyah çerçeve) */
        .form-control:focus {
            border-color: #0B132B;
            box-shadow: none;
            background-color: #fff !important;
        }

        /* Checkbox Focus Rengi */
        .form-check-input:checked {
            background-color: #0B132B;
            border-color: #0B132B;
        }

        .form-check-input:focus {
            box-shadow: none;
            border-color: #0B132B;
        }
    </style>
}