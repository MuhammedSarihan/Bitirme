@using Tasarim.Models.Hesap
@model KayitViewModel

@{
    ViewData["Title"] = "Aramıza Katıl";
}

<div class="container py-5 my-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="text-center mb-5">
                <h2 class="font-playfair fw-bold text-dark display-6">Luvia Lukka'ya Katılın</h2>
                <div style="width: 50px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="my-3"></div>
                <p class="text-muted small">Özel koleksiyonlara erişmek ve hızlı sipariş vermek için hesabınızı oluşturun.</p>
            </div>

            <div class="card border-0 shadow-sm rounded-0 bg-light bg-opacity-50">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="SignUp">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-0 small"></div>

                        <div class="row g-5">
                            <div class="col-md-5 border-end-md">
                                <h6 class="text-uppercase fw-bold mb-4 text-gold letter-spacing-1">Hesap Bilgileri</h6>

                                <div class="form-floating mb-3">
                                    <input asp-for="KullaniciAd" class="form-control rounded-0 border-secondary bg-transparent"/>
                                    <label asp-for="KullaniciAd" class="text-muted">Kullanıcı Adı</label>
                                    <span asp-validation-for="KullaniciAd" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <input asp-for="Sifre" type="password" class="form-control rounded-0 border-secondary bg-transparent"/>
                                    <label asp-for="Sifre" class="text-muted">Şifre</label>
                                    <span asp-validation-for="Sifre" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-4">
                                    <input asp-for="SifreTekrar" type="password" class="form-control rounded-0 border-secondary bg-transparent"/>
                                    <label asp-for="SifreTekrar" class="text-muted">Şifre (Tekrar)</label>
                                    <span asp-validation-for="SifreTekrar" class="text-danger small"></span>
                                </div>

                                <div class="p-3 border rounded-0 bg-white small text-muted">
                                    <i class="fa-solid fa-shield-halved text-gold me-2"></i>
                                    Kişisel verileriniz gizlilik politikamız kapsamında güvenle saklanmaktadır. Kayıt olarak sözleşmeyi kabul etmiş sayılırsınız.
                                </div>
                            </div>

                            <div class="col-md-7">
                                <h6 class="text-uppercase fw-bold mb-4 text-gold letter-spacing-1">Kişisel Bilgiler</h6>

                                <div class="row g-3 mb-3">
                                    <div class="col-sm-6">
                                        <div class="form-floating">
                                            <input asp-for="Ad" class="form-control rounded-0 border-secondary bg-transparent" />
                                            <label asp-for="Ad" class="text-muted">Adınız</label>
                                        </div>
                                        <span asp-validation-for="Ad" class="text-danger small"></span>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="form-floating">
                                            <input asp-for="Soyad" class="form-control rounded-0 border-secondary bg-transparent" />
                                            <label asp-for="Soyad" class="text-muted">Soyadınız</label>
                                        </div>
                                        <span asp-validation-for="Soyad" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="row g-3 mb-3">
                                    <div class="col-sm-6">
                                        <div class="form-floating">
                                            <input asp-for="Tel" class="form-control rounded-0 border-secondary bg-transparent" />
                                            <label asp-for="Tel" class="text-muted">Telefon Numaranız</label>
                                        </div>
                                        <span asp-validation-for="Tel" class="text-danger small"></span>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="form-floating">
                                            <input asp-for="Mail" type="email" class="form-control rounded-0 border-secondary bg-transparent" />
                                            <label asp-for="Mail" class="text-muted">E-Posta Adresiniz</label>
                                        </div>
                                        <span asp-validation-for="Mail" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="form-floating mb-3">
                                    <textarea asp-for="Adres" class="form-control rounded-0 border-secondary bg-transparent" style="height: 100px;"></textarea>
                                    <label asp-for="Adres" class="text-muted"> Adresiniz</label>
                                    <span asp-validation-for="Adres" class="text-danger small"></span>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-md-3 col-6">
                                        <div class="form-floating">
                                            <select asp-for="Cinsiyet" class="form-select rounded-0 border-secondary bg-transparent">
                                                <option value="Kadın">Kadın</option>
                                                <option value="Erkek">Erkek</option>
                                            </select>
                                            <label asp-for="Cinsiyet" class="text-muted">Cinsiyet</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3 col-6">
                                        <div class="form-floating">
                                            <input asp-for="Yas" type="number" class="form-control rounded-0 border-secondary bg-transparent" />
                                            <label asp-for="Yas" class="text-muted">Yaş</label>
                                        </div>
                                        <span asp-validation-for="Yas" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-3 col-6">
                                        <div class="form-floating">
                                            <input asp-for="Boy" type="number" class="form-control rounded-0 border-secondary bg-transparent" />
                                            <label asp-for="Boy" class="text-muted">Boy (cm)</label>
                                        </div>
                                        <span asp-validation-for="Boy" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-3 col-6">
                                        <div class="form-floating">
                                            <input asp-for="Kilo" type="number" class="form-control rounded-0 border-secondary bg-transparent"  />
                                            <label asp-for="Kilo" class="text-muted">Kilo (kg)</label>
                                        </div>
                                        <span asp-validation-for="Kilo" class="text-danger small"></span>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <hr class="my-5 border-secondary opacity-25">

                        <div class="d-flex flex-column align-items-center">
                            <button type="submit" class="btn btn-dark btn-lg rounded-0 px-5 py-3 mb-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0" style="min-width: 300px;">
                                Kaydı Tamamla
                            </button>
                            <a asp-action="SignIn" class="text-decoration-none text-muted small hover-gold">
                                Zaten bir hesabınız var mı? <strong class="text-dark">Buradan giriş yapın.</strong>
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <style>
        .text-gold {
            color: #D4AF37 !important;
        }

        .hover-gold:hover {
            color: #D4AF37 !important;
            transition: 0.3s;
        }

        .hover-gold-bg:hover {
            background-color: #D4AF37 !important;
            color: #fff !important;
            transition: 0.3s;
        }

        .font-playfair {
            font-family: 'Playfair Display', serif;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        /* Input Focus Renkleri */
        .form-control:focus, .form-select:focus {
            border-color: #0B132B;
            box-shadow: none;
            background-color: #fff !important;
        }

        /* Orta Çizgi (Responsive) */
        @@media (min-width: 768px) {
            .border-end-md {
                border-right: 1px solid rgba(0,0,0,0.1);
            }
        }
    </style>
}