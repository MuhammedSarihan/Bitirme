@model Tasarim.Core.Entities.Kampanya
@{
    ViewData["Title"] = Model.KampanyaAd + " - Kampanya Detayları";
}

<div class="container my-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            <div class="text-center mb-5 pb-2">
                <h2 class="font-playfair fw-bold text-dark display-5">Kampanya Detayları</h2>
                <div style="width: 60px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="my-4"></div>
            </div>

            <div class="row g-5 mb-5">
                <div class="col-md-7 d-flex flex-column justify-content-center">
                    <h3 class="font-playfair fw-bold text-dark mb-4">@Html.DisplayFor(model => model.KampanyaAd)</h3>
                    
                    <div class="mb-4">
                        @if (Model.KampanyaAktifMi)
                        {
                            <span class="badge rounded-0 bg-dark text-white px-4 py-2 fs-6 letter-spacing-1 text-uppercase fw-normal">Aktif Kampanya</span>
                        }
                        else
                        {
                            <span class="badge rounded-0 bg-secondary text-white px-4 py-2 fs-6 letter-spacing-1 text-uppercase fw-normal">Süresi Dolmuş</span>
                        }
                    </div>

                    <div class="p-4 border rounded-0 bg-light bg-opacity-50 mt-2">
                        <h6 class="fw-bold text-dark mb-3 text-uppercase letter-spacing-1"><i class="fa-solid fa-align-left text-gold me-2"></i>Açıklama</h6>
                        <p class="mb-0 text-muted lh-lg">
                            @(string.IsNullOrEmpty(Model.Aciklama) ? "Bu kampanya için henüz bir açıklama girilmemiş." : Model.Aciklama)
                        </p>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="sticky-top" style="top: 80px;">
                        <div class="bg-white p-2 rounded-0 border kampanya-image-wrapper d-flex align-items-center justify-content-center" style="min-height: 400px;">
                            @if (!string.IsNullOrEmpty(Model.KampanyaResmi))
                            {
                                <img src="/img/@Model.KampanyaResmi" id="mainImage" alt="@Model.KampanyaAd" class="img-fluid rounded-0 active-fade" style="max-height: 380px; object-fit: contain;" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                            }
                            else
                            {
                                <div class="text-center text-muted py-5">
                                    <i class="fa-regular fa-image fs-1 mb-3 opacity-25" style="font-size: 3rem !important;"></i>
                                    <p class="small mb-0 fst-italic letter-spacing-1">Görsel Eklenmemiş</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5 pt-5 border-top">
                <div class="text-center mb-5 pb-2">
                    <h3 class="font-playfair fw-bold text-dark h2">Kampanyadaki Ürünler</h3>
                    <div style="width: 40px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="my-3"></div>
                </div>

                <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
                    @if (Model.KampanyaUrunleri != null && Model.KampanyaUrunleri.Any())
                    {                    
                        // Kampanya içindeki KampanyaUrunleri listesinde dönüyoruz                    
                        foreach (var item in Model.KampanyaUrunleri)
                        {
                            <div class="col mb-4">
                                <div class="card h-100 rounded-0 border product-card-hover">
                                    <img class="card-img-top p-3 rounded-0"
                                         src="~/img/@item.Urun.AnaResim"
                                         alt="@item.Urun.Baslik"
                                         style="height: 280px; object-fit: contain; width: 100%;">

                                    <div class="card-body p-3 text-center d-flex flex-column justify-content-end">
                                        <h6 class="fw-bold text-dark text-truncate mb-2 font-playfair" style="font-size: 1.1rem;">@item.Urun.Baslik</h6>
                                        <span class="text-muted fw-bold mb-3">@item.Urun.Fiyat.ToString("c")</span>
                                    </div>

                                    <div class="card-footer p-0 border-top-0 bg-transparent">
                                        <a class="btn btn-dark w-100 rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0" href="/Urunler/Details/@item.Urun.ID">
                                            Detaylı İncele
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert rounded-0 border bg-light bg-opacity-50 text-center py-4" role="alert">
                                <i class="fa-solid fa-gem text-gold fs-3 mb-3 d-block"></i>
                                <span class="text-muted letter-spacing-1 fw-bold">Bu kampanyaya henüz ürün eklenmemiş.</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateMainImage(src, element) {
            const mainImg = document.getElementById('mainImage');
            mainImg.src = src;

            // Animasyonu Yenile
            mainImg.classList.remove('active-fade');
            void mainImg.offsetWidth;
            mainImg.classList.add('active-fade');

            // Aktif Sınıfını Güncelle
            document.querySelectorAll('.thumb-item').forEach(item => item.classList.remove('active'));
            element.classList.add('active');
        }
    </script>

    <style>
        /* Marka Renkleri ve Fontları */
        .text-gold {
            color: #D4AF37 !important;
        }

        .hover-gold:hover {
            color: #D4AF37 !important;
            transition: 0.3s;
        }

        .hover-gold-bg:hover {
            background-color: #D4AF37 !important;
            color: #fff !important;
            transition: 0.3s;
        }

        .font-playfair {
            font-family: 'Playfair Display', serif;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        /* Resim Çerçevesi Hover Efekti */
        .kampanya-image-wrapper {
            transition: border-color 0.3s, box-shadow 0.3s;
        }
        
        .kampanya-image-wrapper:hover {
            border-color: #D4AF37 !important;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        /* Ürün Kartı Hover Efekti */
        .product-card-hover {
            transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        }

        .product-card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            border-color: #D4AF37 !important;
        }

        /* Thumbnail ve Animasyon Stilleri */
        .thumb-item {
            cursor: pointer;
            transition: 0.3s;
            opacity: 0.6;
            min-width: 70px;
            border-radius: 0 !important; /* Keskin köşeler */
        }

        .thumb-item:hover, .thumb-item.active {
            opacity: 1;
            transform: translateY(-3px);
        }

        .thumb-item.active img {
            border: 2px solid #D4AF37 !important; /* Mavi yerine Altın Sarısı çerçeve */
        }

        .active-fade {
            animation: imgFade 0.4s ease-in-out;
        }

@@keyframes imgFade {
            from {
                opacity: 0;
                transform: scale(0.98);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
}