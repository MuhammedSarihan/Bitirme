@using Tasarim.Core.Entities
@model Urun
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Baslik;
    var digerRenkler = ViewBag.AyniGrupUrunler as List<Tasarim.Core.Entities.Urun>;
}

<div class="container my-5 pt-4">
    <div class="row g-5">

        <div class="col-lg-6">
            <!-- ÇÖZÜM 2: z-index: 1 eklendi (Navbar çakışmasını önler) -->
            <div class="sticky-top" style="top: 100px; z-index: 1;">
                <div class="card border border-light shadow-sm mb-3 p-2 text-center position-relative">
                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                    {
                        <img src="/img/@Model.AnaResim" id="mainProductImage" class="img-fluid fade-in-image rounded" alt="@Model.Baslik" style="max-height: 750px; object-fit: contain; width: 100%;">
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center" style="height: 650px; background: #f8f9fa;">
                            <i class="fa-regular fa-image text-muted opacity-25" style="font-size: 5rem;"></i>
                        </div>
                    }

                    @if (Model.Fiyat > 20000)
                    {
                        <span class="badge bg-dark text-gold position-absolute top-0 start-0 m-3 px-3 py-2 fs-6 font-playfair shadow">Premium</span>
                    }
                </div>

                <div class="d-flex justify-content-center gap-2 overflow-auto custom-scrollbar pb-2">
                    @if (!string.IsNullOrEmpty(Model.AnaResim))
                    {
                        <div class="thumb-wrapper active" onclick="changeProductImage('/img/@Model.AnaResim', this)">
                            <img src="/img/@Model.AnaResim" alt="Ana Görsel">
                        </div>
                    }

                    @if (Model.Resimler != null && Model.Resimler.Any())
                    {
                        foreach (var resim in Model.Resimler.OrderBy(r => r.SiraNo))
                        {
                            <div class="thumb-wrapper" onclick="changeProductImage('/img/@resim.ResimYolu', this)">
                                <img src="/img/@resim.ResimYolu" alt="Detay">
                            </div>
                        }
                    }
                </div>
                <div class="text-center mt-2">
                    <small class="text-muted"><i class="fa-solid fa-magnifying-glass-plus me-1"></i>Resimler arasında geçiş yapmak için tıklayın.</small>
                </div>
            </div>
        </div>

        <div class="col-lg-6">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb small">
                    <li class="breadcrumb-item"><a href="/" class="text-muted text-decoration-none hover-gold">Ana Sayfa</a></li>
                    <li class="breadcrumb-item"><a href="#" class="text-muted text-decoration-none hover-gold">@(Model.Kategori?.KategoriAd ?? "Kategori")</a></li>
                    <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">@Model.Baslik</li>
                </ol>
            </nav>

            <h1 class="display-5 font-playfair fw-bold mb-2">@Model.Baslik</h1>

            <div class="d-flex flex-wrap gap-4 text-muted mb-4 small bg-light p-3 rounded border">
                <span><i class="fa-solid fa-barcode me-1"></i>Kod: <strong class="text-dark">@Model.UrunKod</strong></span>
                <span><i class="fa-solid fa-palette me-1"></i>Renk: <strong class="text-dark">@(string.IsNullOrEmpty(Model.Renk) ? "Belirtilmemiş" : Model.Renk)</strong></span>
                <span><i class="fa-solid fa-copyright me-1"></i>Marka: <strong class="text-dark">@(Model.Marka?.MarkaAd ?? "-")</strong></span>
            </div>

            @if (Model.Fiyat > Model.KampanyaliFiyat)
            {
                <span class="text-muted text-decoration-line-through me-2 fs-5 opacity-75">@Model.Fiyat.ToString("C2")</span>
                <span class="text-danger fw-bold fs-3">@Model.KampanyaliFiyat.ToString("C2")</span>
            }
            else
            {
                <span class="text-gold fw-bold fs-3">@Model.Fiyat.ToString("C2")</span>
            }

            <div class="mb-4 mt-3">
                <p class="mb-2 text-dark fw-semibold">Ürün Açıklaması</p>
                <p class="text-muted lh-lg font-sm">
                    @(string.IsNullOrEmpty(Model.Aciklama) ? "Bu zarif tasarım, özel günlerinizde şıklığınızı tamamlamak için özenle üretilmiştir." : Model.Aciklama)
                </p>
            </div>
            @{
                var onayliYorumlar = Model.Yorumlar?.Where(y => y.AnalizEdilirMi == 1 && y.YasakliKelime == false).ToList();
                int toplamYorum = onayliYorumlar?.Count ?? 0;
                double ortPuan = toplamYorum > 0 ? onayliYorumlar.Average(y => (double)y.Puan) : 0;
                int yildizAdedi = (int)Math.Round(ortPuan);
            }

            <div class="mb-4 d-flex align-items-center bg-light p-3 rounded border">
                <span class="text-dark fw-semibold me-3">Ürün Puanı:</span>
                <div class="text-gold fs-5">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= yildizAdedi)
                        {
                            <i class="fa-solid fa-star"></i>
                        }
                        else
                        {
                            <i class="fa-regular fa-star opacity-50"></i>
                        }
                    }
                </div>
                <span class="text-muted ms-3 small fw-medium letter-spacing-1">
                    @(toplamYorum > 0 ? $"{ortPuan.ToString("0.0")} / 5 ({toplamYorum} Değerlendirme)" : "Henüz değerlendirilmedi")
                </span>
            </div>
            <hr class="my-4">

            <div class="mb-4">
                <p class="mb-2 text-dark fw-semibold">Diğer Renk Seçenekleri</p>
                <div class="d-flex gap-3 align-items-center">
                    <div class="border border-dark p-1 rounded-circle" title="@Model.Renk (Seçili)">
                        <img src="/img/@Model.AnaResim" class="rounded-circle" style="width: 55px; height: 55px; object-fit: cover;">
                    </div>

                    @if (digerRenkler != null && digerRenkler.Any())
                    {
                        foreach (var benzer in digerRenkler)
                        {
                            <a href="/Urunler/Details/@benzer.ID" class="border p-1 rounded-circle opacity-50 hover-opacity-100 transition-300" title="@benzer.Renk">
                                <img src="/img/@benzer.AnaResim" class="rounded-circle" style="width: 55px; height: 55px; object-fit: cover;">
                            </a>
                        }
                    }
                </div>
            </div>

            <form asp-controller="Sepet" asp-action="Ekle" method="post" class="mb-3">
                <div class="mb-4">
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @{
                            // ÇÖZÜM 1: Stok kontrolleri
                            bool hasAnyStock = false;
                            bool defaultSelected = false;
                        }

                        @if (Model.Varyasyonlar != null && Model.Varyasyonlar.Any())
                        {
                            foreach (var varyasyon in Model.Varyasyonlar.OrderBy(v => v.Beden))
                            {
                                bool stokYok = varyasyon.StokAdedi <= 0;
                                if (!stokYok) { hasAnyStock = true; } 

                                bool isChecked = false;
                                if (!stokYok && !defaultSelected)
                                {
                                    isChecked = true;
                                    defaultSelected = true;
                                }

                                <input type="radio" class="btn-check beden-radio" name="UrunVaryasyonID" value="@varyasyon.ID" id="beden_@varyasyon.ID" data-stok="@varyasyon.StokAdedi" autocomplete="off" @(stokYok ? "disabled" : "") @(isChecked ? "checked" : "") required>
                                <label class="btn btn-outline-dark rounded-0 px-4 py-2 fw-semibold @(stokYok ? "opacity-50 text-decoration-line-through bg-light" : "")" for="beden_@varyasyon.ID">
                                    @varyasyon.Beden
                                </label>
                            }
                        }
                        else
                        {
                            <div class="alert alert-warning py-2 small rounded-0 w-100">Stok bilgisi bulunmuyor.</div>
                        }
                    </div>

                    <div class="mb-4">
                        <p class="mb-2 text-dark fw-semibold">Adet <span id="stokUyari" class="text-danger small ms-2" style="display:none;">(Maksimum stok limitine ulaştınız)</span></p>
                        <div class="input-group" style="width: 120px;">
                            <input type="number" name="miktar" id="miktarInput" class="form-control rounded-0 border-dark text-center fw-bold" value="1" min="1" max="1" disabled required />
                        </div>
                    </div>
                </div>

                <button type="submit" id="btnSepeteEkle" class="btn btn-dark btn-lg w-100 rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0 shadow-sm" @(!hasAnyStock ? "disabled" : "")>
                    <i class="fa-solid fa-bag-shopping me-2"></i> @(!hasAnyStock ? "Tükendi" : "Sepete Ekle")
                </button>
            </form>
            
            <div class="d-grid gap-3">
                @if (ViewBag.FavorideMi != null && ViewBag.FavorideMi == true)
                {
                    <form asp-action="Remove" asp-controller="Favoriler" method="post" class="m-0 p-0">
                        <input type="hidden" name="UrunID" value="@Model.ID" />
                        <button class="btn btn-light border w-100 btn-lg rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 transition-300" type="submit" title="Favorilerden Çıkar">
                            <i class="fa-solid fa-heart text-danger me-2"></i> Favorilerde
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="Add" asp-controller="Favoriler" method="post" class="m-0 p-0">
                        <input type="hidden" name="UrunID" value="@Model.ID" />
                        <button class="btn btn-outline-dark w-100 btn-lg rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 transition-300" type="submit">
                            <i class="fa-regular fa-heart me-2"></i> Favorilere Ekle
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
    <!------------------------------------------------------------------------------------>
@{
        var yapayZekaOzeti = Model.LLSonuc; 
        
        // Yüzdelik kartlar için yorum sayılarını ve oranlarını hesaplıyoruz
        var hesaplanacakYorumlar = Model.Yorumlar?.Where(y => y.AnalizEdilirMi == 1 && y.YasakliKelime == false).ToList();
        int gnToplamYorum = hesaplanacakYorumlar?.Count ?? 0;

        // Puan mantığı: 4-5 Pozitif | 3 Nötr | 1-2 Negatif
        int pozitifSayisi = hesaplanacakYorumlar?.Count(y => y.Puan >= 4) ?? 0;
        int negatifSayisi = hesaplanacakYorumlar?.Count(y => y.Puan <= 2) ?? 0;
        int notrSayisi = hesaplanacakYorumlar?.Count(y => y.Puan == 3) ?? 0;

        string pozitifYuzde = gnToplamYorum > 0 ? ((double)pozitifSayisi / gnToplamYorum * 100).ToString("0.00") : "0.00";
        string negatifYuzde = gnToplamYorum > 0 ? ((double)negatifSayisi / gnToplamYorum * 100).ToString("0.00") : "0.00";
        string notrYuzde = gnToplamYorum > 0 ? ((double)notrSayisi / gnToplamYorum * 100).ToString("0.00") : "0.00";
    }

    @if (yapayZekaOzeti != null)
    {
        List<string> Top5Artilar = new();
        List<string> Top5Eksiler = new();
        List<string> Top5Oneriler = new();
        List<string> Top5Sikayetler = new();

        // JSON formatında tutulan verileri Listelere çeviriyoruz
        try
        {
            if (!string.IsNullOrWhiteSpace(yapayZekaOzeti.TopArtilar) && yapayZekaOzeti.TopArtilar != "[]")
                Top5Artilar = System.Text.Json.JsonSerializer.Deserialize<List<string>>(yapayZekaOzeti.TopArtilar) ?? new List<string>();

            if (!string.IsNullOrWhiteSpace(yapayZekaOzeti.TopEksiler) && yapayZekaOzeti.TopEksiler != "[]")
                Top5Eksiler = System.Text.Json.JsonSerializer.Deserialize<List<string>>(yapayZekaOzeti.TopEksiler) ?? new List<string>();

            if (!string.IsNullOrWhiteSpace(yapayZekaOzeti.TopOneriler) && yapayZekaOzeti.TopOneriler != "[]")
                Top5Oneriler = System.Text.Json.JsonSerializer.Deserialize<List<string>>(yapayZekaOzeti.TopOneriler) ?? new List<string>();

            if (!string.IsNullOrWhiteSpace(yapayZekaOzeti.TopSikayetler) && yapayZekaOzeti.TopSikayetler != "[]")
                Top5Sikayetler = System.Text.Json.JsonSerializer.Deserialize<List<string>>(yapayZekaOzeti.TopSikayetler) ?? new List<string>();
        }
        catch { }

        <div class="row mt-5 pt-4 border-top">
            <div class="col-lg-12">
                
                <h3 class="font-playfair fw-bold mb-4">
                    <i class="fa-solid fa-wand-magic-sparkles text-gold me-2"></i>Yapay Zeka Deneyim Özeti
                </h3>

                <div class="row g-3 mb-4">
                    
                    <div class="col-xl-3 col-md-6">
                        <div class="card border border-light shadow-sm rounded-4 h-100 bg-white">
                            <div class="card-body p-3 d-flex align-items-center">
                                <div class="me-3" style="font-size: 2.5rem; line-height: 1;">😊</div>
                                <div>
                                    <h4 class="mb-0 text-success fw-bold">%@pozitifYuzde</h4>
                                    <span class="d-block text-dark fw-medium small letter-spacing-1 text-uppercase">Pozitif</span>
                                    <small class="text-muted">@pozitifSayisi yorum</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card border border-light shadow-sm rounded-4 h-100 bg-white">
                            <div class="card-body p-3 d-flex align-items-center">
                                <div class="me-3" style="font-size: 2.5rem; line-height: 1;">😞</div>
                                <div>
                                    <h4 class="mb-0 text-danger fw-bold">%@negatifYuzde</h4>
                                    <span class="d-block text-dark fw-medium small letter-spacing-1 text-uppercase">Negatif</span>
                                    <small class="text-muted">@negatifSayisi yorum</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card border border-light shadow-sm rounded-4 h-100 bg-white">
                            <div class="card-body p-3 d-flex align-items-center">
                                <div class="me-3" style="font-size: 2.5rem; line-height: 1;">😐</div>
                                <div>
                                    <h4 class="mb-0 text-warning fw-bold">%@notrYuzde</h4>
                                    <span class="d-block text-dark fw-medium small letter-spacing-1 text-uppercase">Nötr</span>
                                    <small class="text-muted">@notrSayisi yorum</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card border border-light shadow-sm rounded-4 h-100 bg-white">
                            <div class="card-body p-3 d-flex align-items-center">
                                <div class="me-3" style="font-size: 2.5rem; line-height: 1;">📊</div>
                                <div>
                                    <h4 class="mb-0 text-info fw-bold">@gnToplamYorum</h4>
                                    <span class="d-block text-dark fw-medium small letter-spacing-1 text-uppercase">Değerlendirme</span>
                                    <small class="text-muted">Toplam Onaylı</small>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="card border-0 bg-light rounded-4 shadow-sm p-4 mb-5">
                    <div class="row g-4">
                        
                        <div class="col-lg-3 col-md-6 border-end-md border-secondary border-opacity-10">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center me-2 shadow-sm" style="width: 32px; height: 32px;"><i class="fa-solid fa-plus small"></i></div>
                                <span class="fw-bold text-success letter-spacing-1 text-uppercase small">Sevilenler</span>
                            </div>
                            <ul class="list-unstyled mb-0 ps-1">
                                @if (Top5Artilar.Any()) {
                                    foreach (var item in Top5Artilar) { <li class="mb-2 d-flex align-items-start"><i class="fa-solid fa-check text-success mt-1 me-2 small"></i><span class="text-dark fw-medium small">@item</span></li> }
                                } else { <li class="text-muted small fst-italic"><i class="fa-solid fa-info-circle me-1 opacity-50"></i> Veri bulunamadı.</li> }
                            </ul>
                        </div>

                        <div class="col-lg-3 col-md-6 border-end-lg border-secondary border-opacity-10">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex justify-content-center align-items-center me-2 shadow-sm" style="width: 32px; height: 32px;"><i class="fa-solid fa-minus small"></i></div>
                                <span class="fw-bold text-danger letter-spacing-1 text-uppercase small">Eksiklikler</span>
                            </div>
                            <ul class="list-unstyled mb-0 ps-1">
                                @if (Top5Eksiler.Any()) {
                                    foreach (var item in Top5Eksiler) { <li class="mb-2 d-flex align-items-start"><i class="fa-solid fa-xmark text-danger mt-1 me-2 small"></i><span class="text-dark fw-medium small">@item</span></li> }
                                } else { <li class="text-muted small fst-italic"><i class="fa-solid fa-info-circle me-1 opacity-50"></i> Veri bulunamadı.</li> }
                            </ul>
                        </div>

                        <div class="col-lg-3 col-md-6 border-end-md border-secondary border-opacity-10">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-warning bg-opacity-10 text-gold rounded-circle d-flex justify-content-center align-items-center me-2 shadow-sm" style="width: 32px; height: 32px;"><i class="fa-solid fa-lightbulb small"></i></div>
                                <span class="fw-bold text-gold letter-spacing-1 text-uppercase small">Öneriler</span>
                            </div>
                            <ul class="list-unstyled mb-0 ps-1">
                                @if (Top5Oneriler.Any()) {
                                    foreach (var item in Top5Oneriler) { <li class="mb-2 d-flex align-items-start"><i class="fa-solid fa-arrow-right text-gold mt-1 me-2 opacity-75 small"></i><span class="text-dark fw-medium small">@item</span></li> }
                                } else { <li class="text-muted small fst-italic"><i class="fa-solid fa-info-circle me-1 opacity-50"></i> Veri bulunamadı.</li> }
                            </ul>
                        </div>

                        <div class="col-lg-3 col-md-6">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-dark bg-opacity-10 text-dark rounded-circle d-flex justify-content-center align-items-center me-2 shadow-sm" style="width: 32px; height: 32px;"><i class="fa-solid fa-bullhorn small"></i></div>
                                <span class="fw-bold text-dark letter-spacing-1 text-uppercase small">Şikayetler</span>
                            </div>
                            <ul class="list-unstyled mb-0 ps-1">
                                @if (Top5Sikayetler.Any()) {
                                    foreach (var item in Top5Sikayetler) { <li class="mb-2 d-flex align-items-start"><i class="fa-solid fa-circle-exclamation text-dark mt-1 me-2 opacity-75 small"></i><span class="text-dark fw-medium small">@item</span></li> }
                                } else { <li class="text-muted small fst-italic"><i class="fa-solid fa-info-circle me-1 opacity-50"></i> Veri bulunamadı.</li> }
                            </ul>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    }
    <!-- Orijinal Yorumlar Kısmın Buradan Başlıyor -->
    <div class="row mt-5 pt-5 border-top">
        <div class="col-lg-8 mx-auto">
            <h3 class="font-playfair fw-bold mb-4 text-center">Müşteri Yorumları</h3>

            <div class="card border-0 bg-light p-4 mb-5 rounded-0">
                <h5 class="fw-bold mb-3 fs-6">Bu ürünü değerlendirin</h5>

                @if (User.Identity!.IsAuthenticated)
                {
                    <form asp-action="YorumEkle" asp-controller="Urunler" method="post">
                        <input type="hidden" name="UrunID" value="@Model.ID" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Puanınız</label>
                            <select name="Puan" class="form-select rounded-0 border-secondary bg-transparent mb-3" required>
                                <option value="5">⭐⭐⭐⭐⭐ (5) Mükemmel</option>
                                <option value="4">⭐⭐⭐⭐ (4) Çok İyi</option>
                                <option value="3">⭐⭐⭐ (3) Ortalama</option>
                                <option value="2">⭐⭐ (2) Kötü</option>
                                <option value="1">⭐ (1) Çok Kötü</option>
                            </select>

                            <label class="form-label small fw-bold text-muted">Yorumunuz</label>
                            <textarea name="YorumIcerik" class="form-control rounded-0 border-secondary bg-transparent" rows="3" placeholder="Ürün hakkında ne düşünüyorsunuz?" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-dark rounded-0 px-4 hover-gold-bg transition-300 border-0">Yorum Yap</button>
                    </form>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fa-solid fa-lock text-muted fs-2 mb-3 opacity-50"></i>
                        <p class="text-muted small mb-3">Değerlendirme yapabilmek için lütfen giriş yapın.</p>
                        <a href="/Hesap/SignIn" class="btn btn-outline-dark rounded-0 px-4 py-2 text-uppercase fw-bold letter-spacing-1 transition-300">Giriş Yap</a>
                    </div>
                }
            </div>

            <div class="comments-list">
                @if (Model.Yorumlar != null && Model.Yorumlar.Any())
                {
                    foreach (var yorum in Model.Yorumlar.OrderByDescending(y => y.ID))
                    {
                        var adBasHarf = !string.IsNullOrEmpty(yorum.Profil?.Ad) ? yorum.Profil.Ad.Substring(0, 1).ToUpper() : "M";
                        var soyadBasHarf = !string.IsNullOrEmpty(yorum.Profil?.Soyad) ? yorum.Profil.Soyad.Substring(0, 1).ToUpper() : "Ü";

                        var mevcutKullaniciId = User.Identity!.IsAuthenticated ? User.FindFirstValue(ClaimTypes.NameIdentifier) : null;
                        bool benimYorumumMu = mevcutKullaniciId != null && yorum.Profil?.KullaniciID.ToString() == mevcutKullaniciId;

                        <div class="comment-item mb-4 pb-4 border-bottom">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <strong>@adBasHarf@soyadBasHarf</strong>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold">@(yorum.Profil?.Ad ?? "Gizli") @(soyadBasHarf)***</h6>
                                        <small class="text-muted">@yorum.Tarih.ToString("dd MMMM yyyy")</small>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-gold small">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= yorum.Puan)
                                            {
                                                <i class="fa-solid fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-regular fa-star text-muted opacity-50"></i>
                                            }
                                        }
                                    </div>

                                    @if (benimYorumumMu)
                                    {
                                        <form asp-action="YorumSil" asp-controller="Urunler" method="post" class="m-0 p-0" onsubmit="return confirm('Bu değerlendirmenizi silmek istediğinize emin misiniz?');">
                                            <input type="hidden" name="YorumID" value="@yorum.ID" />
                                            <input type="hidden" name="UrunID" value="@Model.ID" />
                                            <button type="submit" class="btn btn-sm text-danger p-0 border-0 bg-transparent" title="Yorumu Sil">
                                                <i class="fa-regular fa-trash-can fs-6 hover-opacity-100 opacity-75 transition-300"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                            <p class="text-muted mb-0 mt-2">@yorum.YorumIcerik</p>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <p class="text-muted fst-italic mb-0">Bu ürün için henüz bir değerlendirme yapılmamış. İlk yorumu siz yapın!</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .text-gold { color: #D4AF37 !important; }
        .hover-gold:hover { color: #D4AF37 !important; transition: 0.3s; }
        .hover-gold-bg:hover { background-color: #D4AF37 !important; color: #fff !important; transition: 0.3s; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: 0.3s ease; }
        .hover-opacity-100:hover { opacity: 1 !important; transform: scale(1.1); }
        .cursor-pointer { cursor: pointer; }
        .thumb-wrapper { width: 70px; height: 90px; cursor: pointer; opacity: 0.5; transition: 0.3s; border: 2px solid transparent; border-radius: 4px; overflow: hidden; }
        .thumb-wrapper img { width: 100%; height: 100%; object-fit: cover; }
        .thumb-wrapper:hover { opacity: 1; }
        .thumb-wrapper.active { opacity: 1; border-color: #0B132B; }
        .btn-outline-dark:hover { background-color: #0B132B; color: #fff; }
        .btn-check:checked + .btn-outline-dark { background-color: #0B132B; color: #D4AF37; border-color: #0B132B; }
        .fade-in-image { animation: fadeIn 0.4s ease-in-out; }
        @@keyframes fadeIn {
            from { opacity: 0.8; transform: scale(0.99); }
            to { opacity: 1; transform: scale(1); }
        }
    </style>

    <script>
        function changeProductImage(src, element) {
            const mainImg = document.getElementById('mainProductImage');
            mainImg.src = src;
            mainImg.classList.remove('fade-in-image');
            void mainImg.offsetWidth;
            mainImg.classList.add('fade-in-image');
            document.querySelectorAll('.thumb-wrapper').forEach(item => item.classList.remove('active'));
            element.classList.add('active');
        }
        
        document.addEventListener('DOMContentLoaded', function () {
            const bedenRadios = document.querySelectorAll('.beden-radio');
            const miktarInput = document.getElementById('miktarInput');
            const stokUyari = document.getElementById('stokUyari');

            let aktifMaxStok = 1;

            const seciliBeden = document.querySelector('.beden-radio:checked');
            if (seciliBeden) {
                aktifMaxStok = parseInt(seciliBeden.getAttribute('data-stok'));
                miktarInput.disabled = false;
                miktarInput.max = aktifMaxStok;
            }

            miktarInput.addEventListener('input', function() {
                let girilenDeger = parseInt(this.value) || 1;
                if (girilenDeger > aktifMaxStok) {
                    this.value = aktifMaxStok;
                    stokUyari.style.display = 'inline';
                    setTimeout(() => stokUyari.style.display = 'none', 3000);
                }
            });

            bedenRadios.forEach(radio => {
                radio.addEventListener('change', function () {
                    aktifMaxStok = parseInt(this.getAttribute('data-stok'));
                    miktarInput.disabled = false;
                    miktarInput.max = aktifMaxStok;

                    if (parseInt(miktarInput.value) > aktifMaxStok) {
                        miktarInput.value = aktifMaxStok;
                    }
                });
            });
        });
    </script>

}