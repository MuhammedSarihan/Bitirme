@model List<Tasarim.Core.Entities.Urun>

@{
    ViewData["Title"] = "Favorilerim";
}

<div class="container py-5 my-4">

    <div class="text-center mb-5">
        <h2 class="font-playfair fw-bold text-dark display-6">Favori Koleksiyonum</h2>
        <div style="width: 50px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="my-3"></div>
        <p class="text-muted small">Beğendiğiniz ürünler sizin için burada özenle saklanıyor.</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="row justify-content-center text-center mt-5 pt-4">
            <div class="col-md-6">
                <div class="mb-4 text-muted opacity-50">
                    <i class="fa-regular fa-heart" style="font-size: 5rem;"></i>
                </div>
                <h4 class="font-playfair fw-bold mb-3">Favori Listeniz Henüz Boş</h4>
                <p class="text-muted mb-4">Luvia Lukka'nın eşsiz koleksiyonlarını inceleyip, beğendiğiniz tasarımları favorilerinize ekleyebilirsiniz.</p>
                <a href="/Home/Index" class="btn btn-dark btn-lg rounded-0 px-5 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0">
                    Koleksiyonu Keşfet
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var urun in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 rounded-0 product-card position-relative">

                        <form asp-action="Remove" asp-controller="Favoriler" method="post" class="position-absolute top-0 end-0 p-2" style="z-index: 10;">
                            <input type="hidden" name="UrunID" value="@urun.ID" />
                            <button type="submit" class="btn btn-light bg-white rounded-circle shadow-sm border-0 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Favorilerden Kaldır">
                                <i class="fa-solid fa-xmark text-dark"></i>
                            </button>
                        </form>

                        <a href="/Urunler/Details/@urun.ID" class="overflow-hidden d-block bg-light">
                            @if (!string.IsNullOrEmpty(urun.AnaResim))
                            {
                                <img src="/img/@urun.AnaResim" class="card-img-top rounded-0 product-img transition-300" alt="@urun.Baslik" style="height: 450px; object-fit: cover; object-position: top;">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center text-muted" style="height: 450px;">Görsel Yok</div>
                            }
                        </a>

                        <div class="card-body px-0 text-center pb-0">
                            <p class="text-muted small mb-1 text-uppercase letter-spacing-1">@(urun.Marka?.MarkaAd ?? "Luvia Lukka")</p>
                            <h5 class="card-title font-playfair fw-bold mb-2">
                                <a href="/Urunler/Details/@urun.ID" class="text-dark text-decoration-none hover-gold">@urun.Baslik</a>
                            </h5>
                            @if (urun.Fiyat > urun.KampanyaliFiyat)
                            {
                                <span class="text-muted text-decoration-line-through me-2 fs-5 opacity-75">@urun.Fiyat.ToString("C2")</span>
                                <span class="text-danger fs-3">@urun.KampanyaliFiyat.ToString("C2")</span>
                            }
                            else
                            {
                                <span class="text-gold fs-3">@urun.Fiyat.ToString("C2")</span>
                            }
                        </div>

                        <div class="card-footer bg-transparent border-0 px-0 pt-0">
                            <a href="/Urunler/Details/@urun.ID" class="btn btn-outline-dark w-100 rounded-0 py-2 text-uppercase fw-semibold letter-spacing-1">
                                Ürünü İncele
                            </a>
                        </div>
                    </div>
                </div>
            }

        </div>
    }
</div>

@section Scripts {
    <style>
        .text-gold {
            color: #D4AF37 !important;
        }

        .hover-gold:hover {
            color: #D4AF37 !important;
            transition: 0.3s;
        }

        .hover-gold-bg:hover {
            background-color: #D4AF37 !important;
            color: #fff !important;
            transition: 0.3s;
        }

        .font-playfair {
            font-family: 'Playfair Display', serif;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        .transition-300 {
            transition: 0.3s ease;
        }

        /* Kart Üzerine Gelince Resim Yakınlaşsın */
        .product-card:hover .product-img {
            transform: scale(1.05);
        }

        /* Kaldır Butonu Efekti */
        .btn-light:hover .fa-xmark {
            color: #dc3545 !important; /* Kırmızıya döner */
            transform: scale(1.2);
            transition: 0.2s;
        }
    </style>
}