@model List<Tasarim.Core.Entities.Urun>

@{
    ViewData["Title"] = "Favorilerim";
}

<div class="container py-5 my-4">

    <div class="text-center mb-5">
        <h2 class="font-playfair fw-bold text-dark display-6">Favori Koleksiyonum</h2>
        <div style="width: 50px; height: 2px; background-color: #D4AF37; margin: 0 auto;" class="my-3"></div>
        <p class="text-muted small">Beğendiğiniz ürünler sizin için burada özenle saklanıyor.</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="row justify-content-center text-center mt-5 pt-4">
            <div class="col-md-6">
                <div class="mb-4 text-muted opacity-50">
                    <i class="fa-regular fa-heart" style="font-size: 5rem;"></i>
                </div>
                <h4 class="font-playfair fw-bold mb-3">Favori Listeniz Henüz Boş</h4>
                <p class="text-muted mb-4">Luvia Lukka'nın eşsiz koleksiyonlarını inceleyip, beğendiğiniz tasarımları favorilerinize ekleyebilirsiniz.</p>
                <a href="/Home/Index" class="btn btn-dark btn-lg rounded-0 px-5 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0">
                    Koleksiyonu Keşfet
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
    @foreach (var urun in Model)
    {
        <partial name="_UrunView" model="urun" view-data='new ViewDataDictionary(ViewData) { { "IsFavoriSayfasi", true } }' />
    }
</div>
    }
</div>

@section Scripts {
    <style>
        .text-gold { color: #D4AF37 !important; }
        .hover-gold:hover { color: #D4AF37 !important; transition: 0.3s; }
        .hover-gold-bg:hover { background-color: #D4AF37 !important; color: #fff !important; border-color: #D4AF37 !important; transition: 0.3s; }
        .font-playfair { font-family: 'Playfair Display', serif; }
        .letter-spacing-1 { letter-spacing: 1px; }
        .transition-300 { transition: 0.3s ease; }

        .product-card:hover .product-img { transform: scale(1.05); }

        /* Kaldır Butonu Efekti */
        .btn-light:hover .fa-xmark {
            color: #dc3545 !important;
            transform: scale(1.2);
            transition: 0.2s;
        }
    </style>
}