<header class="sticky-top bg-white shadow-sm transition-300">

    <div class="border-bottom py-3">
        <div class="container d-flex align-items-center justify-content-between gap-3">

            <button class="navbar-toggler border-0 shadow-none d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#altKatmanKategoriler" aria-controls="altKatmanKategoriler" aria-expanded="false" aria-label="Menüyü Aç">
                <i class="fa-solid fa-bars fs-3"></i>
            </button>

            <a class="navbar-brand font-playfair fw-bold fs-3 text-dark letter-spacing-1 mb-0" asp-controller="Home" asp-action="Index">
                LUVIA LUKKA
            </a>

            <form action="/Urunler/Index" class="flex-grow-1 mx-lg-5 d-none d-lg-block" role="search" style="max-width: 600px;">
                <div class="input-group">
                    <input name="q" type="search" class="form-control rounded-start-pill border-secondary py-2 px-4 bg-light" placeholder="Ürün, kategori veya marka ara..." aria-label="Search">
                    <button type="submit" class="btn btn-dark rounded-end-pill px-4 hover-gold-bg border-0 transition-300">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center gap-3 gap-xl-4">

                <a href="/Home/KargoTakip" class="text-dark text-decoration-none d-flex flex-column align-items-center flex-xl-row gap-xl-2 hover-gold transition-300">
                    <i class="fa-solid fa-truck-fast fs-5 mb-1 mb-xl-0"></i>
                    <span class="fw-semibold small d-none d-md-inline">Kargom Nerede</span>
                </a>

                <a href="/Favoriler" class="text-dark text-decoration-none d-flex flex-column align-items-center flex-xl-row gap-xl-2 hover-gold transition-300">
                    <div class="position-relative">
                        <i class="fa-regular fa-heart fs-5 mb-1 mb-xl-0"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle d-xl-none"></span>
                    </div>
                    <span class="fw-semibold small d-none d-md-inline">Favorilerim</span>
                </a>

                @await Component.InvokeAsync("SepetOzet")

                <div class="dropdown">
                    <a class="text-dark text-decoration-none d-flex flex-column align-items-center flex-xl-row gap-xl-2 hover-gold transition-300 cursor-pointer" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        @if (Context.User.Identity!.IsAuthenticated)
                        {
                            <i class="fa-solid fa-user-check text-success fs-5 mb-1 mb-xl-0"></i>
                            <span class="fw-semibold small d-none d-md-inline">Hesabım</span>
                        }
                        else
                        {
                            <i class="fa-regular fa-user fs-5 mb-1 mb-xl-0"></i>
                            <span class="fw-semibold small d-none d-md-inline">Üye Girişi</span>
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-0 mt-3">
                        @if (Context.User.Identity.IsAuthenticated)
                        {
                            <li><a class="dropdown-item py-2 small" href="/Hesap">Profilim</a></li>
                            <li><a class="dropdown-item py-2 small text-danger" href="/Hesap/SignOut">Çıkış Yap</a></li>
                        }
                        else
                        {
                            <li><a class="dropdown-item py-2 small" href="/Hesap/SignIn">Giriş Yap</a></li>
                            <li><a class="dropdown-item py-2 small" href="/Hesap/SignUp">Kayıt Ol</a></li>
                        }
                    </ul>
                </div>

            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg bg-white py-0">
        <div class="container">
            <div class="collapse navbar-collapse justify-content-center" id="altKatmanKategoriler">
                @await Component.InvokeAsync("Kategoriler")
            </div>
        </div>
    </nav>
</header>