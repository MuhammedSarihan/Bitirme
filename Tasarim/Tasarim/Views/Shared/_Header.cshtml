<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Luvia Lukka      </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-evenly">

                <form action="/Urunler" class="col-12 col-lg-auto mb-3 mb-lg-0 me-lg-3" role="search">
                    <input name="q" type="search" class="form-control" placeholder="Ara..." aria-label="Search">
                </form>

                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Anasayfa</a>
                    </li>
                    @* <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li> *@
                    @await Component.InvokeAsync("Kategoriler")
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="ContactUs">İletişim</a>
                    </li>
                </ul>
                @if (Context.User.Identity.IsAuthenticated)
                {
                    <div class="text-end me-4">
                        <div class="dropdown me-4">
                            <a class="dropdown-toggle nav-link text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Hesabım
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Hesap">Profilim</a></li>
                                <li><a class="dropdown-item" href="/Item">Ürünlerim</a></li>
                                <li><a class="dropdown-item" href="/Hesap/SignOut">Çıkış Yap</a></li>
                            </ul>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-end me-4">
                        <div class="dropdown me-4">
                            <a class="dropdown-toggle nav-link text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Giriş Yap
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Hesap/SignIn">Giriş</a></li>
                                <li><a class="dropdown-item" href="/Hesap/SignUp">Kayıt Ol</a></li>
                            </ul>
                        </div>
                    </div>
                }
            </div>

        </div>
    </nav>
</header>