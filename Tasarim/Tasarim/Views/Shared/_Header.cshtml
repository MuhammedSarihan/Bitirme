<header class="sticky-top">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-3 transition-300">
        <div class="container">
            <a class="navbar-brand font-playfair fw-bold fs-3 text-dark letter-spacing-1" asp-area="" asp-controller="Home" asp-action="Index">
                LUVIA LUKKA
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between align-items-center mt-3 mt-lg-0">

                <ul class="navbar-nav mx-auto gap-1 gap-lg-4 text-uppercase small fw-bold letter-spacing-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark hover-gold transition-300" asp-controller="Home" asp-action="Index">Anasayfa</a>
                    </li>

                    @await Component.InvokeAsync("Kategoriler")

                    <li class="nav-item">
                        <a class="nav-link text-dark hover-gold transition-300" asp-controller="Home" asp-action="ContactUs">İletişim</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center justify-content-center justify-content-lg-end gap-3 gap-lg-4 mt-3 mt-lg-0">

                    <form action="/Urunler/Index" class="position-relative d-none d-md-block" role="search">
                        <input name="q" type="search" class="form-control rounded-pill pe-5 shadow-sm border-light bg-light font-sm" placeholder="Ürün ara..." aria-label="Search" style="width: 220px;">
                        <button type="submit" class="btn border-0 position-absolute top-50 end-0 translate-middle-y text-muted hover-gold transition-300">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </form>

                    <a href="/Favoriler" class="text-dark fs-5 hover-gold transition-300 position-relative" title="Favorilerim">
                        <i class="fa-regular fa-heart"></i>
                    </a>

                    <div class="dropdown">
                        <a class="text-dark fs-5 hover-gold transition-300" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Hesabım">
                            @if (Context.User.Identity!.IsAuthenticated)
                            {
                                <i class="fa-solid fa-user-check text-success" title="Giriş Yapıldı"></i>
                            }
                            else
                            {
                                <i class="fa-regular fa-user"></i>
                            }
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3 mt-3" style="min-width: 200px;">
                            @if (Context.User.Identity.IsAuthenticated)
                            {
                                <li><h6 class="dropdown-header font-playfair fs-6 fw-bold">Hoş Geldiniz</h6></li>
                                <li><a class="dropdown-item py-2 small hover-gold transition-300" href="/Hesap"><i class="fa-regular fa-id-badge me-2 text-muted"></i>Profilim</a></li>
                                <li><a class="dropdown-item py-2 small hover-gold transition-300" href="/#"><i class="fa-solid fa-box-open me-2 text-muted"></i>Siparişlerim</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 small text-danger hover-gold-bg transition-300" href="/Hesap/SignOut"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i>Çıkış Yap</a></li>
                            }
                            else
                            {
                                <li><h6 class="dropdown-header font-playfair fs-6 fw-bold">Üye İşlemleri</h6></li>
                                <li><a class="dropdown-item py-2 small hover-gold transition-300" href="/Hesap/SignIn"><i class="fa-solid fa-right-to-bracket me-2 text-muted"></i>Giriş Yap</a></li>
                                <li><a class="dropdown-item py-2 small hover-gold transition-300" href="/Hesap/SignUp"><i class="fa-solid fa-user-plus me-2 text-muted"></i>Kayıt Ol</a></li>
                            }
                        </ul>
                    </div>

                    @await Component.InvokeAsync("SepetOzet")

                </div>
            </div>

        </div>
    </nav>
</header>