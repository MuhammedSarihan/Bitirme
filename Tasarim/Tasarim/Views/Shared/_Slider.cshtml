@model IEnumerable<Tasarim.Core.Entities.Slider>
@{
    int i = 0;
    int j = 0;
}

<style>
    /* 1. Görsel Boyutları */
    .custom-slider-img {
        width: 100%;
        height: 400px; /* Mobilde biraz daha ferah bir alan */
        object-fit: cover;
        object-position: top center;
    }

    @@media (min-width: 768px) {
        .custom-slider-img {
            height: 650px; /* Masaüstünde tam bir vitrin havası */
        }
    }

    /* 2. Yazı Alanı (Görselin Tam Altında, Beyaz Zemin) */
    .slider-bottom-content {
        background-color: #ffffff;
        padding: 2rem 1rem 3.5rem 1rem;
        text-align: center;
    }

    /* 3. Tipografi */
    .slider-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem;
        font-weight: 700;
        color: #000;
        margin-bottom: 0.75rem;
        letter-spacing: 1px;
    }

    .slider-desc {
        font-size: 0.95rem;
        color: #6c757d;
        max-width: 600px;
        margin: 0 auto 1.5rem auto;
        line-height: 1.6;
    }

    @@media (min-width: 768px) {
        .slider-bottom-content {
            padding: 3rem 1rem 4.5rem 1rem;
        }

        .slider-title {
            font-size: 2.5rem;
        }

        .slider-desc {
            font-size: 1.1rem;
        }
    }

    /* 4. Oklar ve Noktalar */
    /* Okların sadece görselin ortasında kalmasını sağlıyoruz, yazı kısmına inmesinler */
    #anaSayfaSlider .carousel-control-prev,
    #anaSayfaSlider .carousel-control-next {
        height: 400px; /* Mobildeki resim yüksekliği kadar */
    }
    
    @@media (min-width: 768px) {
        #anaSayfaSlider .carousel-control-prev,
        #anaSayfaSlider .carousel-control-next {
            height: 650px; /* Masaüstündeki resim yüksekliği kadar */
        }
    }

    /* Açık renkli görsellerde de okların görünmesi için zarif bir siyah gölge */
    .carousel-control-prev-icon, .carousel-control-next-icon {
        filter: drop-shadow(0px 0px 5px rgba(0,0,0,0.8));
        width: 2.5rem;
        height: 2.5rem;
    }

    /* Noktaları (Indicators) en alta Luvia Gold çizgileri olarak alıyoruz */
    #anaSayfaSlider .carousel-indicators {
        bottom: 0;
        margin-bottom: 15px;
    }

        #anaSayfaSlider .carousel-indicators [data-bs-target] {
            background-color: #D4AF37;
            width: 35px;
            height: 3px;
            border-radius: 0;
            opacity: 0.4;
            transition: opacity 0.3s;
        }

        #anaSayfaSlider .carousel-indicators .active {
            opacity: 1;
        }
</style>

<div id="anaSayfaSlider" class="carousel slide carousel-fade mb-5 shadow-sm bg-white" data-bs-ride="carousel">

    <div class="carousel-indicators">
        @foreach (var item in Model)
        {
            <button type="button" data-bs-target="#anaSayfaSlider" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
            i++;
        }
    </div>

    <div class="carousel-inner">
        @foreach (var item in Model)
        {
            <div class="carousel-item @(j == 0 ? "active" : "")" data-bs-interval="5000">
                
                <img src="/img/@item.SliderResim" class="custom-slider-img" alt="@item.Baslik">

                <div class="slider-bottom-content">
                    @if (!string.IsNullOrEmpty(item.Baslik))
                    {
                        <h2 class="slider-title">@item.Baslik</h2>
                    }
                    
                    @if (!string.IsNullOrEmpty(item.SliderAciklama))
                    {
                        <p class="slider-desc">@item.SliderAciklama</p>
                    }

                    @if (!string.IsNullOrEmpty(item.Link))
                    {
                        <a href="@item.Link" class="btn btn-outline-dark px-5 py-2 mt-2 rounded-0 text-uppercase fw-bold letter-spacing-1 transition-300 hover-gold-bg">
                            İncele
                        </a>
                    }
                </div>
                
            </div>
            j++;
        }
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#anaSayfaSlider" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Önceki</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#anaSayfaSlider" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Sonraki</span>
    </button>
</div>