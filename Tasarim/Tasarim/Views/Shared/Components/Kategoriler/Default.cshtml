@model IEnumerable<Kategori>

@{
    foreach(var anaKategori in Model.Where(c=> c.UstKategoriID==null && c.AktifMi && c.UstteGoster))
    {
        <div class="dropdown">
            <a class="btn dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                @anaKategori.KategoriAd
            </a>

            <ul class="dropdown-menu">
                @foreach (var altKategori in Model.Where(c => c.UstKategoriID == anaKategori.ID))
                {
                    <li><a class="dropdown-item" href="/Kategoriler/Index/@altKategori.ID">@altKategori.KategoriAd</a></li>
                }    
            </ul>
        </div>
    }

}
