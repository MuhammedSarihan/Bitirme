@model int

<a href="/Sepet/Index" class="text-dark text-decoration-none d-flex align-items-center gap-2 hover-gold transition-300">
    <i class="fa-solid fa-cart-shopping fs-5"></i>
    <span class="fw-semibold small d-none d-md-inline">Sepetim</span>

    @if (Model > 0)
    {
        <span class="badge bg-danger text-white border border-danger ms-1">@Model</span>
    }
    else
    {
        <span class="badge bg-light text-dark border ms-1">0</span>
    }
</a>