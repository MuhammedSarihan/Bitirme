@model int

<a href="/Sepet/Index" class="btn btn-outline-dark position-relative border-0 rounded-circle p-2 ms-3 transition-300 hover-opacity-100" title="Sepetim">
    <i class="fa-solid fa-bag-shopping fs-5"></i>

    @if (Model > 0)
    {
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light shadow-sm" style="font-size: 0.75rem;">
            @Model
            <span class="visually-hidden">Sepetteki Ürünler</span>
        </span>
    }
</a>