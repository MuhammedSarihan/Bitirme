@using Tasarim.Core.Entities
@model Urun

@{
    // Sadece analizden geçmiş ve yasaklı olmayan temiz yorumları alıyoruz
    var yorumlar = Model.Yorumlar?.ToList();
    
    double ortalamaPuan = 0;
    int yorumSayisi = yorumlar?.Count ?? 0;

    if (yorumSayisi > 0)
    {
        // Yorumların Puan sütunundaki değerlerin aritmetik ortalamasını al
        ortalamaPuan = yorumlar.Average(y => (double)y.Puan);
    }

    // Yıldızları ekranda boyamak için ortalamayı en yakın tam sayıya yuvarlıyoruz (Örn: 4.3 -> 4 yıldız, 4.6 -> 5 yıldız)
    int yildizSayisi = (int)Math.Round(ortalamaPuan);
}

<div class="col mb-5 ">
    <div class="card h-100 border-0 rounded-0 product-card bg-transparent">

        <a href="/Urunler/Details/@Model.ID" class="overflow-hidden d-block bg-light position-relative">
            <img class="card-img-top rounded-0 product-img transition-300"
                 src="~/img/@Model.AnaResim"
                 alt="@Model.Baslik"
                 style="height: 450px; object-fit: cover; object-position: top; width: 100%;">
        </a>

        <div class="card-body px-0 text-center pb-0 mt-3">

            <p class="text-muted small mb-1 text-uppercase letter-spacing-1">@Model.ModelKodu</p>

            <h5 class="card-title font-playfair fw-bold mb-2 text-truncate px-2">
                <a href="/Urunler/Details/@Model.ID" class="text-dark text-decoration-none hover-gold">@Model.Baslik</a>
            </h5>

            <div class="mb-3">
                @if (Model.Fiyat > Model.KampanyaliFiyat)
                {
                    <span class="text-muted text-decoration-line-through me-2 fs-6 opacity-75">@Model.Fiyat.ToString("C2")</span>
                    <span class="text-gold fw-bold fs-5">@Model.KampanyaliFiyat.ToString("C2")</span>
                }
                else
                {
                    <span class="text-gold fw-bold fs-5">@Model.Fiyat.ToString("C2")</span>
                }
            </div>
        </div>

        <div class="card-footer bg-transparent border-0 px-0 pt-0 mt-auto">
            <div class="mb-3 d-flex justify-content-center align-items-center text-gold" style="font-size: 0.9rem;">
                @if (yorumSayisi > 0)
                {
                    // 5 üzerinden döngü kurup, ortalamaya kadar olanları dolu yıldız, kalanları boş yıldız yapıyoruz
                    for (int i = 1; i <= 5; i++)
                    {
                        if (i <= yildizSayisi)
                        {
                            <i class="fa-solid fa-star"></i>
                        }
                        else
                        {
                            <i class="fa-regular fa-star opacity-50"></i>
                        }
                    }
                    <span class="text-muted ms-2 small letter-spacing-1">(@yorumSayisi)</span>
                }
                else
                {
                    // Ürüne ait hiç yorum yoksa soluk renkte 5 tane boş yıldız gösterilir
                    for (int i = 1; i <= 5; i++)
                    {
                        <i class="fa-regular fa-star opacity-25"></i>
                    }
                    <span class="text-muted ms-2 small letter-spacing-1">(@yorumSayisi)</span>
                }
            </div>
            <a class="btn btn-outline-dark w-100 rounded-0 py-2 text-uppercase fw-semibold letter-spacing-1 transition-300" href="/Urunler/Details/@Model.ID">
                Detaylı İncele
            </a>
        </div>

    </div>
</div>