@model Tasarim.Core.Entities.Sepet

@{
    ViewData["Title"] = "Sepetim";

    // Toplam tutar
    decimal toplamTutar = Model?.SepetItems?.Sum(si => si.Adet * si.UrunVaryasyon.Urun.KampanyaliFiyat) ?? 0;
}

<div class="container my-5 pt-4">
    <div class="text-center mb-5">
        <h1 class="display-6 font-playfair fw-bold mb-2">Alışveriş Sepetim</h1>
        <div class="mx-auto bg-dark" style="height: 2px; width: 60px;"></div>
    </div>

    @if (Model == null || Model.SepetItems == null || !Model.SepetItems.Any())
    {
        <div class="row justify-content-center text-center my-5 py-5">
            <div class="col-md-6">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 120px; height: 120px;">
                    <i class="fa-solid fa-bag-shopping text-muted opacity-50" style="font-size: 3rem;"></i>
                </div>
                <h3 class="font-playfair fw-bold mb-3">Sepetiniz şu an boş.</h3>
                <p class="text-muted mb-4">LUVIA LUKKA'nın eşsiz koleksiyonunu keşfetmek ve sepetinize harika parçalar eklemek için alışverişe başlayın.</p>
                <a href="/" class="btn btn-dark btn-lg rounded-0 px-5 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg transition-300">
                    Koleksiyonu Keşfet
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-5">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-0 mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-list me-2 text-gold"></i>Ürünler (@Model.SepetItems.Sum(x => x.Adet) Adet)</h5>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.SepetItems.OrderByDescending(x => x.ID))
                            {
                                var urun = item.UrunVaryasyon.Urun;
                                var resim = !string.IsNullOrEmpty(urun.AnaResim) ? $"/img/{urun.AnaResim}" : "/img/default.jpg";

                                bool kampanyaliMi = urun.KampanyaliFiyat > 0 && urun.KampanyaliFiyat < urun.Fiyat;
                                decimal gecerliFiyat = kampanyaliMi ? urun.KampanyaliFiyat : urun.Fiyat;

                                <li class="list-group-item p-4 position-relative">
                                    <div class="row align-items-center g-3">
                                        <div class="col-3 col-md-2">
                                            <a href="/Urunler/Details/@urun.ID">
                                                <img src="@resim" class="img-fluid rounded shadow-sm" alt="@urun.Baslik" style="object-fit: cover; aspect-ratio: 3/4;">
                                            </a>
                                        </div>

                                        <div class="col-9 col-md-5">
                                            <a href="/Urunler/Details/@urun.ID" class="text-decoration-none text-dark hover-gold transition-300">
                                                <h6 class="fw-bold mb-1 font-playfair fs-5">@urun.Baslik</h6>
                                            </a>
                                            <div class="text-muted small mb-2 d-flex flex-column gap-1">
                                                <span>Renk: <strong>@(urun.Renk ?? "-")</strong></span>
                                                <span>Beden: <strong class="badge bg-light text-dark border px-2">@item.UrunVaryasyon.Beden</strong></span>
                                            </div>
                                        </div>

                                        <div class="col-6 col-md-3 text-md-center mt-3 mt-md-0">
                                            <span class="text-muted small d-block mb-1">Birim Fiyat</span>

                                            @if (kampanyaliMi)
                                            {
                                                <span class="text-muted text-decoration-line-through small d-block">@urun.Fiyat.ToString("C2")</span>
                                                <span class="fw-bold text-danger">@gecerliFiyat.ToString("C2")</span>
                                            }
                                            else
                                            {
                                                <span class="fw-bold text-dark">@gecerliFiyat.ToString("C2")</span>
                                            }

                                            <div class="mt-3 d-flex justify-content-md-center align-items-center">
                                                <form asp-controller="Sepet" asp-action="Guncelle" method="post" class="d-flex align-items-center m-0">
                                                    <input type="hidden" name="UrunVaryasyonID" value="@item.UrunVaryasyonID" />

                                                    <button type="button" class="btn btn-sm btn-outline-secondary rounded-0" onclick="miktarGuncelle(this, -1)" @(item.Adet <= 1 ? "disabled" : "")>
                                                        <i class="fa-solid fa-minus"></i>
                                                    </button>

                                                    <input type="number" name="miktar" value="@item.Adet" class="form-control form-control-sm text-center border-secondary rounded-0 mx-1 bg-white" style="width: 50px;" readonly data-stok="@item.UrunVaryasyon.StokAdedi" />

                                                    <button type="button" class="btn btn-sm btn-outline-secondary rounded-0" onclick="miktarGuncelle(this, 1)">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>

                                        <div class="col-6 col-md-2 text-end mt-3 mt-md-0">
                                            <span class="text-gold fw-bold d-block mb-2 fs-5">@((gecerliFiyat * item.Adet).ToString("C2"))</span>

                                            <form asp-controller="Sepet" asp-action="Sil" method="post" onsubmit="return urunSilOnay(event, this);">
                                                <input type="hidden" name="UrunVaryasyonID" value="@item.UrunVaryasyonID" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger border-0 transition-300" title="Ürünü Sil">
                                                    <i class="fa-solid fa-trash-can me-1"></i>Kaldır
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border border-light shadow-sm rounded-0 sticky-top" style="top: 120px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-dark mb-4 border-bottom pb-3 font-playfair">Sipariş Özeti</h5>

                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>Ara Toplam</span>
                            <span class="fw-semibold text-dark">@toplamTutar.ToString("C2")</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3 text-muted pb-3 border-bottom">
                            <span>Kargo Ücreti</span>
                            <span class="text-success fw-bold">Ücretsiz</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4 mt-2">
                            <span class="fw-bold text-dark fs-5">Genel Toplam</span>
                            <span class="fw-bold text-gold fs-4">@toplamTutar.ToString("C2")</span>
                        </div>

                        <a href="/Siparis/Odeme" class="btn btn-dark btn-lg w-100 rounded-0 py-3 text-uppercase fw-bold letter-spacing-1 hover-gold-bg border-0 shadow-sm mb-3">
                            Güvenle Öde <i class="fa-solid fa-shield-halved ms-2"></i>
                        </a>

                        <a href="/" class="btn btn-outline-secondary w-100 rounded-0 py-2 text-uppercase fw-semibold transition-300 border-0">
                            <i class="fa-solid fa-arrow-left me-2"></i>Alışverişe Devam Et
                        </a>
                    </div>
                    <div class="card-footer bg-light border-top-0 text-center py-3">
                        <div class="d-flex justify-content-center gap-2 opacity-50">
                            <i class="fa-brands fa-cc-visa fs-4"></i>
                            <i class="fa-brands fa-cc-mastercard fs-4"></i>
                            <i class="fa-brands fa-cc-amex fs-4"></i>
                        </div>
                        <small class="text-muted d-block mt-2" style="font-size: 0.70rem;">256-bit SSL Sertifikası ile güvenli ödeme</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <style>
        .text-gold {
            color: #D4AF37 !important;
        }

        .hover-gold:hover {
            color: #D4AF37 !important;
            transition: 0.3s;
        }

        .hover-gold-bg:hover {
            background-color: #D4AF37 !important;
            color: #fff !important;
            transition: 0.3s;
        }

        .font-playfair {
            font-family: 'Playfair Display', serif;
        }

        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        .transition-300 {
            transition: 0.3s ease;
        }
        /* Sayı inputunun oklarını gizler */
        input[type=number]::-webkit-inner-spin-button,
        input[type=number]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Silme Onay Fonksiyonu
        function urunSilOnay(e, formElement) {
            e.preventDefault();
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu şık tasarımı sepetinizden çıkarmak istediğinize emin misiniz?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0B132B',
                cancelButtonColor: '#dc3545',
                confirmButtonText: '<i class="fa-solid fa-trash-can me-1"></i> Evet, Çıkar',
                cancelButtonText: 'Vazgeç',
                background: '#f8f9fa',
                customClass: {
                    title: 'font-playfair fw-bold',
                    confirmButton: 'rounded-0 px-4 letter-spacing-1 fw-bold',
                    cancelButton: 'rounded-0 px-4 letter-spacing-1 fw-bold'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    formElement.submit();
                }
            });
        }

        // Miktar Güncelleme ve Stok Kontrolü
        function miktarGuncelle(btn, degisim) {
            var form = btn.closest('form');
            var input = form.querySelector('input[type="number"]');
            var mevcutDeger = parseInt(input.value);
            var maksimumStok = parseInt(input.getAttribute('data-stok'));

            var yeniDeger = mevcutDeger + degisim;

            // Değer 1'den küçük olamaz
            if (yeniDeger < 1) return;

            // Stok sınırı kontrolü
            if (yeniDeger > maksimumStok) {
                Swal.fire({
                    title: 'Stok Sınırı',
                    text: 'Maalesef bu şık parçadan stoklarımızda sadece ' + maksimumStok + ' adet kaldı.',
                    icon: 'info',
                    confirmButtonColor: '#D4AF37',
                    confirmButtonText: 'Anladım',
                    customClass: {
                        title: 'font-playfair fw-bold',
                        confirmButton: 'rounded-0 px-4 letter-spacing-1 fw-bold text-dark'
                    }
                });
                return;
            }

            // Değeri ekranda güncelle ve formu otomatik olarak sunucuya gönder
            input.value = yeniDeger;
            form.submit();
        }
    </script>
}